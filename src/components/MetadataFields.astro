---
interface Props {
  t: any;
  initial: {
    address: string;
    published_at: string;
    version_date: string;
    rss_url: string;
    repository_url: string;
  };
}

const { t, initial } = Astro.props;
---

<div id="address-container" class="form-control hidden">
  <label class="label"><span class="form-label">{t.address}</span></label>
  <div class="relative">
    <input type="text" id="address-search" value={initial.address} placeholder={t.addressPlaceholder} maxlength="255" class="input input-bordered w-full" autocomplete="off" />
    <input type="hidden" name="address-value" value={initial.address} />
    <div id="address-results" class="absolute left-0 right-0 top-full mt-1 bg-white border rounded-lg shadow-xl z-50 hidden max-h-48 overflow-y-auto"></div>
  </div>
  <div id="online-toggle-container" class="mt-2 hidden">
    <label class="label cursor-pointer justify-start gap-4">
      <input type="checkbox" id="online-toggle" class="checkbox checkbox-primary checkbox-sm" />
      <span class="form-label font-bold text-stone-500">{t.online}</span>
    </label>
  </div>
</div>

<div id="occurrences-container" class="form-control hidden space-y-4">
  <div class="flex justify-between items-center">
    <span class="form-label font-bold text-stone-600">{t.occurrences}</span>
    <button type="button" id="add-occurrence" class="btn btn-xs btn-outline btn-primary">{t.addOccurrence}</button>
  </div>
  <div id="occurrences-list" class="space-y-4"></div>
</div>

<div id="pub-date-container" class="form-control hidden">
  <label class="label"><span class="form-label">{t.pubDate}</span></label>
  <input type="date" name="published_at" value={initial.published_at} class="input input-bordered w-full" />
</div>

<div id="rss-url-container" class="form-control hidden">
  <label class="label"><span class="form-label">{t.rssUrl}</span></label>
  <input type="url" name="rss_url" value={initial.rss_url} placeholder="https://..." class="input input-bordered w-full" />
</div>

<div id="repository-url-container" class="form-control hidden">
  <label class="label"><span class="form-label">{t.repositoryUrl}</span></label>
  <input type="url" name="repository_url" value={initial.repository_url} placeholder="https://github.com/..." class="input input-bordered w-full" />
</div>

<div id="version-date-container" class="form-control hidden">
  <label class="label"><span class="form-label">{t.versionDate}</span></label>
  <input type="date" name="version_date" value={initial.version_date} class="input input-bordered w-full" />
</div>

<div id="related-container" class="form-control hidden">
  <label class="label"><span class="form-label">{t.related}</span></label>
  <div class="relative">
    <input type="text" id="related-search" placeholder={t.relatedPlaceholder} maxlength="100" class="input input-bordered w-full" autocomplete="off" />
    <div id="related-results" class="absolute left-0 right-0 top-full mt-1 bg-white border rounded-lg shadow-xl z-40 hidden max-h-48 overflow-y-auto"></div>
  </div>
  <div id="selected-related" class="flex flex-wrap gap-2 mt-2"></div>
</div>
