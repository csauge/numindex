---
import { CATEGORIES, ACTION_ICONS } from '../utils/categories';
import { fetchResourceById, fetchSuggestionById } from '../lib/services';
import type { SuggestionAction, Resource, Suggestion } from '../lib/supabase/types';
import SuggestionPreview from './SuggestionPreview.astro';
import MetadataFields from './MetadataFields.astro';

interface Props {
  lang: 'fr' | 'en';
  resourceId?: string | null;
  suggestionId?: string | null;
  action?: SuggestionAction;
  isModeration?: boolean;
}

const { lang, resourceId, suggestionId, action: propAction, isModeration = false } = Astro.props;

// Fetch data server-side
let existingData: Resource | Suggestion | null = null;
let action = propAction || 'create';

if (suggestionId) {
  existingData = await fetchSuggestionById(suggestionId);
  if (existingData) {
    action = (existingData as Suggestion).action;
  }
} else if (resourceId) {
  existingData = await fetchResourceById(resourceId);
}

const t = {
  fr: {
    titleCreate: isModeration ? 'Corriger la proposition' : 'Proposer un ajout',
    titleUpdate: isModeration ? 'Corriger la modification' : 'Proposer une modification',
    titleDelete: 'Proposer une suppression',
    name: 'Nom de la ressource',
    description: 'Description',
    link: 'Lien (URL)',
    category: 'Catégorie',
    mandatoryTag: 'Sous-catégorie (Obligatoire)',
    optionalTags: 'Tags qualificatifs',
    related: 'Organisations / Personnes liées',
    relatedPlaceholder: 'Chercher...',
    image: 'Image',
    imageHelp: 'Préféré : SVG, AVIF, WebP (ou PNG, JPG)',
    reason: 'Motif suppression',
    target: 'Aperçu :',
    submitCreate: isModeration ? 'Enregistrer les corrections' : 'Envoyer la proposition',
    submitUpdate: isModeration ? 'Enregistrer les corrections' : 'Envoyer la modification',
    submitDelete: 'Confirmer la suppression',
    loading: 'Envoi...',
    success: isModeration ? 'Corrections enregistrées !' : 'Suggestion envoyée !',
    error: 'Erreur technique.',
    address: 'Adresse / Lieu',
    addressPlaceholder: 'Ex: 12 rue de la Paix, Paris',
    pubDate: 'Date parution',
    versionDate: 'Date mise à jour',
    occurrences: 'Éditions / Dates',
    addOccurrence: 'Ajouter une date',
    start: 'Début',
    end: 'Fin',
    online: 'En ligne / Online',
  },
  en: {
    titleCreate: isModeration ? 'Correct proposal' : 'Suggest addition',
    titleUpdate: isModeration ? 'Correct modification' : 'Suggest modification',
    titleDelete: 'Suggest deletion',
    name: 'Resource name',
    description: 'Description',
    link: 'Link (URL)',
    category: 'Category',
    mandatoryTag: 'Sub-category (Mandatory)',
    optionalTags: 'Qualifiers',
    related: 'Related Organizations / People',
    relatedPlaceholder: 'Search...',
    image: 'Image',
    imageHelp: 'Preferred: SVG, AVIF, WebP (or PNG, JPG)',
    reason: 'Reason',
    target: 'Preview:',
    submitCreate: isModeration ? 'Save corrections' : 'Send suggestion',
    submitUpdate: isModeration ? 'Save corrections' : 'Send modification',
    submitDelete: 'Confirm deletion',
    loading: 'Sending...',
    success: isModeration ? 'Corrections saved!' : 'Suggestion sent!',
    error: 'Error occurred.',
    address: 'Address / Location',
    addressPlaceholder: 'Ex: 12 Oxford St, London',
    pubDate: 'Publication date',
    versionDate: 'Update date',
    occurrences: 'Editions / Dates',
    addOccurrence: 'Add a date',
    start: 'Start',
    end: 'End',
    online: 'Online',
  }
}[lang];

const isDelete = action === 'delete';
const isUpdate = action === 'update';
const title = isDelete ? t.titleDelete : (isUpdate ? t.titleUpdate : t.titleCreate);
const submitText = isDelete ? t.submitDelete : (isUpdate ? t.submitUpdate : t.submitCreate);

// Initial values for SSR pre-filling
const initial = {
  title: existingData?.title || '',
  description: existingData?.description || '',
  category: (existingData?.category as any) || 'acteur',
  link: existingData?.link || '',
  tags: existingData?.tags || [],
  address: existingData?.metadata?.address || '',
  published_at: existingData?.metadata?.published_at || '',
  version_date: existingData?.metadata?.version_date || '',
  occurrences: existingData?.metadata?.occurrences || [],
};
---

<div class="bg-white rounded-3xl shadow-sm border border-stone-100 p-4 md:p-8 w-full overflow-hidden">
  <h2 class="text-2xl font-black mb-8 flex items-center gap-4">
    <div id="form-icon-container" class={`w-12 h-12 rounded-2xl border flex items-center justify-center flex-shrink-0 ${isDelete ? 'bg-red-50 border-red-100' : 'bg-emerald-50 border-emerald-100'}`}>
      <svg id="action-icon" xmlns="http://www.w3.org/2000/svg" class={`h-6 w-6 ${isDelete ? 'text-red-600' : 'text-emerald-700'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d={ACTION_ICONS[action]} />
      </svg>
    </div>
    <span id="form-title-text" class="truncate text-stone-800">{title}</span>
    <a href={`/${lang}/guide`} class="ml-auto text-xs font-bold text-emerald-600 hover:underline flex items-center gap-1 bg-emerald-50 px-3 py-1.5 rounded-full transition-colors border border-emerald-100" target="_blank">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      {lang === 'fr' ? 'Consulter le guide' : 'Read guide'}
    </a>
  </h2>

  <SuggestionPreview t={t} initialTitle={initial.title} />

  <form id="suggestion-form" class="space-y-4 w-full" data-lang={lang} data-t={JSON.stringify(t)} data-existing={JSON.stringify(existingData)} data-moderation={isModeration.toString()} data-categories={JSON.stringify(CATEGORIES)}>
    <div id="standard-fields" class={isDelete ? 'hidden' : 'space-y-4 w-full'}>
      <div class="form-control w-full">
        <label class="label"><span class="label-text">{t.name}</span></label>
        <input type="text" name="title" value={initial.title} required={!isDelete} maxlength="100" class="input input-bordered w-full" />
      </div>

      <div class="form-control w-full">
        <label class="label"><span class="label-text">{t.description}</span></label>
        <textarea name="description" required={!isDelete} maxlength="1000" class="textarea textarea-bordered h-24 w-full">{initial.description}</textarea>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-control w-full">
          <label class="label"><span class="label-text">{t.category}</span></label>
          <select name="category" class="select select-bordered w-full">
            {Object.entries(CATEGORIES).map(([k, v]) => <option value={k} selected={k === initial.category}>{v[lang as 'fr' | 'en']}</option>)}
          </select>
        </div>
        <div id="mandatory-tag-container" class="form-control w-full">
          <label class="label"><span class="label-text">{t.mandatoryTag}</span></label>
          <select name="mandatory-tag" class="select select-bordered w-full" required={!isDelete}></select>
        </div>
      </div>

      <div id="optional-tags-container" class="form-control w-full">
        <label class="label"><span class="label-text">{t.optionalTags}</span></label>
        <div id="optional-tags-list" class="flex flex-wrap gap-2"></div>
      </div>

      <MetadataFields t={t} initial={initial} />

      <div class="form-control w-full">
        <label class="label"><span class="label-text">{t.link}</span></label>
        <input type="url" name="link" value={initial.link} required={!isDelete} maxlength="2048" class="input input-bordered w-full" />
      </div>

      <div class="form-control w-full">
        <label class="label"><span class="label-text font-bold">{t.image}</span></label>
        <div class="flex gap-2">
          <input type="file" name="image" id="image-input" accept="image/svg+xml,image/avif,image/webp,image/png,image/jpeg" class="file-input file-input-bordered flex-grow" />
          <button type="button" id="clear-image" class="btn btn-ghost border-stone-200 hidden" title={lang === 'fr' ? 'Supprimer l\'image' : 'Remove image'}>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
          </button>
        </div>
        <label class="label"><span class="label-text-alt italic opacity-60">{t.imageHelp}</span></label>
      </div>
    </div>

    <div id="delete-fields" class={!isDelete ? 'hidden' : 'space-y-4 w-full'}>
      <div class="form-control w-full">
        <label class="label"><span class="label-text text-error font-bold">{t.reason}</span></label>
        <textarea name="reason" required={isDelete} maxlength="500" class="textarea textarea-bordered textarea-error h-24 w-full">{(existingData as Suggestion)?.reason || ''}</textarea>
      </div>
    </div>

    <button id="submit-btn" type="submit" class="btn btn-primary w-full mt-4">{submitText}</button>
  </form>

  <div id="toast-container" class="toast toast-middle toast-center z-[100] hidden">
    <div id="toast-message" class="alert shadow-2xl border-none text-white font-black px-12 py-8 rounded-3xl scale-110 transition-transform duration-300">
      <div class="flex flex-col items-center gap-4 text-center">
        <span id="toast-text" class="text-lg"></span>
      </div>
    </div>
  </div>
</div>

<script>
  import { initSuggestionForm } from '../lib/suggestion-client';
  const form = document.getElementById('suggestion-form') as HTMLFormElement;
  if (form) initSuggestionForm(form);
</script>
