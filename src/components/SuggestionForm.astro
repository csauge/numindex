---
import { CATEGORIES, ACTION_ICONS, getCategoryType, getCategoryGroup } from '../utils/categories';
import { fetchResourceById, fetchSuggestionById } from '../lib/services';
import type { SuggestionAction, Resource, Suggestion } from '../lib/supabase/types';

interface Props {
  lang: 'fr' | 'en';
  resourceId?: string | null;
  suggestionId?: string | null;
  action?: SuggestionAction;
  isModeration?: boolean;
}

const { lang, resourceId, suggestionId, action: propAction, isModeration = false } = Astro.props;

// Fetch data server-side
let existingData: Resource | Suggestion | null = null;
let action = propAction || 'create';

if (suggestionId) {
  existingData = await fetchSuggestionById(suggestionId);
  if (existingData) {
    action = (existingData as Suggestion).action;
  }
} else if (resourceId) {
  existingData = await fetchResourceById(resourceId);
}

const t = {
  fr: {
    titleCreate: isModeration ? 'Corriger la proposition' : 'Proposer un ajout',
    titleUpdate: isModeration ? 'Corriger la modification' : 'Proposer une modification',
    titleDelete: 'Proposer une suppression',
    name: 'Nom de la ressource',
    description: 'Description',
    link: 'Lien (URL)',
    category: 'Catégorie',
    tags: 'Tags (séparés par des virgules)',
    related: 'Organisations / Personnes liées',
    relatedPlaceholder: 'Chercher...',
    image: 'Image',
    imageHelp: 'Préféré : SVG, AVIF, WebP (ou PNG, JPG)',
    reason: 'Motif suppression',
    target: 'Aperçu :',
    submitCreate: isModeration ? 'Enregistrer les corrections' : 'Envoyer la proposition',
    submitUpdate: isModeration ? 'Enregistrer les corrections' : 'Envoyer la modification',
    submitDelete: 'Confirmer la suppression',
    loading: 'Envoi...',
    success: isModeration ? 'Corrections enregistrées !' : 'Suggestion envoyée !',
    error: 'Erreur technique.',
    city: 'Ville',
    cityPlaceholder: 'Rechercher...',
    pubDate: 'Date parution',
    nextDate: 'Prochaine date',
  },
  en: {
    titleCreate: isModeration ? 'Correct proposal' : 'Suggest addition',
    titleUpdate: isModeration ? 'Correct modification' : 'Suggest modification',
    titleDelete: 'Suggest deletion',
    name: 'Resource name',
    description: 'Description',
    link: 'Link (URL)',
    category: 'Category',
    tags: 'Tags (comma separated)',
    related: 'Related Organizations / People',
    relatedPlaceholder: 'Search...',
    image: 'Image',
    imageHelp: 'Preferred: SVG, AVIF, WebP (or PNG, JPG)',
    reason: 'Reason',
    target: 'Preview:',
    submitCreate: isModeration ? 'Save corrections' : 'Send suggestion',
    submitUpdate: isModeration ? 'Save corrections' : 'Send modification',
    submitDelete: 'Confirm deletion',
    loading: 'Sending...',
    success: isModeration ? 'Corrections saved!' : 'Suggestion sent!',
    error: 'Error occurred.',
    city: 'City',
    cityPlaceholder: 'Search...',
    pubDate: 'Publication date',
    nextDate: 'Next date',
  }
}[lang];

const isDelete = action === 'delete';
const isUpdate = action === 'update';
const title = isDelete ? t.titleDelete : (isUpdate ? t.titleUpdate : t.titleCreate);
const submitText = isDelete ? t.submitDelete : (isUpdate ? t.submitUpdate : t.submitCreate);

// Initial values for SSR pre-filling
const initial = {
  title: existingData?.title || '',
  description: existingData?.description || '',
  category: existingData?.category || 'societe',
  link: existingData?.link || '',
  tags: existingData?.tags?.join(', ') || '',
  city: existingData?.metadata?.city || '',
  published_at: existingData?.metadata?.published_at || '',
  next_date: existingData?.metadata?.next_date || '',
};
---

<div class="max-w-2xl mx-auto p-6 bg-base-100 rounded-xl shadow-sm border border-base-200">
  <h2 class="text-2xl font-bold mb-6 flex items-center gap-3">
    <div id="form-icon-container" class={`p-2 rounded-lg border flex items-center justify-center ${isDelete ? 'bg-red-50 border-red-100' : 'bg-stone-50 border-stone-100'}`}>
      <svg id="action-icon" xmlns="http://www.w3.org/2000/svg" class={`h-6 w-6 ${isDelete ? 'text-error' : 'text-primary'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ACTION_ICONS[action]} />
      </svg>
    </div>
    <span id="form-title-text">{title}</span>
  </h2>

  <div id="resource-preview-block" class="mb-8 p-4 bg-stone-50 border border-stone-200 rounded-xl flex items-center gap-4">
    <div id="preview-img" class="w-20 h-20 rounded-lg bg-white border border-stone-200 overflow-hidden flex-shrink-0 flex items-center justify-center text-stone-200"></div>
    <div class="flex-grow">
      <p class="text-[10px] font-bold text-stone-400 uppercase tracking-widest mb-1">{t.target}</p>
      <p id="preview-title" class="font-bold text-stone-800 leading-tight">{initial.title || '...'}</p>
      <div class="flex gap-2 mt-1 flex-wrap">
        <span id="badge-cat" class="text-[9px] font-bold uppercase text-stone-400"></span>
        <span id="badge-city" class="text-[9px] font-bold uppercase text-stone-400 hidden"></span>
        <span id="badge-date" class="text-[9px] font-bold uppercase text-stone-400 hidden"></span>
        <span id="badge-next-date" class="text-[9px] font-bold uppercase text-emerald-600 hidden"></span>
      </div>
    </div>
  </div>

  <form id="suggestion-form" class="space-y-4" data-lang={lang} data-t={JSON.stringify(t)} data-existing={JSON.stringify(existingData)} data-moderation={isModeration.toString()}>
    <div id="standard-fields" class={isDelete ? 'hidden' : 'space-y-4'}>
      <div class="form-control">
        <label class="label"><span class="label-text">{t.name}</span></label>
        <input type="text" name="title" value={initial.title} required={!isDelete} class="input input-bordered" />
      </div>

      <div class="form-control">
        <label class="label"><span class="label-text">{t.description}</span></label>
        <textarea name="description" required={!isDelete} class="textarea textarea-bordered h-24">{initial.description}</textarea>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-control">
          <label class="label"><span class="label-text">{t.category}</span></label>
          <select name="category" class="select select-bordered">
            {Object.entries(CATEGORIES).map(([k, v]) => <option value={k} selected={k === initial.category}>{v[lang]}</option>)}
          </select>
        </div>
      </div>

      <div id="city-container" class="form-control hidden">
        <label class="label"><span class="label-text">{t.city}</span></label>
        <div class="relative">
          <input type="text" id="city-search" value={initial.city} placeholder={t.cityPlaceholder} class="input input-bordered w-full" autocomplete="off" />
          <input type="hidden" name="city-value" value={initial.city} />
          <div id="city-results" class="absolute left-0 right-0 top-full mt-1 bg-white border rounded-lg shadow-xl z-50 hidden max-h-48 overflow-y-auto"></div>
        </div>
      </div>

      <div id="date-container" class="form-control hidden">
        <label class="label"><span class="label-text" id="date-label">{t.pubDate}</span></label>
        <input type="date" name="published_at" value={initial.published_at} class="input input-bordered w-full" />
      </div>

      <div id="next-date-container" class="form-control hidden">
        <label class="label"><span class="label-text">{t.nextDate}</span></label>
        <input type="date" name="next_date" value={initial.next_date} class="input input-bordered w-full" />
      </div>

      <div id="related-container" class="form-control hidden">
        <label class="label"><span class="label-text">{t.related}</span></label>
        <div class="relative">
          <input type="text" id="related-search" placeholder={t.relatedPlaceholder} class="input input-bordered w-full" autocomplete="off" />
          <div id="related-results" class="absolute left-0 right-0 top-full mt-1 bg-white border rounded-lg shadow-xl z-40 hidden max-h-48 overflow-y-auto"></div>
        </div>
        <div id="selected-related" class="flex flex-wrap gap-2 mt-2"></div>
      </div>

      <div class="form-control">
        <label class="label"><span class="label-text">{t.link}</span></label>
        <input type="url" name="link" value={initial.link} required={!isDelete} class="input input-bordered" />
      </div>

      <div class="form-control">
        <label class="label"><span class="label-text">{t.tags}</span></label>
        <input type="text" name="tags" value={initial.tags} class="input input-bordered" />
      </div>

      <div class="form-control">
        <label class="label"><span class="label-text font-bold">{t.image}</span></label>
        <input type="file" name="image" accept="image/svg+xml,image/avif,image/webp,image/png,image/jpeg" class="file-input file-input-bordered" />
        <label class="label"><span class="label-text-alt italic opacity-60">{t.imageHelp}</span></label>
      </div>
    </div>

    <div id="delete-fields" class={!isDelete ? 'hidden' : 'space-y-4'}>
      <div class="form-control">
        <label class="label"><span class="label-text text-error font-bold">{t.reason}</span></label>
        <textarea name="reason" required={isDelete} class="textarea textarea-bordered textarea-error h-24">{(existingData as Suggestion)?.reason || ''}</textarea>
      </div>
    </div>

    <button id="submit-btn" type="submit" class="btn btn-primary w-full mt-4">{submitText}</button>
  </form>

  <div id="toast-container" class="toast toast-middle toast-center z-[100] hidden">
    <div id="toast-message" class="alert shadow-2xl border-none text-white font-black px-12 py-8 rounded-3xl scale-110 transition-transform duration-300">
      <div class="flex flex-col items-center gap-4 text-center">
        <span id="toast-text" class="text-lg"></span>
      </div>
    </div>
  </div>
</div>

<script>
  import { supabase, getImageUrl } from '../lib/supabase/client';
  import { getCategoryIcon, getCategoryLabel, getCategoryType, getCategoryGroup, ACTION_ICONS } from '../utils/categories';
  import { searchCities, uploadCompressedImage, fetchEntities, fetchResourceById, fetchSuggestionById } from '../lib/services';
  import type { Resource, SuggestionAction, Suggestion } from '../lib/supabase/types';

  const form = document.getElementById('suggestion-form') as HTMLFormElement;
  const t = JSON.parse(form.dataset.t!);
  const lang = form.dataset.lang;
  const isModeration = form.dataset.moderation === 'true';
  let existingData = JSON.parse(form.dataset.existing || 'null') as Resource | Suggestion | null;
  const toastContainer = document.getElementById('toast-container');
  const toastMessage = document.getElementById('toast-message');
  const toastText = document.getElementById('toast-text');

  // Détection dynamique des paramètres
  const urlParams = new URLSearchParams(window.location.search);
  const sid = urlParams.get('sid'); // Suggestion ID
  const rid = urlParams.get('id');  // Resource ID
  const action = (urlParams.get('action') || 'create') as SuggestionAction;

  const elements = {
    title: form.querySelector('[name="title"]') as HTMLInputElement,
    desc: form.querySelector('[name="description"]') as HTMLTextAreaElement,
    cat: form.querySelector('[name="category"]') as HTMLSelectElement,
    link: form.querySelector('[name="link"]') as HTMLInputElement,
    tags: form.querySelector('[name="tags"]') as HTMLInputElement,
    img: form.querySelector('[name="image"]') as HTMLInputElement,
    cityVal: form.querySelector('[name="city-value"]') as HTMLInputElement,
    citySearch: document.getElementById('city-search') as HTMLInputElement,
    cityResults: document.getElementById('city-results'),
    dateInput: form.querySelector('[name="published_at"]') as HTMLInputElement,
    nextDateInput: form.querySelector('[name="next_date"]') as HTMLInputElement,
    reason: form.querySelector('[name="reason"]') as HTMLTextAreaElement,
    relatedSearch: document.getElementById('related-search') as HTMLInputElement,
    relatedResults: document.getElementById('related-results'),
    selectedRelated: document.getElementById('selected-related'),
    submitBtn: document.getElementById('submit-btn') as HTMLButtonElement,
    formTitle: document.getElementById('form-title-text'),
    formIcon: document.getElementById('action-icon'),
    formIconContainer: document.getElementById('form-icon-container'),
    preview: {
      title: document.getElementById('preview-title'),
      cat: document.getElementById('badge-cat'),
      city: document.getElementById('badge-city'),
      date: document.getElementById('badge-date'),
      nextDate: document.getElementById('badge-next-date'),
      img: document.getElementById('preview-img')
    }
  };

  let entities: Resource[] = [];
  let selectedIds: string[] = existingData?.related_ids || [];

  async function showToast(message: string, type: 'success' | 'error') {
    if (!toastContainer || !toastMessage || !toastText) return;

    toastText.innerText = message;
    toastMessage.className = `alert shadow-2xl border-none text-white font-black px-12 py-8 rounded-3xl scale-110 transition-all duration-300 ${type === 'success' ? 'bg-primary' : 'bg-error'}`;
    toastContainer.classList.remove('hidden');
    
    if (type === 'success') {
      setTimeout(() => {
        window.location.href = isModeration ? `/${lang}/admin` : `/${lang}`;
      }, 2500);
    } else {
      setTimeout(() => {
        toastContainer.classList.add('hidden');
      }, 5000);
    }
  }

  function updateUI() {
    const type = getCategoryType(elements.cat.value);
    const group = getCategoryGroup(elements.cat.value);
    const currentAction = sid ? (existingData as Suggestion)?.action : action;
    const isDelete = currentAction === 'delete';
    const isEvent = elements.cat.value === 'evenement';

    // Preview
    elements.preview.title!.innerText = elements.title.value || existingData?.title || '...';
    elements.preview.cat!.innerText = getCategoryLabel(elements.cat.value, lang as any);
    
    elements.preview.city!.innerText = elements.cityVal.value || '';
    elements.preview.city!.classList.toggle('hidden', !elements.cityVal.value);
    
    elements.preview.date!.innerText = elements.dateInput.value || '';
    elements.preview.date!.classList.toggle('hidden', !elements.dateInput.value);

    elements.preview.nextDate!.innerText = elements.nextDateInput.value ? `📅 ${elements.nextDateInput.value}` : '';
    elements.preview.nextDate!.classList.toggle('hidden', !elements.nextDateInput.value);

    if (elements.img.files?.[0]) {
      // Image already handled by change listener
    } else {
      const url = getImageUrl(existingData?.image_url);
      elements.preview.img!.innerHTML = url ? `<img src="${url}" class="w-full h-full object-contain" />` : 
        `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="${getCategoryIcon(elements.cat.value)}"/></svg>`;
    }

    // Toggle container visibilities
    document.getElementById('city-container')?.classList.toggle('hidden', (type !== 'entity' && !isEvent) || isDelete);
    document.getElementById('date-container')?.classList.toggle('hidden', group !== 'CONTENUS' || isDelete);
    document.getElementById('next-date-container')?.classList.toggle('hidden', !isEvent || isDelete);
    document.getElementById('related-container')?.classList.toggle('hidden', type !== 'resource' || isDelete);
  }

  function renderRelated() {
    elements.selectedRelated!.innerHTML = selectedIds.map(id => {
      const ent = entities.find(e => e.id === id);
      return `<div class="badge badge-primary gap-2 font-bold py-3">
        ${ent?.title || id} <button type="button" data-id="${id}" class="remove-rel">×</button>
      </div>`;
    }).join('');
    
    elements.selectedRelated!.querySelectorAll('.remove-rel').forEach(btn => {
      btn.addEventListener('click', () => {
        selectedIds = selectedIds.filter(i => i !== (btn as HTMLElement).dataset.id);
        renderRelated();
      });
    });
  }

  // Photon
  let photonTimer: any;
  elements.citySearch.addEventListener('input', (e) => {
    clearTimeout(photonTimer);
    const val = (e.target as HTMLInputElement).value;
    if (val.length < 2) return elements.cityResults!.classList.add('hidden');
    photonTimer = setTimeout(async () => {
      const findRes = await searchCities(val, lang!);
      elements.cityResults!.innerHTML = findRes.map(c => `
        <button type="button" class="w-full text-left px-4 py-2 hover:bg-stone-50 border-b last:border-none" data-label="${c.label}">
          <p class="font-bold text-sm">${c.name}</p><p class="text-[10px] text-stone-400">${c.sub}</p>
        </button>`).join('');
      elements.cityResults!.classList.remove('hidden');
      elements.cityResults!.querySelectorAll('button').forEach(b => b.addEventListener('click', () => {
        elements.citySearch.value = (b as HTMLElement).dataset.label!;
        elements.cityVal.value = (b as HTMLElement).dataset.label!;
        elements.cityResults!.classList.add('hidden');
        updateUI();
      }));
    }, 300);
  });

  // Related search
  elements.relatedSearch.addEventListener('input', (e) => {
    const val = (e.target as HTMLInputElement).value.toLowerCase();
    if (val.length < 1) return elements.relatedResults!.classList.add('hidden');
    const filtered = entities.filter(ent => ent.title.toLowerCase().includes(val) && !selectedIds.includes(ent.id));
    elements.relatedResults!.innerHTML = filtered.map(ent => `<button type="button" class="w-full text-left px-4 py-2 hover:bg-stone-50" data-id="${ent.id}">${ent.title}</button>`).join('');
    elements.relatedResults!.classList.toggle('hidden', filtered.length === 0);
    elements.relatedResults!.querySelectorAll('button').forEach(btn => btn.addEventListener('click', () => {
      selectedIds.push((btn as HTMLElement).dataset.id!);
      elements.relatedSearch.value = '';
      elements.relatedResults!.classList.add('hidden');
      renderRelated();
    }));
  });

  // Init
  async function init() {
    entities = await fetchEntities();

    // Fallback: If SSR didn't fetch existingData
    if (!existingData) {
      if (sid) {
        existingData = await fetchSuggestionById(sid);
      } else if (rid) {
        existingData = await fetchResourceById(rid);
      }

      if (existingData) {
        const currentAction = sid ? (existingData as Suggestion).action : action;
        if (currentAction !== 'delete') {
          elements.title.value = existingData.title;
          elements.desc.value = existingData.description;
          elements.cat.value = existingData.category;
          elements.link.value = existingData.link;
          elements.tags.value = existingData.tags?.join(', ') || '';
          elements.cityVal.value = existingData.metadata?.city || '';
          elements.citySearch.value = existingData.metadata?.city || '';
          elements.dateInput.value = existingData.metadata?.published_at || '';
          elements.nextDateInput.value = existingData.metadata?.next_date || '';
          selectedIds = existingData.related_ids || [];
        } else {
          elements.reason.value = (existingData as Suggestion).reason || '';
        }
      }
    }

    renderRelated();
    updateUI();
    form.addEventListener('input', updateUI);

    // Image preview update on change
    elements.img.addEventListener('change', () => {
      if (elements.img.files?.[0]) {
        const reader = new FileReader();
        reader.onload = (e) => {
          if (elements.preview.img) {
            elements.preview.img.innerHTML = `<img src="${e.target?.result}" class="w-full h-full object-contain" />`;
          }
        };
        reader.readAsDataURL(elements.img.files[0]);
      }
    });
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = elements.submitBtn;
    const currentAction = sid ? (existingData as Suggestion)?.action : action;
    const isDeleteSubmit = currentAction === 'delete';
    
    btn.disabled = true; btn.innerText = t.loading;

    try {
      let imageUrl = existingData?.image_url || null;
      if (elements.img.files?.[0]) imageUrl = await uploadCompressedImage(elements.img.files[0]);

      const tags = elements.tags.value.split(',').map(t => t.trim()).filter(Boolean);
      const metadata = { ...existingData?.metadata };
      if (elements.cityVal.value) metadata.city = elements.cityVal.value;
      if (elements.dateInput.value) metadata.published_at = elements.dateInput.value;
      if (elements.nextDateInput.value) metadata.next_date = elements.nextDateInput.value;

      const payload: any = {
        title: isDeleteSubmit ? existingData?.title : elements.title.value,
        description: isDeleteSubmit ? existingData?.description : elements.desc.value,
        category: isDeleteSubmit ? existingData?.category : elements.cat.value,
        link: isDeleteSubmit ? existingData?.link : elements.link.value,
        tags: isDeleteSubmit ? existingData?.tags : tags,
        related_ids: isDeleteSubmit ? existingData?.related_ids : selectedIds,
        metadata,
        image_url: imageUrl,
        action: currentAction,
        status: 'pending',
        resource_id: sid ? (existingData as Suggestion).resource_id : (rid || null),
        reason: elements.reason.value || null
      };

      if (sid) {
        // Update existing suggestion (Moderator correction)
        const { error: updateError } = await supabase!.from('suggestions').update(payload).eq('id', sid);
        if (updateError) throw updateError;
      } else {
        // New suggestion
        const { error: insertError } = await supabase!.from('suggestions').insert([payload]);
        if (insertError) throw insertError;
      }
      
      showToast(t.success, 'success');
    } catch (err) {
      showToast(t.error, 'error');
      btn.disabled = false; 
      btn.innerText = isDeleteSubmit ? t.submitDelete : t.submitCreate;
    }
  });

  init();
</script>
