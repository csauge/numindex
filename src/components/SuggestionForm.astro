---
import { CATEGORIES, ACTION_ICONS } from '../utils/categories';
import { fetchResourceById, fetchSuggestionById } from '../lib/services';
import type { SuggestionAction, Resource, Suggestion } from '../lib/supabase/types';

interface Props {
  lang: 'fr' | 'en';
  resourceId?: string | null;
  suggestionId?: string | null;
  action?: SuggestionAction;
  isModeration?: boolean;
}

const { lang, resourceId, suggestionId, action: propAction, isModeration = false } = Astro.props;

// Fetch data server-side
let existingData: Resource | Suggestion | null = null;
let action = propAction || 'create';

if (suggestionId) {
  existingData = await fetchSuggestionById(suggestionId);
  if (existingData) {
    action = (existingData as Suggestion).action;
  }
} else if (resourceId) {
  existingData = await fetchResourceById(resourceId);
}

const t = {
  fr: {
    titleCreate: isModeration ? 'Corriger la proposition' : 'Proposer un ajout',
    titleUpdate: isModeration ? 'Corriger la modification' : 'Proposer une modification',
    titleDelete: 'Proposer une suppression',
    name: 'Nom de la ressource',
    description: 'Description',
    link: 'Lien (URL)',
    category: 'Catégorie',
    mandatoryTag: 'Sous-catégorie (Obligatoire)',
    optionalTags: 'Tags qualificatifs',
    related: 'Organisations / Personnes liées',
    relatedPlaceholder: 'Chercher...',
    image: 'Image',
    imageHelp: 'Préféré : SVG, AVIF, WebP (ou PNG, JPG)',
    reason: 'Motif suppression',
    target: 'Aperçu :',
    submitCreate: isModeration ? 'Enregistrer les corrections' : 'Envoyer la proposition',
    submitUpdate: isModeration ? 'Enregistrer les corrections' : 'Envoyer la modification',
    submitDelete: 'Confirmer la suppression',
    loading: 'Envoi...',
    success: isModeration ? 'Corrections enregistrées !' : 'Suggestion envoyée !',
    error: 'Erreur technique.',
    address: 'Adresse / Lieu',
    addressPlaceholder: 'Ex: 12 rue de la Paix, Paris',
    pubDate: 'Date parution',
    versionDate: 'Date mise à jour',
    occurrences: 'Éditions / Dates',
    addOccurrence: 'Ajouter une date',
    start: 'Début',
    end: 'Fin',
    online: 'En ligne / Online',
  },
  en: {
    titleCreate: isModeration ? 'Correct proposal' : 'Suggest addition',
    titleUpdate: isModeration ? 'Correct modification' : 'Suggest modification',
    titleDelete: 'Suggest deletion',
    name: 'Resource name',
    description: 'Description',
    link: 'Link (URL)',
    category: 'Category',
    mandatoryTag: 'Sub-category (Mandatory)',
    optionalTags: 'Qualifiers',
    related: 'Related Organizations / People',
    relatedPlaceholder: 'Search...',
    image: 'Image',
    imageHelp: 'Preferred: SVG, AVIF, WebP (or PNG, JPG)',
    reason: 'Reason',
    target: 'Preview:',
    submitCreate: isModeration ? 'Save corrections' : 'Send suggestion',
    submitUpdate: isModeration ? 'Save corrections' : 'Send modification',
    submitDelete: 'Confirm deletion',
    loading: 'Sending...',
    success: isModeration ? 'Corrections saved!' : 'Suggestion sent!',
    error: 'Error occurred.',
    address: 'Address / Location',
    addressPlaceholder: 'Ex: 12 Oxford St, London',
    pubDate: 'Publication date',
    versionDate: 'Update date',
    occurrences: 'Editions / Dates',
    addOccurrence: 'Add a date',
    start: 'Start',
    end: 'End',
    online: 'Online',
  }
}[lang];

const isDelete = action === 'delete';
const isUpdate = action === 'update';
const title = isDelete ? t.titleDelete : (isUpdate ? t.titleUpdate : t.titleCreate);
const submitText = isDelete ? t.submitDelete : (isUpdate ? t.submitUpdate : t.submitCreate);

// Initial values for SSR pre-filling
const initial = {
  title: existingData?.title || '',
  description: existingData?.description || '',
  category: (existingData?.category as any) || 'acteur',
  link: existingData?.link || '',
  tags: existingData?.tags || [],
  address: existingData?.metadata?.address || '',
  published_at: existingData?.metadata?.published_at || '',
  version_date: existingData?.metadata?.version_date || '',
  occurrences: existingData?.metadata?.occurrences || [],
};
---

<div class="bg-white rounded-3xl shadow-sm border border-stone-100 p-4 md:p-8 w-full overflow-hidden">
  <h2 class="text-2xl font-black mb-8 flex items-center gap-4">
    <div id="form-icon-container" class={`w-12 h-12 rounded-2xl border flex items-center justify-center flex-shrink-0 ${isDelete ? 'bg-red-50 border-red-100' : 'bg-emerald-50 border-emerald-100'}`}>
      <svg id="action-icon" xmlns="http://www.w3.org/2000/svg" class={`h-6 w-6 ${isDelete ? 'text-red-600' : 'text-emerald-700'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d={ACTION_ICONS[action]} />
      </svg>
    </div>
    <span id="form-title-text" class="truncate text-stone-800">{title}</span>
  </h2>

  <div id="resource-preview-block" class="mb-8 p-5 bg-stone-50/50 border border-stone-100 rounded-2xl flex items-center gap-4 overflow-hidden">
    <div id="preview-img" class="w-16 h-16 md:w-20 md:h-20 rounded-lg bg-white border border-stone-200 overflow-hidden flex-shrink-0 flex items-center justify-center text-stone-200"></div>
    <div class="flex-grow min-w-0">
      <p class="text-[10px] font-bold text-stone-400 uppercase tracking-widest mb-1">{t.target}</p>
      <p id="preview-title" class="font-bold text-stone-800 leading-tight truncate">{initial.title || '...'}</p>
      <div id="preview-badges" class="flex gap-2 mt-1 flex-wrap overflow-hidden">
        <span id="badge-cat" class="text-[9px] font-bold uppercase text-stone-400"></span>
      </div>
    </div>
  </div>

  <form id="suggestion-form" class="space-y-4 w-full" data-lang={lang} data-t={JSON.stringify(t)} data-existing={JSON.stringify(existingData)} data-moderation={isModeration.toString()} data-categories={JSON.stringify(CATEGORIES)}>
    <div id="standard-fields" class={isDelete ? 'hidden' : 'space-y-4 w-full'}>
      <div class="form-control w-full">
        <label class="label"><span class="label-text">{t.name}</span></label>
        <input type="text" name="title" value={initial.title} required={!isDelete} class="input input-bordered w-full" />
      </div>

      <div class="form-control w-full">
        <label class="label"><span class="label-text">{t.description}</span></label>
        <textarea name="description" required={!isDelete} class="textarea textarea-bordered h-24 w-full">{initial.description}</textarea>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-control w-full">
          <label class="label"><span class="label-text">{t.category}</span></label>
          <select name="category" class="select select-bordered w-full">
            {Object.entries(CATEGORIES).map(([k, v]) => <option value={k} selected={k === initial.category}>{v[lang]}</option>)}
          </select>
        </div>
        <div id="mandatory-tag-container" class="form-control w-full">
          <label class="label"><span class="label-text">{t.mandatoryTag}</span></label>
          <select name="mandatory-tag" class="select select-bordered w-full" required={!isDelete}></select>
        </div>
      </div>

      <div id="optional-tags-container" class="form-control w-full">
        <label class="label"><span class="label-text">{t.optionalTags}</span></label>
        <div id="optional-tags-list" class="flex flex-wrap gap-2"></div>
      </div>

      {/* Metadata : Adresse (Acteurs & Evenements) */}
      <div id="address-container" class="form-control hidden">
        <label class="label"><span class="label-text">{t.address}</span></label>
        <div class="relative">
          <input type="text" id="address-search" value={initial.address} placeholder={t.addressPlaceholder} class="input input-bordered w-full" autocomplete="off" />
          <input type="hidden" name="address-value" value={initial.address} />
          <div id="address-results" class="absolute left-0 right-0 top-full mt-1 bg-white border rounded-lg shadow-xl z-50 hidden max-h-48 overflow-y-auto"></div>
        </div>
        <div id="online-toggle-container" class="mt-2 hidden">
          <label class="label cursor-pointer justify-start gap-4">
            <input type="checkbox" id="online-toggle" class="checkbox checkbox-primary checkbox-sm" />
            <span class="label-text font-bold text-stone-500">{t.online}</span>
          </label>
        </div>
      </div>

      {/* Metadata : Occurrences (Evenements) */}
      <div id="occurrences-container" class="form-control hidden space-y-4">
        <div class="flex justify-between items-center">
          <span class="label-text font-bold text-stone-600">{t.occurrences}</span>
          <button type="button" id="add-occurrence" class="btn btn-xs btn-outline btn-primary">{t.addOccurrence}</button>
        </div>
        <div id="occurrences-list" class="space-y-4"></div>
      </div>

      {/* Metadata : Dates spécifiques */}
      <div id="pub-date-container" class="form-control hidden">
        <label class="label"><span class="label-text">{t.pubDate}</span></label>
        <input type="date" name="published_at" value={initial.published_at} class="input input-bordered w-full" />
      </div>

      <div id="version-date-container" class="form-control hidden">
        <label class="label"><span class="label-text">{t.versionDate}</span></label>
        <input type="date" name="version_date" value={initial.version_date} class="input input-bordered w-full" />
      </div>

      <div id="related-container" class="form-control hidden">
        <label class="label"><span class="label-text">{t.related}</span></label>
        <div class="relative">
          <input type="text" id="related-search" placeholder={t.relatedPlaceholder} class="input input-bordered w-full" autocomplete="off" />
          <div id="related-results" class="absolute left-0 right-0 top-full mt-1 bg-white border rounded-lg shadow-xl z-40 hidden max-h-48 overflow-y-auto"></div>
        </div>
        <div id="selected-related" class="flex flex-wrap gap-2 mt-2"></div>
      </div>

      <div class="form-control w-full">
        <label class="label"><span class="label-text">{t.link}</span></label>
        <input type="url" name="link" value={initial.link} required={!isDelete} class="input input-bordered w-full" />
      </div>

      <div class="form-control w-full">
        <label class="label"><span class="label-text font-bold">{t.image}</span></label>
        <input type="file" name="image" accept="image/svg+xml,image/avif,image/webp,image/png,image/jpeg" class="file-input file-input-bordered w-full" />
        <label class="label"><span class="label-text-alt italic opacity-60">{t.imageHelp}</span></label>
      </div>
    </div>

    <div id="delete-fields" class={!isDelete ? 'hidden' : 'space-y-4 w-full'}>
      <div class="form-control w-full">
        <label class="label"><span class="label-text text-error font-bold">{t.reason}</span></label>
        <textarea name="reason" required={isDelete} class="textarea textarea-bordered textarea-error h-24 w-full">{(existingData as Suggestion)?.reason || ''}</textarea>
      </div>
    </div>

    <button id="submit-btn" type="submit" class="btn btn-primary w-full mt-4">{submitText}</button>
  </form>

  <div id="toast-container" class="toast toast-middle toast-center z-[100] hidden">
    <div id="toast-message" class="alert shadow-2xl border-none text-white font-black px-12 py-8 rounded-3xl scale-110 transition-transform duration-300">
      <div class="flex flex-col items-center gap-4 text-center">
        <span id="toast-text" class="text-lg"></span>
      </div>
    </div>
  </div>
</div>

<script>
  import { supabase, getImageUrl } from '../lib/supabase/client';
  import { ACTION_ICONS } from '../utils/categories';
  import { searchAddresses, uploadCompressedImage, fetchEntities, fetchResourceById, fetchSuggestionById } from '../lib/services';
  import type { Resource, SuggestionAction, Suggestion } from '../lib/supabase/types';

  const form = document.getElementById('suggestion-form') as HTMLFormElement;
  const t = JSON.parse(form.dataset.t!);
  const lang = form.dataset.lang as 'fr' | 'en';
  const isModeration = form.dataset.moderation === 'true';
  const CATEGORIES = JSON.parse(form.dataset.categories!);
  let existingData = JSON.parse(form.dataset.existing || 'null') as Resource | Suggestion | null;
  const toastContainer = document.getElementById('toast-container');
  const toastMessage = document.getElementById('toast-message');
  const toastText = document.getElementById('toast-text');

  const elements = {
    title: form.querySelector('[name="title"]') as HTMLInputElement,
    desc: form.querySelector('[name="description"]') as HTMLTextAreaElement,
    cat: form.querySelector('[name="category"]') as HTMLSelectElement,
    mandatoryTag: form.querySelector('[name="mandatory-tag"]') as HTMLSelectElement,
    optionalTagsList: document.getElementById('optional-tags-list'),
    link: form.querySelector('[name="link"]') as HTMLInputElement,
    img: form.querySelector('[name="image"]') as HTMLInputElement,
    addressVal: form.querySelector('[name="address-value"]') as HTMLInputElement,
    addressSearch: document.getElementById('address-search') as HTMLInputElement,
    addressResults: document.getElementById('address-results'),
    onlineToggle: document.getElementById('online-toggle') as HTMLInputElement,
    pubDateInput: form.querySelector('[name="published_at"]') as HTMLInputElement,
    versionDateInput: form.querySelector('[name="version_date"]') as HTMLInputElement,
    occurrencesList: document.getElementById('occurrences-list'),
    addOccurrenceBtn: document.getElementById('add-occurrence'),
    reason: form.querySelector('[name="reason"]') as HTMLTextAreaElement,
    relatedSearch: document.getElementById('related-search') as HTMLInputElement,
    relatedResults: document.getElementById('related-results'),
    selectedRelated: document.getElementById('selected-related'),
    submitBtn: document.getElementById('submit-btn') as HTMLButtonElement,
    preview: {
      title: document.getElementById('preview-title'),
      cat: document.getElementById('badge-cat'),
      img: document.getElementById('preview-img'),
      badges: document.getElementById('preview-badges')
    }
  };

  let entities: Resource[] = [];
  let selectedRelatedIds: string[] = [];
  let selectedOptionalTags: string[] = [];
  let occurrences: any[] = [];

  async function showToast(message: string, type: 'success' | 'error') {
    if (!toastContainer || !toastMessage || !toastText) return;
    toastText.innerText = message;
    toastMessage.className = `alert shadow-2xl border-none text-white font-black px-12 py-8 rounded-3xl scale-110 transition-all duration-300 ${type === 'success' ? 'bg-primary' : 'bg-error'}`;
    toastContainer.classList.remove('hidden');
    if (type === 'success') {
      setTimeout(() => window.location.href = isModeration ? `/${lang}/admin` : `/${lang}`, 2500);
    } else {
      setTimeout(() => toastContainer.classList.add('hidden'), 5000);
    }
  }

  function updateMandatoryTags() {
    const cat = elements.cat.value;
    const tags = CATEGORIES[cat].mandatoryTags;
    elements.mandatoryTag.innerHTML = tags.map((tag: string) => `<option value="${tag}">${tag}</option>`).join('');
    
    // Si on a des données existantes, on essaie de matcher le premier tag obligatoire
    if (existingData?.tags) {
      const match = tags.find((t: string) => existingData?.tags.includes(t));
      if (match) elements.mandatoryTag.value = match;
    }
  }

  function updateOptionalTags() {
    const cat = elements.cat.value;
    const tags = CATEGORIES[cat].optionalTags;
    elements.optionalTagsList!.innerHTML = tags.map((tag: string) => {
      const isChecked = selectedOptionalTags.includes(tag);
      return `<button type="button" data-tag="${tag}" class="btn btn-xs ${isChecked ? 'btn-primary' : 'btn-outline'}">${tag}</button>`;
    }).join('');

    elements.optionalTagsList!.querySelectorAll('button').forEach(btn => {
      btn.addEventListener('click', () => {
        const tag = (btn as HTMLElement).dataset.tag!;
        if (selectedOptionalTags.includes(tag)) {
          selectedOptionalTags = selectedOptionalTags.filter(t => t !== tag);
        } else {
          selectedOptionalTags.push(tag);
        }
        updateOptionalTags();
        updateUI();
      });
    });
  }

  function renderOccurrences() {
    elements.occurrencesList!.innerHTML = occurrences.map((occ, index) => `
      <div class="bg-stone-50 p-4 rounded-xl border border-stone-200 relative space-y-3">
        <button type="button" class="btn btn-xs btn-circle btn-ghost absolute top-2 right-2 remove-occ" data-index="${index}">✕</button>
        <div class="grid grid-cols-2 gap-2">
          <div class="form-control">
            <label class="label p-1"><span class="label-text text-[10px] uppercase font-bold text-stone-400">${t.start}</span></label>
            <input type="datetime-local" class="input input-sm input-bordered occ-start" value="${occ.start || ''}" data-index="${index}" />
          </div>
          <div class="form-control">
            <label class="label p-1"><span class="label-text text-[10px] uppercase font-bold text-stone-400">${t.end}</span></label>
            <input type="datetime-local" class="input input-sm input-bordered occ-end" value="${occ.end || ''}" data-index="${index}" />
          </div>
        </div>
        <div class="form-control">
          <label class="label p-1"><span class="label-text text-[10px] uppercase font-bold text-stone-400">${t.address}</span></label>
          <input type="text" class="input input-sm input-bordered occ-addr" value="${occ.address || ''}" data-index="${index}" placeholder="${t.addressPlaceholder}" />
        </div>
      </div>
    `).join('');

    elements.occurrencesList!.querySelectorAll('.remove-occ').forEach(btn => {
      btn.addEventListener('click', () => {
        occurrences.splice(parseInt((btn as HTMLElement).dataset.index!), 1);
        renderOccurrences();
        updateUI();
      });
    });

    // Listeners for inputs
    elements.occurrencesList!.querySelectorAll('input').forEach(input => {
      input.addEventListener('change', (e) => {
        const idx = parseInt((e.target as HTMLInputElement).dataset.index!);
        const field = (e.target as HTMLInputElement).classList.contains('occ-start') ? 'start' : 
                      ((e.target as HTMLInputElement).classList.contains('occ-end') ? 'end' : 'address');
        occurrences[idx][field] = (e.target as HTMLInputElement).value;
        updateUI();
      });
    });
  }

  function updateUI() {
    const cat = elements.cat.value;
    const isActeur = cat === 'acteur';
    const isEvenement = cat === 'evenement';
    const isContenu = cat === 'contenu';
    const isOutil = cat === 'outil';
    const isDelete = (elements.reason.closest('#delete-fields') as HTMLElement)?.classList.contains('hidden') === false;

    // Preview
    elements.preview.title!.innerText = elements.title.value || '...';
    elements.preview.cat!.innerText = CATEGORIES[cat][lang];
    
    // Clear old badges
    elements.preview.badges!.innerHTML = `<span id="badge-cat" class="text-[9px] font-bold uppercase text-stone-400">${CATEGORIES[cat][lang]}</span>`;
    if (elements.mandatoryTag.value) {
      elements.preview.badges!.innerHTML += `<span class="text-[9px] font-bold uppercase text-primary">${elements.mandatoryTag.value}</span>`;
    }
    if (elements.addressVal.value) {
      elements.preview.badges!.innerHTML += `<span class="text-[9px] font-bold uppercase text-stone-400 border-l border-stone-200 pl-2 ml-1">${elements.addressVal.value}</span>`;
    }
    if (elements.pubDateInput.value) {
      const year = elements.pubDateInput.value.split('-')[0];
      elements.preview.badges!.innerHTML += `<span class="text-[9px] font-bold uppercase text-stone-400 border-l border-stone-200 pl-2 ml-1">${year}</span>`;
    }
    if (elements.versionDateInput.value) {
      const year = elements.versionDateInput.value.split('-')[0];
      elements.preview.badges!.innerHTML += `<span class="text-[9px] font-bold uppercase text-stone-400 border-l border-stone-200 pl-2 ml-1">v.${year}</span>`;
    }
    selectedOptionalTags.forEach(tag => {
      elements.preview.badges!.innerHTML += `<span class="text-[9px] font-bold uppercase text-stone-400 border border-stone-200 px-1 rounded">#${tag}</span>`;
    });

    if (elements.img.files?.[0]) {
      // FileReader logic handled in listener
    } else {
      const url = getImageUrl(existingData?.image_url);
      elements.preview.img!.innerHTML = url ? `<img src="${url}" class="w-full h-full object-contain" />` : 
        `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-stone-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="${CATEGORIES[cat].icon}" stroke-width="2"/></svg>`;
    }

    // Toggle fields
    document.getElementById('address-container')?.classList.toggle('hidden', (!isActeur && !isEvenement) || isDelete);
    document.getElementById('online-toggle-container')?.classList.toggle('hidden', !isEvenement);
    document.getElementById('occurrences-container')?.classList.toggle('hidden', !isEvenement || isDelete);
    document.getElementById('pub-date-container')?.classList.toggle('hidden', !isContenu || isDelete);
    document.getElementById('version-date-container')?.classList.toggle('hidden', !isOutil || isDelete);
    document.getElementById('related-container')?.classList.toggle('hidden', isActeur || isDelete);
  }

  // Address search (Photon)
  let addressTimer: any;
  elements.addressSearch.addEventListener('input', (e) => {
    clearTimeout(addressTimer);
    const val = (e.target as HTMLInputElement).value;
    if (val.length < 2) return elements.addressResults!.classList.add('hidden');
    addressTimer = setTimeout(async () => {
      const findRes = await searchAddresses(val, lang);
      elements.addressResults!.innerHTML = findRes.map(c => `
        <button type="button" class="w-full text-left px-4 py-2 hover:bg-stone-50 border-b last:border-none" data-label="${c.label}">
          <p class="font-bold text-sm">${c.name}</p><p class="text-[10px] text-stone-400">${c.sub}</p>
        </button>`).join('');
      elements.addressResults!.classList.remove('hidden');
      elements.addressResults!.querySelectorAll('button').forEach(b => b.addEventListener('click', () => {
        elements.addressSearch.value = (b as HTMLElement).dataset.label!;
        elements.addressVal.value = (b as HTMLElement).dataset.label!;
        elements.addressResults!.classList.add('hidden');
        updateUI();
      }));
    }, 300);
  });

  elements.onlineToggle.addEventListener('change', (e) => {
    if ((e.target as HTMLInputElement).checked) {
      elements.addressSearch.value = t.online;
      elements.addressVal.value = t.online;
    } else {
      elements.addressSearch.value = '';
      elements.addressVal.value = '';
    }
    updateUI();
  });

  elements.addOccurrenceBtn!.addEventListener('click', () => {
    occurrences.push({ start: '', end: '', address: elements.addressVal.value || '' });
    renderOccurrences();
  });

  elements.cat.addEventListener('change', () => {
    updateMandatoryTags();
    selectedOptionalTags = [];
    updateOptionalTags();
    updateUI();
  });

  elements.mandatoryTag.addEventListener('change', updateUI);

  // Init
  async function init() {
    entities = await fetchEntities();
    
    // Explicit client-side fetch if SSR failed (RLS issue)
    const urlParams = new URLSearchParams(window.location.search);
    const sid = urlParams.get('sid');
    const rid = urlParams.get('id');

    if (!existingData) {
      if (sid) existingData = await fetchSuggestionById(sid);
      else if (rid) existingData = await fetchResourceById(rid);
    }

    // Now populate fields explicitly
    if (existingData) {
      elements.title.value = existingData.title || '';
      elements.desc.value = existingData.description || '';
      elements.cat.value = existingData.category || 'acteur';
      elements.link.value = existingData.link || '';
      
      const metadata = existingData.metadata || {};
      elements.addressVal.value = metadata.address || '';
      elements.addressSearch.value = metadata.address || '';
      elements.pubDateInput.value = metadata.published_at || '';
      elements.versionDateInput.value = metadata.version_date || '';
      
      occurrences = metadata.occurrences || [];
      selectedRelatedIds = existingData.related_ids || [];
      
      if (existingData.tags) {
        const currentMandatory = CATEGORIES[elements.cat.value].mandatoryTags;
        selectedOptionalTags = existingData.tags.filter(t => !currentMandatory.includes(t));
      }
    }

    updateMandatoryTags();
    updateOptionalTags();
    renderOccurrences();
    renderRelated();
    updateUI();
    form.addEventListener('input', updateUI);

    elements.img.addEventListener('change', () => {
      if (elements.img.files?.[0]) {
        const reader = new FileReader();
        reader.onload = (e) => {
          elements.preview.img!.innerHTML = `<img src="${e.target?.result}" class="w-full h-full object-contain" />`;
        };
        reader.readAsDataURL(elements.img.files[0]);
      }
    });

    // Related search
    elements.relatedSearch.addEventListener('input', (e) => {
      const val = (e.target as HTMLInputElement).value.toLowerCase();
      if (val.length < 1) return elements.relatedResults!.classList.add('hidden');
      const filtered = entities.filter(ent => ent.title.toLowerCase().includes(val) && !selectedRelatedIds.includes(ent.id));
      elements.relatedResults!.innerHTML = filtered.map(ent => `<button type="button" class="w-full text-left px-4 py-2 hover:bg-stone-50" data-id="${ent.id}">${ent.title}</button>`).join('');
      elements.relatedResults!.classList.toggle('hidden', filtered.length === 0);
      elements.relatedResults!.querySelectorAll('button').forEach(btn => btn.addEventListener('click', () => {
        selectedRelatedIds.push((btn as HTMLElement).dataset.id!);
        elements.relatedSearch.value = '';
        elements.relatedResults!.classList.add('hidden');
        renderRelated();
      }));
    });
  }

  function renderRelated() {
    elements.selectedRelated!.innerHTML = selectedRelatedIds.map(id => {
      const ent = entities.find(e => e.id === id);
      return `<div class="badge badge-primary gap-2 font-bold py-3">${ent?.title || id} <button type="button" data-id="${id}" class="remove-rel">×</button></div>`;
    }).join('');
    elements.selectedRelated!.querySelectorAll('.remove-rel').forEach(btn => {
      btn.addEventListener('click', () => {
        selectedRelatedIds = selectedRelatedIds.filter(i => i !== (btn as HTMLElement).dataset.id);
        renderRelated();
      });
    });
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = elements.submitBtn;
    const urlParams = new URLSearchParams(window.location.search);
    const sid = urlParams.get('sid');
    const currentAction = sid ? (existingData as Suggestion)?.action : (urlParams.get('action') || 'create');
    const isDeleteSubmit = currentAction === 'delete';
    
    btn.disabled = true; btn.innerText = t.loading;

    try {
      const { data: { session } } = await supabase.auth.getSession();
      
      let imageUrl = existingData?.image_url || null;
      if (elements.img.files?.[0]) imageUrl = await uploadCompressedImage(elements.img.files[0]);

      const tags = [elements.mandatoryTag.value, ...selectedOptionalTags].filter(Boolean);
      const metadata = { ...existingData?.metadata };
      
      if (elements.cat.value === 'acteur') {
        metadata.address = elements.addressVal.value;
      } else if (elements.cat.value === 'evenement') {
        metadata.address = elements.addressVal.value;
        metadata.occurrences = occurrences;
      } else if (elements.cat.value === 'contenu') {
        metadata.published_at = elements.pubDateInput.value;
      } else if (elements.cat.value === 'outil') {
        metadata.version_date = elements.versionDateInput.value;
      }

      const payload: any = {
        title: isDeleteSubmit ? existingData?.title : elements.title.value,
        description: isDeleteSubmit ? existingData?.description : elements.desc.value,
        category: elements.cat.value,
        link: isDeleteSubmit ? existingData?.link : elements.link.value,
        tags,
        related_ids: selectedRelatedIds,
        metadata,
        image_url: imageUrl,
        action: currentAction,
        status: 'pending',
        resource_id: (existingData && 'id' in existingData && !('action' in existingData)) ? existingData.id : (existingData as Suggestion)?.resource_id || null,
        reason: elements.reason.value || null,
        submitted_by: (existingData as Suggestion)?.submitted_by || session?.user.id || null
      };

      if (sid) {
        const { error } = await supabase!.from('suggestions').update(payload).eq('id', sid);
        if (error) throw error;
      } else {
        const { error } = await supabase!.from('suggestions').insert([payload]);
        if (error) throw error;
      }
      
      showToast(t.success, 'success');
    } catch (err) {
      console.error(err);
      showToast(t.error, 'error');
      btn.disabled = false; 
      btn.innerText = isDeleteSubmit ? t.submitDelete : t.submitCreate;
    }
  });

  init();
</script>
