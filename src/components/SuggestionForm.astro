---
import { CATEGORIES, type CategoryKey, ACTION_ICONS, getCategoryType, getCategoryGroup } from '../utils/categories';
import type { Suggestion, SuggestionAction, Resource } from '../lib/supabase/types';

interface Props {
  lang: 'fr' | 'en';
  initialData?: Partial<Resource> | null;
  resourceId?: string | null;
  action?: SuggestionAction;
}

const { lang, initialData: rawInitialData, resourceId, action = 'create' } = Astro.props;
const initialData = rawInitialData || {};

const t = {
  fr: {
    titleCreate: 'Proposer un ajout de ressource',
    titleUpdate: 'Proposer une modification de ressource',
    titleDelete: 'Proposer une suppression de ressource',
    name: 'Nom de la ressource',
    description: 'Description',
    link: 'Lien (URL)',
    category: 'Catégorie',
    resourceLang: 'Langue de la ressource',
    tags: 'Tags (séparés par des virgules)',
    related: 'Contributeurs / Organisations liés',
    relatedPlaceholder: 'Chercher une entreprise, association...',
    image: 'Image (sera compressée)',
    reason: 'Motif de la suppression',
    target: 'Aperçu de la ressource :',
    submit: 'Envoyer la suggestion',
    loading: 'Chargement...',
    success: 'Merci ! Votre suggestion a été envoyée pour modération. Redirection...',
    error: 'Une erreur est survenue. Veuillez réessayer.',
    city: 'Ville / Localisation',
    cityPlaceholder: 'Rechercher une ville...',
    pubDate: 'Date de parution',
  },
  en: {
    titleCreate: 'Suggest a resource addition',
    titleUpdate: 'Suggest a resource modification',
    titleDelete: 'Suggest a resource deletion',
    name: 'Resource name',
    description: 'Description',
    link: 'Link (URL)',
    category: 'Category',
    resourceLang: 'Resource language',
    tags: 'Tags (comma separated)',
    related: 'Related Contributors / Organizations',
    relatedPlaceholder: 'Search for a company, association...',
    image: 'Image (will be compressed)',
    reason: 'Reason for deletion',
    target: 'Resource preview:',
    submit: 'Send suggestion',
    loading: 'Loading...',
    success: 'Thank you! Your suggestion has been sent for moderation. Redirecting...',
    error: 'An error occurred. Please try again.',
    city: 'City / Location',
    cityPlaceholder: 'Search for a city...',
    pubDate: 'Publication date',
  }
}[lang];
---

<div class="max-w-2xl mx-auto p-6 bg-base-100 rounded-xl shadow-sm border border-base-200">
  <h2 id="form-title" class="text-2xl font-bold mb-6 flex items-center gap-3">
    <div id="form-icon-container" class="p-2 bg-stone-50 rounded-lg border border-stone-100 flex items-center justify-center">
      <span id="form-icon-placeholder">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ACTION_ICONS[action]} />
        </svg>
      </span>
    </div>
    <span id="form-title-text">{action === 'delete' ? t.titleDelete : (action === 'update' ? t.titleUpdate : t.titleCreate)}</span>
  </h2>

  {/* Unified Resource Preview Block */}
  <div id="resource-preview-block" class="mb-8 p-4 bg-stone-50 border border-stone-200 rounded-xl flex items-center gap-4">
    <div id="resource-preview-img" class="w-20 h-20 rounded-lg bg-white border border-stone-200 overflow-hidden flex-shrink-0 flex items-center justify-center text-stone-200">
    </div>
    <div class="flex-grow">
      <p class="text-[10px] font-bold text-stone-400 uppercase tracking-widest mb-1">{t.target}</p>
      <p id="resource-preview-title" class="font-bold text-stone-800 leading-tight">Nouveau projet...</p>
      <div class="flex gap-2 mt-1">
        <span id="resource-preview-badge-cat" class="text-[9px] font-bold uppercase text-stone-400">CATÉGORIE</span>
        <span id="resource-preview-badge-lang" class="text-[9px] font-bold uppercase text-primary">FR</span>
        <span id="resource-preview-badge-city" class="text-[9px] font-bold uppercase text-stone-400 hidden"></span>
        <span id="resource-preview-badge-date" class="text-[9px] font-bold uppercase text-stone-400 hidden"></span>
      </div>
    </div>
  </div>

  <form 
    id="suggestion-form" 
    class="space-y-4"
    data-msg-success={t.success}
    data-msg-error={t.error}
    data-msg-loading={t.loading}
    data-msg-submit={t.submit}
    data-lang={lang}
  >
    <div id="standard-fields" class="space-y-4">
      <div class="form-control">
        <label class="label"><span class="label-text">{t.name}</span></label>
        <input type="text" name="title" required placeholder="Ex: Salvia" class="input input-bordered w-full" />
      </div>

      <div class="form-control">
        <label class="label"><span class="label-text">{t.description}</span></label>
        <textarea name="description" required placeholder="Brève description..." class="textarea textarea-bordered h-24"></textarea>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-control">
          <label class="label"><span class="label-text">{t.category}</span></label>
          <select name="category" id="category-select" class="select select-bordered w-full">
            {Object.entries(CATEGORIES).map(([key, labels]) => (
              <option value={key}>{labels[lang]}</option>
            ))}
          </select>
        </div>

        <div class="form-control">
          <label class="label"><span class="label-text">{t.resourceLang}</span></label>
          <select name="language" class="select select-bordered w-full">
            <option value="fr">Français (FR)</option>
            <option value="en">English (EN)</option>
          </select>
        </div>
      </div>

      {/* City Autocomplete (Photon API) */}
      <div id="city-container" class="form-control hidden">
        <label class="label"><span class="label-text">{t.city}</span></label>
        <div class="relative">
          <input 
            type="text" 
            id="city-search" 
            placeholder={t.cityPlaceholder} 
            class="input input-bordered w-full" 
            autocomplete="off"
          />
          <input type="hidden" name="city-value" id="city-value" />
          <div id="city-results" class="absolute left-0 right-0 top-full mt-1 bg-white border border-stone-200 rounded-lg shadow-xl z-[70] hidden max-h-48 overflow-y-auto">
          </div>
        </div>
      </div>

      {/* Publication Date (For CONTENUS) */}
      <div id="date-container" class="form-control hidden">
        <label class="label"><span class="label-text">{t.pubDate}</span></label>
        <input type="date" name="pub-date" id="pub-date" class="input input-bordered w-full" />
      </div>

      {/* Relations multi-sélecteur (Affiché conditionnellement par script) */}
      <div id="related-container" class="form-control hidden">
        <label class="label"><span class="label-text">{t.related}</span></label>
        <div class="relative">
          <input 
            type="text" 
            id="related-search" 
            placeholder={t.relatedPlaceholder} 
            class="input input-bordered w-full" 
            autocomplete="off"
          />
          <div id="related-results" class="absolute left-0 right-0 top-full mt-1 bg-white border border-stone-200 rounded-lg shadow-xl z-[60] hidden max-h-48 overflow-y-auto">
            {/* Résultats de recherche injectés ici */}
          </div>
        </div>
        <div id="selected-related" class="flex flex-wrap gap-2 mt-2">
          {/* Badges des entités sélectionnées */}
        </div>
      </div>

      <div class="form-control">
        <label class="label"><span class="label-text">{t.link}</span></label>
        <input type="url" name="link" required placeholder="https://..." class="input input-bordered w-full" />
      </div>

      <div class="form-control">
        <label class="label"><span class="label-text">{t.tags}</span></label>
        <input 
          type="text" 
          name="tags" 
          placeholder="low-tech, open-source..." 
          class="input input-bordered w-full" 
        />
      </div>

      <div class="form-control" id="image-field">
        <label class="label"><span class="label-text font-semibold text-stone-600">{t.image}</span></label>
        <input 
          type="file" 
          name="image" 
          accept="image/*" 
          class="file-input file-input-bordered file-input-primary w-full bg-stone-50/50 border-stone-200 text-stone-500 text-sm focus:outline-primary/30 transition-all hover:border-primary/50" 
        />
        <label class="label">
          <span class="label-text-alt text-stone-400 italic">Format WebP, JPG ou PNG (max 5MB)</span>
        </label>
      </div>
    </div>

    <div id="delete-fields" class="hidden space-y-4">
      <div class="form-control">
        <label class="label"><span class="label-text font-bold text-error">{t.reason}</span></label>
        <textarea name="reason" placeholder="Ex: Le site n'existe plus..." class="textarea textarea-bordered textarea-error h-32"></textarea>
      </div>
    </div>

    <button type="submit" class="btn btn-primary w-full mt-4 hover:bg-[#52b788] transition-colors shadow-sm">
      {t.submit}
    </button>
  </form>

  <div id="toast-container" class="toast toast-top toast-center z-[100] hidden">
    <div id="toast-message" class="alert shadow-lg border-none text-white font-bold px-8 py-4 rounded-2xl">
      <span id="toast-text"></span>
    </div>
  </div>
</div>

<script>
  import { supabase, getImageUrl } from '../lib/supabase/client';
  import { getCategoryIcon, getCategoryLabel, ACTION_ICONS, getCategoryType, getCategoryGroup } from '../utils/categories';
  import type { Resource, SuggestionAction } from '../lib/supabase/types';

  const form = document.getElementById('suggestion-form') as HTMLFormElement;
  const toastContainer = document.getElementById('toast-container');
  const toastMessage = document.getElementById('toast-message');
  const toastText = document.getElementById('toast-text');
  
  const formIconContainer = document.getElementById('form-icon-container');
  const formTitleText = document.getElementById('form-title-text');
  const standardFields = document.getElementById('standard-fields');
  const deleteFields = document.getElementById('delete-fields');
  const catSelect = document.getElementById('category-select') as HTMLSelectElement;

  // City Autocomplete elements
  const cityContainer = document.getElementById('city-container');
  const citySearch = document.getElementById('city-search') as HTMLInputElement;
  const cityValue = document.getElementById('city-value') as HTMLInputElement;
  const cityResults = document.getElementById('city-results');

  // Date elements
  const dateContainer = document.getElementById('date-container');
  const dateInput = document.getElementById('pub-date') as HTMLInputElement;

  // Related selector elements
  const relatedContainer = document.getElementById('related-container');
  const relatedSearch = document.getElementById('related-search') as HTMLInputElement;
  const relatedResults = document.getElementById('related-results');
  const selectedRelatedContainer = document.getElementById('selected-related');

  // Preview elements
  const previewImg = document.getElementById('resource-preview-img');
  const previewTitle = document.getElementById('resource-preview-title');
  const previewCat = document.getElementById('resource-preview-badge-cat');
  const previewLang = document.getElementById('resource-preview-badge-lang');
  const previewCity = document.getElementById('resource-preview-badge-city');
  const previewDate = document.getElementById('resource-preview-badge-date');

  const msgSuccess = form?.dataset.msgSuccess || '';
  const msgError = form?.dataset.msgError || '';
  const msgLoading = form?.dataset.msgLoading || '';
  const msgSubmit = form?.dataset.msgSubmit || '';
  const uiLang = (form?.dataset.lang || 'fr') as 'fr' | 'en';

  const urlParams = new URLSearchParams(window.location.search);
  const resourceId = urlParams.get('id');
  const action = (urlParams.get('action') || 'create') as SuggestionAction;

  const i18n = {
    fr: {
      titleCreate: 'Proposer un ajout de ressource',
      titleUpdate: 'Proposer une modification de ressource',
      titleDelete: 'Proposer une suppression de ressource',
      defaultTitle: 'Nouveau projet...'
    },
    en: {
      titleCreate: 'Suggest a resource addition',
      titleUpdate: 'Suggest a resource modification',
      titleDelete: 'Suggest a resource deletion',
      defaultTitle: 'New project...'
    }
  }[uiLang];

  let existingData: Resource | null = null;
  let allEntities: Resource[] = [];
  let selectedRelatedIds: string[] = [];

  async function showToast(message: string, type: 'success' | 'error') {
    if (!toastContainer || !toastMessage || !toastText) return;
    toastText.innerText = message;
    toastMessage.className = `alert shadow-lg border-none text-white font-bold px-8 py-4 rounded-2xl ${type === 'success' ? 'bg-primary' : 'bg-error'}`;
    toastContainer.classList.remove('hidden');
    
    if (type === 'success') {
      setTimeout(() => {
        window.location.href = `/${uiLang}`;
      }, 2000);
    } else {
      setTimeout(() => {
        toastContainer.classList.add('hidden');
      }, 5000);
    }
  }

  function updatePreview() {
    if (!previewTitle || !previewCat || !previewLang || !previewImg || !previewCity || !previewDate) return;

    const titleInput = form.querySelector('[name="title"]') as HTMLInputElement;
    const catInput = form.querySelector('[name="category"]') as HTMLSelectElement;
    const langInput = form.querySelector('[name="language"]') as HTMLSelectElement;
    const imageInput = form.querySelector('[name="image"]') as HTMLInputElement;

    previewTitle.innerText = titleInput.value || existingData?.title || i18n.defaultTitle;
    previewCat.innerText = getCategoryLabel(catInput.value || existingData?.category || 'entreprise', uiLang);
    previewLang.innerText = (langInput.value || existingData?.language || 'fr').toUpperCase();

    // Preview city
    if (cityValue.value || existingData?.metadata?.city) {
      previewCity.innerText = cityValue.value || existingData?.metadata?.city;
      previewCity.classList.remove('hidden');
    } else {
      previewCity.classList.add('hidden');
    }

    // Preview date
    if (dateInput.value || existingData?.metadata?.published_at) {
      previewDate.innerText = dateInput.value || existingData?.metadata?.published_at;
      previewDate.classList.remove('hidden');
    } else {
      previewDate.classList.add('hidden');
    }

    if (imageInput?.files && imageInput.files[0]) {
      const reader = new FileReader();
      reader.onload = (e) => {
        previewImg.innerHTML = `<img src="${e.target?.result}" class="w-full h-full object-contain p-1" />`;
      };
      reader.readAsDataURL(imageInput.files[0]);
    } else if (existingData?.image_url) {
      const url = getImageUrl(existingData.image_url);
      previewImg.innerHTML = `<img src="${url}" class="w-full h-full object-contain p-1" />`;
    } else {
      const cat = catInput.value || existingData?.category || 'entreprise';
      previewImg.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="${getCategoryIcon(cat)}" /></svg>`;
    }

    // Dynamic visibility
    const catType = getCategoryType(catInput.value);
    const catGroup = getCategoryGroup(catInput.value);

    if (action !== 'delete') {
      // Related selector logic
      if (catType === 'resource') {
        relatedContainer?.classList.remove('hidden');
      } else {
        relatedContainer?.classList.add('hidden');
      }

      // City field logic
      if (catType === 'entity') {
        cityContainer?.classList.remove('hidden');
      } else {
        cityContainer?.classList.add('hidden');
      }

      // Date field logic
      if (catGroup === 'CONTENUS') {
        dateContainer?.classList.remove('hidden');
      } else {
        dateContainer?.classList.add('hidden');
      }
    } else {
      relatedContainer?.classList.add('hidden');
      cityContainer?.classList.add('hidden');
      dateContainer?.classList.add('hidden');
    }
  }

  function renderSelectedRelated() {
    if (!selectedRelatedContainer) return;
    selectedRelatedContainer.innerHTML = '';
    
    selectedRelatedIds.forEach(id => {
      const entity = allEntities.find(e => e.id === id);
      if (!entity) return;
      
      const badge = document.createElement('div');
      badge.className = 'badge badge-primary gap-2 font-bold py-3 pl-3 pr-1';
      badge.innerHTML = `
        <span>${entity.title}</span>
        <button type="button" class="hover:text-red-200" data-id="${id}">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      `;
      
      badge.querySelector('button')?.addEventListener('click', () => {
        selectedRelatedIds = selectedRelatedIds.filter(rid => rid !== id);
        renderSelectedRelated();
      });
      
      selectedRelatedContainer.appendChild(badge);
    });
  }

  async function fetchEntities() {
    if (!supabase) return;
    const { data } = await supabase
      .from('resources')
      .select('id, title, category')
      .in('category', ['entreprise', 'association', 'personne'])
      .order('title');
    
    if (data) allEntities = data as Resource[];
  }

  // Photon API logic
  let photonTimeout: any;
  citySearch?.addEventListener('input', (e) => {
    clearTimeout(photonTimeout);
    const val = (e.target as HTMLInputElement).value;
    if (val.length < 2) {
      cityResults?.classList.add('hidden');
      return;
    }

    photonTimeout = setTimeout(async () => {
      try {
        const response = await fetch(`https://photon.komoot.io/api/?q=${encodeURIComponent(val)}&limit=10&lang=${uiLang}`);
        const data = await response.json();
        
        if (data.features && data.features.length > 0 && cityResults) {
          const filtered = data.features.filter((f: any) => 
            f.properties.osm_key === 'place' && 
            ['city', 'town', 'village', 'hamlet'].includes(f.properties.osm_value)
          ).slice(0, 5);

          if (filtered.length === 0) {
            cityResults.classList.add('hidden');
            return;
          }

          cityResults.innerHTML = filtered.map((f: any) => {
            const name = f.properties.name;
            const city = f.properties.city || f.properties.state || '';
            const country = f.properties.country || '';
            const label = [name, country].filter(Boolean).join(', ');
            return `
              <button type="button" class="w-full text-left px-4 py-3 hover:bg-stone-50 border-b border-stone-100 last:border-none group" data-label="${label}">
                <p class="font-bold text-sm text-stone-800">${name}</p>
                <p class="text-[10px] text-stone-400 uppercase">${[city, country].filter(Boolean).join(', ')}</p>
              </button>
            `;
          }).join('');
          cityResults.classList.remove('hidden');

          cityResults.querySelectorAll('button').forEach(btn => {
            btn.addEventListener('click', () => {
              const label = btn.dataset.label || '';
              citySearch.value = label;
              cityValue.value = label;
              cityResults.classList.add('hidden');
              updatePreview();
            });
          });
        }
      } catch (err) {
        console.error('Photon API Error:', err);
      }
    }, 300);
  });

  // Initialize UI
  async function initForm() {
    await fetchEntities();

    if (formIconContainer) {
      const iconPath = ACTION_ICONS[action];
      formIconContainer.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 ${action === 'delete' ? 'text-error' : 'text-primary'}" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="${iconPath}" /></svg>`;
    }

    if ((action === 'update' || action === 'delete') && resourceId) {
      if (action === 'delete') {
        if (formTitleText) formTitleText.innerText = i18n.titleDelete;
        standardFields?.classList.add('hidden');
        deleteFields?.classList.remove('hidden');
        const inputs = standardFields?.querySelectorAll('input, textarea, select');
        inputs?.forEach(input => {
          (input as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement).required = false;
        });
        const reasonInput = deleteFields?.querySelector('textarea');
        if (reasonInput) reasonInput.required = true;
      } else {
        if (formTitleText) formTitleText.innerText = i18n.titleUpdate;
      }
      
      if (supabase) {
        const { data } = await supabase
          .from('resources')
          .select('*')
          .eq('id', resourceId)
          .single();

        if (data) {
          existingData = data as Resource;
          if (action !== 'delete') {
            (form.querySelector('[name="title"]') as HTMLInputElement).value = data.title || '';
            (form.querySelector('[name="description"]') as HTMLTextAreaElement).value = data.description || '';
            (form.querySelector('[name="category"]') as HTMLSelectElement).value = data.category || '';
            (form.querySelector('[name="language"]') as HTMLSelectElement).value = data.language || 'fr';
            (form.querySelector('[name="link"]') as HTMLInputElement).value = data.link || '';
            (form.querySelector('[name="tags"]') as HTMLInputElement).value = data.tags?.join(', ') || '';
            if (data.metadata?.city) {
              citySearch.value = data.metadata.city;
              cityValue.value = data.metadata.city;
            }
            if (data.metadata?.published_at) {
              dateInput.value = data.metadata.published_at;
            }
            selectedRelatedIds = data.related_ids || [];
            renderSelectedRelated();
          }
          updatePreview();
        }
      }
    } else {
      if (formTitleText) formTitleText.innerText = i18n.titleCreate;
      updatePreview();
    }

    form.querySelectorAll('input, select, textarea').forEach(input => {
      input.addEventListener('input', updatePreview);
    });

    // Related search logic
    relatedSearch?.addEventListener('input', (e) => {
      const val = (e.target as HTMLInputElement).value.toLowerCase();
      if (val.length < 1) {
        relatedResults?.classList.add('hidden');
        return;
      }
      
      const filtered = allEntities.filter(ent => 
        ent.title.toLowerCase().includes(val) && !selectedRelatedIds.includes(ent.id)
      );
      
      if (filtered.length > 0 && relatedResults) {
        relatedResults.innerHTML = filtered.map(ent => `
          <button type="button" class="w-full text-left px-4 py-3 hover:bg-stone-50 border-b border-stone-100 last:border-none flex items-center justify-between group" data-id="${ent.id}">
            <div>
              <p class="font-bold text-sm text-stone-800">${ent.title}</p>
              <p class="text-[10px] text-stone-400 uppercase">${ent.category}</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-stone-200 group-hover:text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
          </button>
        `).join('');
        
        relatedResults.classList.remove('hidden');
        
        relatedResults.querySelectorAll('button').forEach(btn => {
          btn.addEventListener('click', () => {
            const id = btn.dataset.id;
            if (id && !selectedRelatedIds.includes(id)) {
              selectedRelatedIds.push(id);
              relatedSearch.value = '';
              relatedResults.classList.add('hidden');
              renderSelectedRelated();
            }
          });
        });
      } else {
        relatedResults?.classList.add('hidden');
      }
    });

    // Close results when clicking outside
    document.addEventListener('click', (e) => {
      if (!relatedSearch?.contains(e.target as Node) && !citySearch?.contains(e.target as Node)) {
        relatedResults?.classList.add('hidden');
        cityResults?.classList.add('hidden');
      }
    });
  }

  initForm();

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    
    submitBtn.disabled = true;
    submitBtn.innerText = msgLoading;

    try {
      if (!supabase) throw new Error('Supabase not initialized');
      
      let imageUrl = existingData?.image_url || '';

      if (action !== 'delete') {
        const imageFile = formData.get('image') as File;
        if (imageFile && imageFile.size > 0) {
          const imageCompression = (await import('browser-image-compression')).default;
          const options = {
            maxSizeMB: 0.05,
            maxWidthOrHeight: 800,
            useWebWorker: true,
            fileType: 'image/webp',
            initialQuality: 0.8
          };
          
          try {
            const compressedFile = await imageCompression(imageFile, options);
            const fileName = `${Date.now()}-${imageFile.name.split('.')[0]}.webp`;
            const { data: uploadData, error: uploadError } = await supabase.storage
              .from('suggestions')
              .upload(fileName, compressedFile);
              
            if (uploadError) throw uploadError;
            if (uploadData) imageUrl = uploadData.path;
          } catch (error) {
            console.error('Erreur Upload/Compression:', error);
          }
        }
      }

      const tagsString = formData.get('tags') as string;
      const tags = tagsString ? tagsString.split(',').map(t => t.trim()).filter(Boolean) : [];
      
      const metadata: any = { ...existingData?.metadata };
      if (action !== 'delete') {
        const city = formData.get('city-value') as string;
        const pubDate = formData.get('pub-date') as string;
        
        if (city) metadata.city = city;
        else delete metadata.city;
        
        if (pubDate) metadata.published_at = pubDate;
        else delete metadata.published_at;
      }

      const payload = {
        title: action === 'delete' ? existingData?.title : formData.get('title'),
        description: action === 'delete' ? existingData?.description : formData.get('description'),
        link: action === 'delete' ? existingData?.link : formData.get('link'),
        category: action === 'delete' ? existingData?.category : formData.get('category'),
        language: action === 'delete' ? (existingData?.language || 'fr') : formData.get('language'),
        tags: action === 'delete' ? (existingData?.tags || []) : tags,
        related_ids: action === 'delete' ? (existingData?.related_ids || []) : selectedRelatedIds,
        metadata: metadata,
        image_url: imageUrl || null,
        status: 'pending',
        action: action,
        resource_id: resourceId || null,
        reason: formData.get('reason') || null
      };

      const { error } = await supabase
        .from('suggestions')
        .insert([payload]);

      if (error) throw error;

      showToast(msgSuccess, 'success');
      form.reset();
    } catch (err) {
      console.error('Erreur:', err);
      showToast(msgError, 'error');
      submitBtn.disabled = false;
      submitBtn.innerText = msgSubmit;
    }
  });
</script>
