};
---

<svg xmlns="http://www.w3.org/2000/svg" class="hidden">
  {Object.entries(spriteIcons).map(([id, path]) => (
    <symbol id={id} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d={path} />
