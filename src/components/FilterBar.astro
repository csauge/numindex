---
import { getCategoryLabel, CATEGORIES } from "../utils/categories";

interface Props {
  lang: string;
  t: any;
}

const { lang, t } = Astro.props;

const categoryMapping: Record<string, string> = {
  'acteur': 'acteurs',
  'evenement': 'evenements',
  'contenu': 'contenus',
  'outil': 'outils'
};

const categoryLinks = Object.keys(CATEGORIES).map(k => ({
  key: k,
  label: getCategoryLabel(k, lang as any),
  href: `/${lang}/${categoryMapping[k]}`
}));

// Déterminer la catégorie active pour le JS
const currentPath = Astro.url.pathname;
let currentCat = 'all';
for (const [key, slug] of Object.entries(categoryMapping)) {
  if (currentPath.includes(`/${lang}/${slug}`)) {
    currentCat = key;
    break;
  }
}
---

<div class="sticky top-20 z-30 mb-6 flex flex-col gap-4" id="filter-bar-container" data-active-category={currentCat}>
  {/* Navigation par Onglets (Tabs) */}
  <nav class="flex items-center border-b border-stone-100 overflow-x-auto no-scrollbar gap-1 md:gap-2 px-1" aria-label="Categories">
    <a 
      href={`/${lang}`} 
      class={`px-4 py-2 text-[11px] font-black uppercase tracking-widest transition-all border-b-2 whitespace-nowrap ${currentCat === 'all' ? 'border-primary text-primary bg-emerald-50/30' : 'border-transparent text-stone-400 hover:text-stone-600 hover:bg-stone-50/50'}`}
    >
      {lang === 'fr' ? 'Tout' : 'All'}
    </a>
    {categoryLinks.map(link => (
      <a 
        href={link.href}
        class={`px-4 py-2 text-[11px] font-black uppercase tracking-widest transition-all border-b-2 whitespace-nowrap ${currentCat === link.key ? 'border-primary text-primary bg-emerald-50/30' : 'border-transparent text-stone-400 hover:text-stone-600 hover:bg-stone-50/50'}`}
      >
        {link.label}s
      </a>
    ))}
  </nav>

  <div class="p-2 bg-white/95 backdrop-blur-md border border-stone-200 rounded-2xl flex flex-col gap-3 shadow-sm">
    <div class="flex flex-col md:flex-row gap-3">
      <div class="flex-grow relative flex items-center">
        <div class="absolute left-3.5 opacity-30"><svg class="h-4 w-4"><use href="#search" /></svg></div>
        <input 
          type="text" 
          id="search-input" 
          placeholder={t.searchPlaceholder} 
          class="input input-ghost w-full pl-10 h-11 bg-stone-50 focus:bg-white focus:ring-2 focus:ring-primary/20 rounded-xl border-none text-sm transition-all" 
        />
        <button 
          id="clear-search" 
          class="absolute right-2 h-8 w-8 flex items-center justify-center rounded-lg hover:bg-stone-200 text-stone-400 opacity-0 pointer-events-none transition-opacity"
        >
          <svg class="h-4 w-4"><use href="#close" /></svg>
        </button>
      </div>

      <div class="flex items-center gap-2 flex-wrap md:flex-nowrap justify-between md:justify-end">
        <div class="flex items-center gap-2">
          <label class="cursor-pointer btn btn-sm h-11 bg-stone-50 hover:bg-stone-100 border-stone-200 rounded-xl px-4 shadow-sm group transition-all" title={t.filterFavorites || 'Favoris'}>
            <input type="checkbox" id="filter-favorites" class="hidden" />
            <svg xmlns="http://www.w3.org/2000/svg" id="fav-icon-off" class="w-5 h-5 text-stone-400 group-hover:text-primary transition-colors fill-none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.175 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.382-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" id="fav-icon-on" class="hidden w-5 h-5 text-amber-500 fill-amber-500 transition-colors" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.175 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.382-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
          </label>

          <select id="filter-sort" class="select select-sm h-11 bg-stone-50 text-stone-700 border-stone-200 rounded-xl text-[10px] font-black uppercase tracking-tight shadow-sm hover:border-primary transition-colors min-w-[120px]">
            <option value="updated_at">{t.sortNewest}</option>
            <option value="favorites">{t.sortFavorites || 'Plus favoris'}</option>
            <option value="title">{t.sortName}</option>
            <option value="next_date" id="opt-next-date" class="hidden">{t.sortDate}</option>
            <option value="published_at" id="opt-pub-date" class="hidden">{t.sortPub}</option>
            <option value="cat" id="opt-cat" class={currentCat === 'all' ? '' : 'hidden'}>{t.sortCat}</option>
          </select>
        </div>

        <div class="flex items-center gap-1 border-l border-stone-100 ml-1 pl-1">
          <div class="dropdown dropdown-end">
            <label tabindex="0" class="btn btn-ghost btn-sm h-10 w-10 p-0 rounded-xl text-stone-400 hover:text-primary transition-colors" title="Exporter">
              <svg class="h-4 w-4"><use href="#export" /></svg>
            </label>
            <ul tabindex="0" class="dropdown-content menu p-2 shadow-xl bg-white border border-stone-100 rounded-xl w-48 mt-2 z-50">
              <li><button id="btn-export-bookmarks" class="text-xs font-bold">{t.exportBookmarks}</button></li>
              <li><button id="btn-export-calendar" class="text-xs font-bold text-left">{t.exportCalendar}</button></li>
            </ul>
          </div>

          <a href={`/${lang}/carte`} class={`btn btn-ghost btn-sm h-10 w-10 p-0 rounded-xl transition-colors ${Astro.url.pathname.includes('/carte') ? 'text-primary bg-emerald-50' : 'text-stone-400 hover:text-primary'}`} title={lang === 'fr' ? 'Vue Carte' : 'Map View'}>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
  
  {/* Conteneur de Sous-catégories (Chips) */}
  <div id="sub-filters-container" class="hidden px-1 py-2 overflow-x-auto no-scrollbar flex items-center gap-2 whitespace-nowrap"></div>
</div>

<script>
  // Script minimal pour gérer l'affichage de l'icône favoris dans FilterBar
  const favToggle = document.getElementById('filter-favorites') as HTMLInputElement;
  const iconOff = document.getElementById('fav-icon-off');
  const iconOn = document.getElementById('fav-icon-on');

  if (favToggle && iconOff && iconOn) {
    favToggle.addEventListener('change', () => {
      if (favToggle.checked) {
        iconOff.classList.add('hidden');
        iconOn.classList.remove('hidden');
      } else {
        iconOff.classList.remove('hidden');
        iconOn.classList.add('hidden');
      }
    });
  }
</script>
