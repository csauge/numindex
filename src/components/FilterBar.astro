---
import { getCategoryLabel } from "../utils/categories";

interface Props {
  lang: string;
  t: any;
  activeCategoryKeys: string[];
}

const { lang, t, activeCategoryKeys } = Astro.props;
---

<div class="sticky top-20 z-30 mb-8 p-1.5 bg-white/90 backdrop-blur border border-stone-200 rounded-2xl flex flex-col gap-2">
  <div class="flex flex-col md:flex-row gap-2">
    <div class="flex-grow relative flex items-center">
      <div class="absolute left-3 opacity-30"><svg class="h-4 w-4"><use href="#search" /></svg></div>
      <input 
        type="text" 
        id="search-input" 
        placeholder={t.searchPlaceholder} 
        class="input input-ghost w-full pl-9 h-10 bg-stone-50 focus:bg-white rounded-xl border-none text-sm" 
      />
      <button 
        id="clear-search" 
        class="absolute right-2 h-7 w-7 flex items-center justify-center rounded-lg hover:bg-stone-200 text-stone-400 opacity-0 pointer-events-none transition-opacity"
      >
        <svg class="h-4 w-4"><use href="#close" /></svg>
      </button>
    </div>

    <div class="flex items-center gap-2 flex-wrap md:flex-nowrap justify-end">
      <select id="filter-sort" class="select select-sm bg-emerald-50 text-emerald-700 border-none rounded-lg text-[10px] font-bold uppercase flex-grow md:flex-grow-0 max-w-[120px] md:max-w-none">
        <option value="updated_at">{t.sortNewest}</option>
        <option value="title">{t.sortName}</option>
        <option value="next_date" id="opt-next-date" class="hidden">{t.sortDate}</option>
        <option value="published_at" id="opt-pub-date" class="hidden">{t.sortPub}</option>
        <option value="cat">{t.sortCat}</option>
      </select>
      
      <select id="filter-category" class="select select-sm bg-stone-100 text-stone-600 border-none rounded-lg text-[10px] font-bold uppercase flex-grow md:flex-grow-0 max-w-[140px] md:max-w-none">
        <option value="all">{t.filterCat}</option>
        {activeCategoryKeys.map(k => <option value={k}>{getCategoryLabel(k, lang as any)}</option>)}
      </select>

      <div class="dropdown dropdown-end">
        <label tabindex="0" class="btn btn-ghost btn-sm h-10 w-10 p-0 rounded-xl text-stone-400" title="Exporter">
          <svg class="h-4 w-4"><use href="#export" /></svg>
        </label>
        <ul tabindex="0" class="dropdown-content menu p-2 shadow-xl bg-white border border-stone-100 rounded-xl w-48 mt-2 z-50">
          <li><button id="btn-export-bookmarks" class="text-xs font-bold">{t.exportBookmarks}</button></li>
          <li><button id="btn-export-calendar" class="text-xs font-bold text-left">{t.exportCalendar}</button></li>
        </ul>
      </div>

      <a href={`/${lang}/carte`} class="btn btn-ghost btn-sm h-10 w-10 p-0 rounded-xl text-stone-400" title={lang === 'fr' ? 'Vue Carte' : 'Map View'}>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </a>

      <label class="swap swap-rotate btn btn-ghost btn-sm h-10 w-10 p-0 rounded-xl text-stone-400">
        <input type="checkbox" id="view-toggle" />
        <svg class="swap-on h-4 w-4 pointer-events-none"><use href="#view-list" /></svg>
        <svg class="swap-off h-4 w-4 pointer-events-none"><use href="#view-grid" /></svg>
      </label>
    </div>
  </div>
  <div id="sub-filters-container" class="hidden px-1 pb-1 overflow-x-auto no-scrollbar flex items-center gap-2 whitespace-nowrap"></div>
</div>
