---
interface Props {
  title: string;
  lang: string;
}
const { title, lang } = Astro.props;

const t = {
  fr: { propose: "Proposer", skip: "Passer au contenu" },
  en: { propose: "Propose", skip: "Skip to content" }
}[lang];
---

<!doctype html>
<html lang={lang} data-theme="garden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Salvia</title>
    <style is:global>
      /* Style pour le lien d'évitement (Accessibilité) */
      .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        background: #5c7f67;
        color: white;
        padding: 8px;
        z-index: 100;
        transition: top 0.3s;
      }
      .skip-link:focus {
        top: 0;
      }
      /* Réchauffer le background par défaut de daisyUI */
      body {
        background-color: #fdfcfb !important; /* Papier chaud au lieu du gris */
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col font-sans text-base-content antialiased">
    <a href="#main-content" class="skip-link">{t.skip}</a>

    <header class="navbar bg-white/70 backdrop-blur-md border-b border-stone-200 px-4 sticky top-0 z-50">
      <div class="flex-1">
        <a href={`/${lang}`} class="text-xl font-bold tracking-tight flex items-center gap-2 hover:text-primary transition-colors focus-visible:outline-dashed focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary" aria-label="Salvia - Accueil">
          <span class="text-2xl" aria-hidden="true">🌱</span> Salvia
        </a>
      </div>
      <div class="flex-none gap-2 flex items-center">
        <a 
          href="#" 
          class="btn btn-outline btn-primary btn-sm font-bold min-h-0 h-9 px-4"
          aria-label={lang === 'fr' ? 'Proposer une nouvelle ressource' : 'Propose a new resource'}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
          <span class="hidden md:inline">{t.propose}</span>
        </a>
        <nav class="flex items-center gap-1 ml-2" aria-label={lang === 'fr' ? 'Changer de langue' : 'Change language'}>
          <a href="/fr" class={`h-9 flex items-center px-3 rounded-lg transition-colors ${lang === 'fr' ? 'bg-primary text-primary-content font-bold' : 'hover:bg-stone-100'}`} aria-current={lang === 'fr' ? 'page' : undefined}>FR</a>
          <a href="/en" class={`h-9 flex items-center px-3 rounded-lg transition-colors ${lang === 'en' ? 'bg-primary text-primary-content font-bold' : 'hover:bg-stone-100'}`} aria-current={lang === 'en' ? 'page' : undefined}>EN</a>
        </nav>
      </div>
    </header>

    <main id="main-content" class="flex-grow container mx-auto p-6 max-w-5xl outline-none" tabindex="-1">
      <slot />
    </main>

    <footer class="footer footer-center p-10 bg-stone-100 text-base-content/60 border-t border-stone-200 mt-12">
      <aside>
        <p class="text-sm italic font-medium">🌱 Salvia — Pour un numérique plus conscient et durable.</p>
        <p class="text-xs mt-2 opacity-70">© {new Date().getFullYear()} - Annuaire Open Source</p>
      </aside>
    </footer>
  </body>
</html>
