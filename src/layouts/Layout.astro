---
import { ACTION_ICONS } from '../utils/categories';

interface Props {
  title: string;
  lang?: string;
}
const { title, lang = 'fr' } = Astro.props;

const translations = {
  fr: { propose: "Ajouter", skip: "Passer au contenu", admin: "Modérer", login: "Connexion", logout: "Déconnexion" },
  en: { propose: "Add", skip: "Skip to content", admin: "Moderate", login: "Login", logout: "Logout" }
};
const t = translations[lang as keyof typeof translations] || translations.fr;
---

<!doctype html>
<html lang={lang} data-theme="numindex">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | numindex.org</title>
    <style is:global>
      /* Style pour le lien d'évitement (Accessibilité) */
      .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        background: #40916c; /* Nouveau vert numindex */
        color: white;
        padding: 8px;
        z-index: 100;
        transition: top 0.3s;
      }
      .skip-link:focus {
        top: 0;
      }
      /* Ambiance visuelle apaisée et fraîche */
      body {
        background-color: #fdfcfb !important;
        background-image: radial-gradient(#d8f3dc 0.5px, transparent 0.5px);
        background-size: 24px 24px;
        background-attachment: fixed;
      }
      [data-auth-only], [data-admin-only] {
        display: none;
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col font-sans text-stone-800 antialiased">
    <a href="#main-content" class="skip-link">{t.skip}</a>

    <header class="navbar bg-white/70 backdrop-blur-lg border-b border-emerald-100 px-4 sticky top-0 z-50 shadow-sm shadow-emerald-50/50">
      <div class="flex-1">
        <a href={`/${lang}`} class="flex items-center hover:opacity-80 transition-all focus-visible:outline-dashed focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary" aria-label="NumIndex - Accueil">
          <img src="/logo.svg" alt="NumIndex Logo" class="h-8 md:h-9 w-auto" />
        </a>
      </div>
      <div class="flex-none gap-2 flex items-center">
        {/* Bouton Modérer (Admin) */}
        <a 
          href={`/${lang}/admin`} 
          id="admin-btn"
          data-admin-only
          class="btn btn-ghost btn-sm font-bold min-h-0 h-9 px-4 rounded-full hover:bg-emerald-50 text-emerald-700 transition-all hover:scale-105 active:scale-95 relative gap-1.5"
          aria-label={lang === 'fr' ? 'Accéder à la modération' : 'Access moderation'}
        >
          <div class="relative">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ACTION_ICONS.moderate} />
            </svg>
            <span id="pending-badge" class="hidden absolute -top-1.5 -right-1.5 h-4 w-4">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
              <span id="pending-count" class="relative inline-flex rounded-full h-4 w-4 bg-red-500 text-[10px] text-white items-center justify-center font-bold"></span>
            </span>
          </div>
          <span class="hidden md:inline">{t.admin}</span>
        </a>

        {/* Bouton Ajouter */}
        <a 
          href={`/${lang}/propose`} 
          id="propose-btn"
          data-auth-only
          class="btn btn-primary btn-sm font-bold min-h-0 h-9 px-4 rounded-full border-none shadow-md shadow-emerald-200/50 hover:bg-[#52b788] hover:scale-105 active:scale-95 transition-all gap-1.5"
          aria-label={lang === 'fr' ? 'Proposer une nouvelle ressource' : 'Propose a new resource'}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ACTION_ICONS.create} />
          </svg>
          <span class="hidden md:inline">{t.propose}</span>
        </a>

        {/* User Menu */}
        <div id="user-menu" class="flex items-center gap-2">
          <a href={`/${lang}/login`} id="login-link" class="text-xs font-bold text-stone-400 hover:text-primary transition-colors px-2">{t.login}</a>
          <div id="user-info" class="hidden items-center gap-2">
            <span id="user-name" class="text-[10px] font-black uppercase text-stone-400 max-w-[100px] truncate"></span>
            <button id="logout-btn" class="text-[10px] font-bold text-red-400 hover:text-red-600 transition-colors uppercase tracking-widest">{t.logout}</button>
          </div>
        </div>

        {/* Sélecteur de langue (Swap) */}
        <div class="ml-2">
          <label class="swap swap-rotate btn btn-ghost btn-sm h-9 w-12 p-0 rounded-full bg-emerald-50/50 text-emerald-800 border-none font-black text-xs hover:bg-emerald-100 transition-all" aria-label={lang === 'fr' ? 'Switch to English' : 'Passer en Français'}>
            <input type="checkbox" id="lang-toggle" checked={lang === 'en'} />
            
            {/* Langue active: EN (visible quand coché) */}
            <div class="swap-on">EN</div>
            
            {/* Langue active: FR (visible quand décoché) */}
            <div class="swap-off">FR</div>
          </label>
        </div>
      </div>
    </header>

    <main id="main-content" class="flex-grow container mx-auto p-6 max-w-5xl outline-none" tabindex="-1">
      <slot />
    </main>

    <footer class="footer footer-center p-12 bg-white text-stone-400 border-t border-emerald-50 mt-12">
      <div class="flex flex-col gap-4">
        <p class="text-xs italic font-medium">© {new Date().getFullYear()} - numindex.org — Pour un numérique joyeux, conscient et durable.</p>
        <nav class="flex gap-6 text-[10px] font-bold uppercase tracking-widest">
          <a href={`/${lang}/contact`} class="hover:text-primary transition-colors">{lang === 'fr' ? 'Contact' : 'Contact'}</a>
        </nav>
      </div>
    </footer>

    <script>
      import { supabase } from '../lib/supabase/client';
      import { fetchPendingSuggestionsCount } from '../lib/services';

      async function updateUI(session: any) {
        const loginLink = document.getElementById('login-link');
        const userInfo = document.getElementById('user-info');
        const userName = document.getElementById('user-name');
        const authOnlyEls = document.querySelectorAll('[data-auth-only]');
        const adminOnlyEls = document.querySelectorAll('[data-admin-only]');
        const pendingBadge = document.getElementById('pending-badge');
        const pendingCountEl = document.getElementById('pending-count');

        if (session) {
          loginLink?.classList.add('hidden');
          userInfo?.classList.remove('hidden');
          userInfo?.classList.add('flex');
          
          const { data: profile } = await supabase
            .from('profiles')
            .select('*')
            .eq('id', session.user.id)
            .single();

          if (userName) userName.innerText = profile?.full_name || session.user.email?.split('@')[0] || 'User';
          
          authOnlyEls.forEach(el => (el as HTMLElement).style.setProperty('display', 'inline-flex'));
          
          if (profile?.role === 'admin') {
            adminOnlyEls.forEach(el => (el as HTMLElement).style.setProperty('display', 'inline-flex'));
            const count = await fetchPendingSuggestionsCount();
            if (count > 0 && pendingBadge && pendingCountEl) {
              pendingCountEl.innerText = count > 99 ? '99+' : count.toString();
              pendingBadge.classList.remove('hidden');
              pendingBadge.classList.add('flex');
            }
          }
        } else {
          loginLink?.classList.remove('hidden');
          userInfo?.classList.add('hidden');
          authOnlyEls.forEach(el => (el as HTMLElement).style.setProperty('display', 'none'));
          adminOnlyEls.forEach(el => (el as HTMLElement).style.setProperty('display', 'none'));
          pendingBadge?.classList.add('hidden');

          const path = window.location.pathname;
          const isProtected = path.includes('/propose') || path.includes('/admin');
          const hasValidLang = path.startsWith('/fr/') || path.startsWith('/en/');

          if (isProtected && hasValidLang) {
            const currentLang = document.documentElement.lang || 'fr';
            const currentPath = window.location.pathname + window.location.search;
            window.location.replace(`/${currentLang}/login?redirect=${encodeURIComponent(currentPath)}`);
          }
        }
      }

      async function initAuth() {
        if (!supabase) return;

        // Écouter les changements d'état (plus robuste)
        supabase.auth.onAuthStateChange((_event, session) => {
          updateUI(session);
        });

        // Premier check
        const { data: { session } } = await supabase.auth.getSession();
        updateUI(session);

        const logoutBtn = document.getElementById('logout-btn');
        logoutBtn?.addEventListener('click', async () => {
          await supabase.auth.signOut();
          window.location.reload();
        });
      }

      function initLangToggle() {
        const toggle = document.getElementById('lang-toggle') as HTMLInputElement;
        if (!toggle) return;

        toggle.onchange = () => {
          const path = window.location.pathname;
          const search = window.location.search;
          const targetLang = toggle.checked ? 'en' : 'fr';
          const newPath = path.replace(/^\/(fr|en)/, `/${targetLang}`);
          window.location.href = newPath + search;
        };
      }

      initAuth();
      initLangToggle();
      
      // Re-init on page transitions (if using ViewTransitions)
      document.addEventListener('astro:after-swap', () => {
        initAuth();
        initLangToggle();
      });
    </script>
  </body>
</html>
