---
interface Props {
  title: string;
  lang: string;
}
const { title, lang } = Astro.props;

const t = {
  fr: { propose: "Proposer" },
  en: { propose: "Propose" }
}[lang];
---

<!doctype html>
<html lang={lang} data-theme="garden">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Salvia</title>
  </head>
  <body class="min-h-screen flex flex-col font-sans">
    <header class="navbar bg-base-100 border-b border-base-200 px-4">
      <div class="flex-1">
        <a href={`/${lang}`} class="text-xl font-bold tracking-tight flex items-center gap-2">
          <span class="text-2xl">🌿</span> Salvia
        </a>
      </div>
      <div class="flex-none gap-2 flex items-center">
        <a href="#" class="btn btn-outline btn-primary btn-sm font-bold min-h-0 h-9">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
          <span class="hidden md:inline">{t.propose}</span>
        </a>
        <nav class="menu menu-horizontal px-1 gap-1">
          <li><a href="/fr" class={`h-9 flex items-center px-3 rounded-lg ${lang === 'fr' ? 'bg-base-200 font-bold' : ''}`}>FR</a></li>
          <li><a href="/en" class={`h-9 flex items-center px-3 rounded-lg ${lang === 'en' ? 'bg-base-200 font-bold' : ''}`}>EN</a></li>
        </nav>
      </div>
    </header>
    <main class="flex-grow container mx-auto p-6 max-w-5xl">
      <slot />
    </main>
    <footer class="footer footer-center p-10 bg-base-200 text-base-content rounded mt-12">
      <aside>
        <p>© {new Date().getFullYear()} - Salvia - Annuaire Numérique Responsable</p>
      </aside>
    </footer>
  </body>
</html>
