---
import '../styles/global.css';
import { ACTION_ICONS } from '../utils/categories';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: URL;
  type?: 'website' | 'article';
  lang?: string;
  jsonLd?: string;
}
const { title, description, ogImage, canonicalURL, type, lang = 'fr', jsonLd } = Astro.props;

const translations = {
  fr: { propose: "Ajouter", skip: "Passer au contenu", admin: "Modérer", login: "Connexion", logout: "Déconnexion" },
  en: { propose: "Add", skip: "Skip to content", admin: "Moderate", login: "Login", logout: "Logout" }
};
const t = translations[lang as keyof typeof translations] || translations.fr;
---

<!doctype html>
<html lang={lang} data-theme="numindex">
  <head>
    <SEO {title} {description} {ogImage} {canonicalURL} {type} {lang} {jsonLd} />
    <style is:global>
      /* Style pour le lien d'évitement (Accessibilité) */
      .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        background: #133F1A; /* Nouveau vert numindex */
        color: white;
        padding: 8px;
        z-index: 100;
        transition: top 0.3s;
      }
      .skip-link:focus {
        top: 0;
      }
      /* Ambiance visuelle apaisée et fraîche */
      body {
        background-color: #fdfcfb !important;
        background-image: radial-gradient(#d8f3dc 0.5px, transparent 0.5px);
        background-size: 24px 24px;
        background-attachment: fixed;
      }
      [data-auth-only], [data-admin-only] {
        display: none;
      }

      /* Styles partagés pour les filtres et la navigation */
      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      
      .pill-chip { 
        cursor: pointer; 
        border-radius: 9999px; 
        padding: 6px 14px; 
        font-size: 10px; 
        font-weight: 800; 
        text-transform: uppercase; 
        letter-spacing: 0.025em;
        border: 1px solid #e7e5e4; 
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); 
        background: white; 
        color: #78716c;
        box-shadow: 0 1px 2px rgba(0,0,0,0.05);
      }
      .pill-chip:hover { 
        border-color: var(--p); 
        color: var(--p);
        background: #f0fdf4;
        transform: translateY(-1px);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
      }
      .pill-chip.active { 
        background: #133F1A !important; 
        color: white !important; 
        border-color: #133F1A !important;
        box-shadow: 0 10px 15px -3px rgba(19, 63, 26, 0.3);
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col font-sans text-stone-800 antialiased">
    <a href="#main-content" class="skip-link">{t.skip}</a>

    <header class="navbar bg-white/70 backdrop-blur-lg border-b border-emerald-100 px-4 sticky top-0 z-50 shadow-sm shadow-emerald-50/50">
      <div class="flex-1">
        <a href={`/${lang}`} class="flex items-center hover:opacity-80 transition-all focus-visible:outline-dashed focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary" aria-label="NumIndex - Accueil">
          <img src="/logo.svg" alt="NumIndex Logo" class="h-8 md:h-9 w-auto" />
        </a>
      </div>
      <div class="flex-none gap-1 md:gap-2 flex items-center">
        {/* Bouton Modérer (Admin) */}
        <a 
          href={`/${lang}/admin`} 
          id="admin-btn"
          data-admin-only
          class="btn btn-ghost btn-sm font-bold min-h-0 h-9 px-2 md:px-4 rounded-full hover:bg-stone-100 text-stone-600 hover:text-primary transition-all hover:scale-105 active:scale-95 relative gap-1.5"
          aria-label={lang === 'fr' ? 'Accéder à la modération' : 'Access moderation'}
        >
          <div class="relative">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ACTION_ICONS.moderate} />
            </svg>
            <span id="pending-badge" class="hidden absolute -top-1.5 -right-1.5 h-4 w-4">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
              <span id="pending-count" class="relative inline-flex rounded-full h-4 w-4 bg-red-500 text-[10px] text-white items-center justify-center font-bold"></span>
            </span>
          </div>
          <span class="hidden md:inline">{t.admin}</span>
        </a>

        {/* Bouton Ajouter */}
        {!Astro.url.pathname.includes('/propose') && (
          <a 
            href={`/${lang}/propose`} 
            id="propose-btn"
            class="btn btn-primary btn-sm font-bold min-h-0 h-9 px-3 md:px-4 rounded-full border-none shadow-md shadow-emerald-200/50 hover:bg-[#52b788] hover:scale-105 active:scale-95 transition-all gap-1.5"
            aria-label={lang === 'fr' ? 'Proposer une nouvelle ressource' : 'Propose a new resource'}
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ACTION_ICONS.create} />
            </svg>
            <span class="hidden md:inline">{t.propose}</span>
          </a>
        )}

        {/* User Menu */}
        <div id="user-menu" class="flex items-center gap-1 md:gap-2">
          <a href={`/${lang}/login`} id="login-link" class="text-xs font-black text-stone-500 hover:text-primary transition-colors px-1 md:px-2 uppercase tracking-tighter">{t.login}</a>
          <div id="user-info" class="hidden dropdown dropdown-end">
            <div tabindex="0" role="button" class="btn btn-ghost h-auto py-1 px-1 md:pl-1 md:pr-3 flex items-center gap-1.5 md:gap-2 rounded-full border border-stone-200 hover:bg-stone-50 transition-all group">
              <div class="avatar placeholder relative">
                <div class="w-8 h-8 md:w-9 md:h-9 rounded-full bg-emerald-100 flex items-center justify-center text-emerald-800 font-black text-[10px] md:text-xs uppercase overflow-hidden group-hover:scale-105 transition-transform border border-emerald-200">
                  <span id="user-initials" class="leading-none"></span>
                </div>
                <span id="profile-warning-badge" class="hidden absolute -top-1 -right-1 h-3.5 w-3.5">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-3.5 w-3.5 bg-red-500 border-2 border-white"></span>
                </span>
              </div>
              <div class="hidden md:flex flex-col items-start text-left">
                <span id="user-name-trigger" class="text-xs font-black text-stone-800 leading-tight truncate max-w-[100px]"></span>
                <span class="text-[9px] font-bold text-stone-500 uppercase tracking-wider">{lang === 'fr' ? 'Mon Compte' : 'My Account'}</span>
              </div>
              <svg xmlns="http://www.w3.org/2000/svg" class="hidden md:block h-3 w-3 text-stone-400 group-hover:text-stone-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
            <ul tabindex="0" class="mt-3 z-[100] p-2 shadow-2xl menu menu-sm dropdown-content bg-white rounded-2xl w-64 border border-stone-100">
              <div class="px-4 py-3 border-b border-stone-50 mb-2 flex items-center gap-3 overflow-hidden bg-stone-50/50 rounded-t-xl">
                <div class="avatar placeholder flex-shrink-0">
                  <div class="bg-stone-100 text-stone-600 rounded-full w-10 h-10 flex items-center justify-center border border-stone-200 shadow-inner">
                    <span id="user-initials-menu" class="text-xs font-black uppercase leading-none"></span>
                  </div>
                </div>
                <div class="flex flex-col min-w-0">
                  <span id="user-name" class="font-bold text-stone-800 truncate leading-none mb-1"></span>
                  <span id="user-email" class="text-[10px] text-stone-400 truncate leading-none"></span>
                </div>
              </div>
              <li id="profile-warning-item" class="hidden mb-1">
                <a href={`/${lang}/profile?tab=settings`} class="py-2 font-bold text-red-600 bg-red-50 hover:bg-red-100 rounded-xl transition-all flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                  <span class="text-xs leading-tight whitespace-normal">{lang === 'fr' ? 'Profil incomplet. Cliquez pour ajouter votre nom.' : 'Incomplete profile. Click to add your name.'}</span>
                </a>
              </li>
              <li>
                <a href={`/${lang}/profile`} class="py-3 font-bold text-stone-600 hover:text-primary active:bg-emerald-50 active:text-primary rounded-xl transition-all">
                  <div class="bg-white p-1.5 rounded-lg border border-stone-100 shadow-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                  </div>
                  <span>{lang === 'fr' ? 'Tableau de bord' : 'Dashboard'}</span>
                </a>
              </li>
              <li class="mt-1">
                <button id="logout-btn" class="py-3 font-bold text-red-400 hover:text-red-600 hover:bg-red-50 active:bg-red-100 rounded-xl">
                  <div class="bg-red-50/50 p-2 rounded-lg">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                  </div>
                  <span>{t.logout}</span>
                </button>
              </li>
            </ul>
          </div>
        </div>

        {/* Sélecteur de langue (Swap) */}
        <div class="ml-2">
          <label class="swap swap-rotate btn btn-ghost btn-sm h-9 w-12 p-0 rounded-full bg-stone-100 text-stone-600 border border-stone-200 hover:border-primary hover:text-primary font-black text-xs transition-all" aria-label={lang === 'fr' ? 'Switch to English' : 'Passer en Français'}>
            <input type="checkbox" id="lang-toggle" checked={lang === 'en'} />
            
            {/* Langue active: EN (visible quand coché) */}
            <div class="swap-on">EN</div>
            
            {/* Langue active: FR (visible quand décoché) */}
            <div class="swap-off">FR</div>
          </label>
        </div>
      </div>
    </header>

    <main id="main-content" class="flex-grow w-full px-4 md:px-6 py-6 md:py-8 outline-none" tabindex="-1">
      <slot />
    </main>

    <footer class="footer footer-center p-12 bg-white text-stone-500 border-t border-emerald-100 mt-12">
      <div class="flex flex-col gap-4">
        <nav class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-[10px] font-black uppercase tracking-widest text-stone-400">
          <a href={`/${lang}/about`} class="hover:text-primary transition-colors">{lang === 'fr' ? 'À propos' : 'About'}</a>
          <a href={`/${lang}/guide`} class="hover:text-primary transition-colors">{lang === 'fr' ? "Guide d'usage" : 'User Guide'}</a>
          <a href={`/${lang}/terms`} class="hover:text-primary transition-colors">{lang === 'fr' ? "Conditions d'utilisation" : 'Terms of Use'}</a>
          <a href={`/${lang}/contact`} class="hover:text-primary transition-colors">{lang === 'fr' ? 'Contact' : 'Contact'}</a>
        </nav>
      </div>
    </footer>

    <script>
      import { supabase } from '../lib/supabase/client';
      import { fetchPendingSuggestionsCount } from '../lib/services';

      async function updateUI(session: any) {
        const loginLink = document.getElementById('login-link');
        const userInfo = document.getElementById('user-info');
        const userName = document.getElementById('user-name');
        const userInitials = document.getElementById('user-initials');
        const authOnlyEls = document.querySelectorAll('[data-auth-only]');
        const adminOnlyEls = document.querySelectorAll('[data-admin-only]');
        const pendingBadge = document.getElementById('pending-badge');
        const pendingCountEl = document.getElementById('pending-count');

        async function refreshBadge() {
          if (!session) return;
          const { data: profile } = await supabase
            .from('profiles')
            .select('role')
            .eq('id', session.user.id)
            .single();

          if (profile?.role === 'admin') {
            const count = await fetchPendingSuggestionsCount();
            if (count > 0 && pendingBadge && pendingCountEl) {
              pendingCountEl.innerText = count > 99 ? '99+' : count.toString();
              pendingBadge.classList.remove('hidden');
              pendingBadge.classList.add('flex');
            } else {
              pendingBadge?.classList.add('hidden');
              pendingBadge?.classList.remove('flex');
            }
          }
        }

        if (session) {
          loginLink?.classList.add('hidden');
          userInfo?.classList.remove('hidden');
          userInfo?.classList.add('inline-block');
          
          const { data: profile } = await supabase
            .from('profiles')
            .select('*')
            .eq('id', session.user.id)
            .single();

          const fullName = profile?.full_name || session.user.email?.split('@')[0] || 'User';
          
          if (!profile?.full_name) {
            const warningBadge = document.getElementById('profile-warning-badge');
            const warningItem = document.getElementById('profile-warning-item');
            if (warningBadge) warningBadge.classList.remove('hidden');
            if (warningItem) warningItem.classList.remove('hidden');
          }

          const userEmail = session.user.email || '';
          const initials = fullName.split(' ').map((n: string) => n[0]).join('').substring(0, 2).toUpperCase();

          if (userName) userName.innerText = fullName;
          
          const userNameTrigger = document.getElementById('user-name-trigger');
          if (userNameTrigger) userNameTrigger.innerText = fullName;

          const userEmailEl = document.getElementById('user-email');
          if (userEmailEl) userEmailEl.innerText = userEmail;

          if (userInitials) userInitials.innerText = initials;
          
          const userInitialsMenu = document.getElementById('user-initials-menu');
          if (userInitialsMenu) userInitialsMenu.innerText = initials;
          
          authOnlyEls.forEach(el => (el as HTMLElement).style.setProperty('display', 'flex'));

          
          if (profile?.role === 'admin') {
            adminOnlyEls.forEach(el => (el as HTMLElement).style.setProperty('display', 'flex'));
            refreshBadge();
            document.addEventListener('suggestion-processed', refreshBadge);
          }
        } else {
          loginLink?.classList.remove('hidden');
          userInfo?.classList.add('hidden');
          userInfo?.classList.remove('inline-block');
          authOnlyEls.forEach(el => (el as HTMLElement).style.setProperty('display', 'none'));
          adminOnlyEls.forEach(el => (el as HTMLElement).style.setProperty('display', 'none'));
          pendingBadge?.classList.add('hidden');

          const path = window.location.pathname;
          const isProtected = path.includes('/propose') || path.includes('/admin');
          const hasValidLang = path.startsWith('/fr/') || path.startsWith('/en/');
          const hasAuthHash = window.location.hash.includes('access_token=') || window.location.hash.includes('recovery_token=');

          if (isProtected && hasValidLang && !hasAuthHash) {
            const currentLang = document.documentElement.lang || 'fr';
            
            // On veut rediriger vers la page de login en gardant le chemin actuel en mémoire
            const currentPath = window.location.pathname;
            const currentSearch = window.location.search;
            const fullRedirectPath = currentPath + currentSearch;
            
            window.location.replace(`/${currentLang}/login?redirect=${encodeURIComponent(fullRedirectPath)}`);
          }
        }
      }

      async function initAuth() {
        if (!supabase) return;

        // Écouter les changements d'état (plus robuste)
        supabase.auth.onAuthStateChange((_event, session) => {
          updateUI(session);
        });

        // Premier check
        const { data: { session } } = await supabase.auth.getSession();
        updateUI(session);

        const logoutBtn = document.getElementById('logout-btn');
        logoutBtn?.addEventListener('click', async () => {
          await supabase.auth.signOut();
          window.location.reload();
        });
      }

      function initLangToggle() {
        const toggle = document.getElementById('lang-toggle') as HTMLInputElement;
        if (!toggle) return;

        toggle.onchange = () => {
          const path = window.location.pathname;
          const search = window.location.search;
          const targetLang = toggle.checked ? 'en' : 'fr';
          const newPath = path.replace(/^\/(fr|en)/, `/${targetLang}`);
          window.location.href = newPath + search;
        };
      }

      initAuth();
      initLangToggle();
      
      // Re-init on page transitions (if using ViewTransitions)
      document.addEventListener('astro:after-swap', () => {
        initAuth();
        initLangToggle();
      });
    </script>
  </body>
</html>
