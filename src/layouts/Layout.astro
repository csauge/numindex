---
import { ACTION_ICONS } from '../utils/categories';

interface Props {
  title: string;
  lang: string;
}
const { title, lang } = Astro.props;

const t = {
  fr: { propose: "Ajouter", skip: "Passer au contenu", admin: "Modérer" },
  en: { propose: "Add", skip: "Skip to content", admin: "Moderate" }
}[lang];
---

<!doctype html>
<html lang={lang} data-theme="salvia">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Salvia</title>
    <style is:global>
      /* Style pour le lien d'évitement (Accessibilité) */
      .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        background: #40916c; /* Nouveau vert Salvia */
        color: white;
        padding: 8px;
        z-index: 100;
        transition: top 0.3s;
      }
      .skip-link:focus {
        top: 0;
      }
      /* Ambiance visuelle apaisée et fraîche */
      body {
        background-color: #fdfcfb !important;
        background-image: radial-gradient(#d8f3dc 0.5px, transparent 0.5px);
        background-size: 24px 24px;
        background-attachment: fixed;
      }
    </style>
  </head>
  <body class="min-h-screen flex flex-col font-sans text-stone-800 antialiased">
    <a href="#main-content" class="skip-link">{t.skip}</a>

    <header class="navbar bg-white/70 backdrop-blur-lg border-b border-emerald-100 px-4 sticky top-0 z-50 shadow-sm shadow-emerald-50/50">
      <div class="flex-1">
        <a href={`/${lang}`} class="text-xl font-black tracking-tight flex items-center gap-2 text-emerald-800 hover:opacity-80 transition-all focus-visible:outline-dashed focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary" aria-label="Salvia - Accueil">
          <span class="text-2xl" aria-hidden="true">🌱</span> Salvia
        </a>
      </div>
      <div class="flex-none gap-2 flex items-center">
        {/* Bouton Modérer (Admin) */}
        <a 
          href={`/${lang}/admin`} 
          class="btn btn-ghost btn-sm font-bold min-h-0 h-9 px-3 rounded-full hover:bg-emerald-50 text-emerald-700 transition-all"
          aria-label={lang === 'fr' ? 'Accéder à la modération' : 'Access moderation'}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ACTION_ICONS.moderate} />
          </svg>
          <span class="hidden md:inline">{t.admin}</span>
        </a>

        {/* Bouton Ajouter */}
        <a 
          href={`/${lang}/propose`} 
          class="btn btn-primary btn-sm font-bold min-h-0 h-9 px-4 rounded-full border-none shadow-md shadow-emerald-200/50 hover:bg-[#52b788] hover:scale-105 active:scale-95 transition-all"
          aria-label={lang === 'fr' ? 'Proposer une nouvelle ressource' : 'Propose a new resource'}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 md:mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ACTION_ICONS.create} />
          </svg>
          <span class="hidden md:inline">{t.propose}</span>
        </a>

        {/* Sélecteur de langue */}
        <nav class="flex items-center gap-1 ml-2 bg-emerald-50/50 p-1 rounded-full" aria-label={lang === 'fr' ? 'Changer de langue' : 'Change language'}>
          <button id="lang-fr" class={`h-7 flex items-center px-3 rounded-full text-xs transition-all ${lang === 'fr' ? 'bg-white text-emerald-800 shadow-sm font-black' : 'text-emerald-700/60 hover:text-emerald-800'}`} aria-current={lang === 'fr' ? 'page' : undefined}>FR</button>
          <button id="lang-en" class={`h-7 flex items-center px-3 rounded-full text-xs transition-all ${lang === 'en' ? 'bg-white text-emerald-800 shadow-sm font-black' : 'text-emerald-700/60 hover:text-emerald-800'}`} aria-current={lang === 'en' ? 'page' : undefined}>EN</button>
        </nav>
      </div>
    </header>

    <main id="main-content" class="flex-grow container mx-auto p-6 max-w-5xl outline-none" tabindex="-1">
      <slot />
    </main>

    <footer class="footer footer-center p-12 bg-white text-stone-400 border-t border-emerald-50 mt-12">
      <div class="flex flex-col gap-4">
        <p class="text-xs italic font-medium">© {new Date().getFullYear()} - Salvia — Pour un numérique joyeux, conscient et durable.</p>
        <nav class="flex gap-6 text-[10px] font-bold uppercase tracking-widest">
          <a href={`/${lang}/contact`} class="hover:text-primary transition-colors">{lang === 'fr' ? 'Contact' : 'Contact'}</a>
        </nav>
      </div>
    </footer>

    <script>
      function updateLangLinks() {
        const btnFr = document.getElementById('lang-fr');
        const btnEn = document.getElementById('lang-en');

        if (btnFr) {
          btnFr.onclick = () => {
            const path = window.location.pathname;
            const search = window.location.search;
            const newPath = path.replace(/^\/(fr|en)/, '/fr');
            window.location.href = newPath + search;
          };
        }
        if (btnEn) {
          btnEn.onclick = () => {
            const path = window.location.pathname;
            const search = window.location.search;
            const newPath = path.replace(/^\/(fr|en)/, '/en');
            window.location.href = newPath + search;
          };
        }
      }
      updateLangLinks();
    </script>
  </body>
</html>
