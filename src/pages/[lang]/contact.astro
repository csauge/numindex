---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params as { lang: 'fr' | 'en' };

const t = {
  fr: {
    title: "Contact",
    subtitle: "Une question ? Une suggestion ? N'hésitez pas à nous écrire.",
    name: "Nom",
    email: "Email",
    message: "Message",
    submit: "Envoyer le message",
    sending: "Envoi en cours...",
    success: "Message envoyé avec succès ! Nous vous répondrons dès que possible.",
    error: "Une erreur est survenue lors de l'envoi. Veuillez réessayer."
  },
  en: {
    title: "Contact",
    subtitle: "A question? A suggestion? Feel free to write to us.",
    name: "Name",
    email: "Email",
    message: "Message",
    submit: "Send message",
    sending: "Sending...",
    success: "Message sent successfully! We will get back to you as soon as possible.",
    error: "An error occurred while sending. Please try again."
  }
}[lang];
---

<Layout title={t.title} lang={lang}>
  <div class="max-w-xl mx-auto py-12">
    <header class="text-center mb-12">
      <h1 class="text-4xl font-black text-stone-800 mb-4">{t.title}</h1>
      <p class="text-stone-500 italic">{t.subtitle}</p>
    </header>

    <div class="bg-white p-8 rounded-2xl border border-stone-100 shadow-sm">
      <form id="contact-form" class="space-y-6">
        <div class="form-control">
          <label for="name" class="label"><span class="label-text font-bold text-stone-600">{t.name}</span></label>
          <input type="text" id="name" name="name" required class="input input-bordered bg-stone-50/50 focus:bg-white transition-all border-stone-200" />
        </div>

        <div class="form-control">
          <label for="email" class="label"><span class="label-text font-bold text-stone-600">{t.email}</span></label>
          <input type="email" id="email" name="email" required class="input input-bordered bg-stone-50/50 focus:bg-white transition-all border-stone-200" />
        </div>

        <div class="form-control">
          <label for="message" class="label"><span class="label-text font-bold text-stone-600">{t.message}</span></label>
          <textarea id="message" name="message" required class="textarea textarea-bordered h-32 bg-stone-50/50 focus:bg-white transition-all border-stone-200"></textarea>
        </div>

        <button type="submit" id="submit-btn" class="btn btn-primary w-full shadow-md shadow-emerald-100 border-none">
          {t.submit}
        </button>
      </form>

      <div id="status-message" class="mt-6 hidden p-4 rounded-xl text-sm font-bold text-center"></div>
    </div>
  </div>
</Layout>

<script define:vars={{ t }}>
  const form = document.getElementById('contact-form');
  const btn = document.getElementById('submit-btn');
  const status = document.getElementById('status-message');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    btn.disabled = true;
    btn.innerText = t.sending;
    status.classList.add('hidden');

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        status.innerText = t.success;
        status.className = "mt-6 p-4 rounded-xl text-sm font-bold text-center bg-emerald-50 text-emerald-700 block";
        form.reset();
      } else {
        throw new Error();
      }
    } catch (err) {
      status.innerText = t.error;
      status.className = "mt-6 p-4 rounded-xl text-sm font-bold text-center bg-red-50 text-red-700 block";
    } finally {
      btn.disabled = false;
      btn.innerText = t.submit;
    }
  });
</script>
