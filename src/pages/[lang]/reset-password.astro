---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';

const { lang } = Astro.params;

const translations = {
  fr: {
    title: "Nouveau mot de passe",
    description: "Veuillez entrer votre nouveau mot de passe.",
    password: "Nouveau mot de passe",
    confirmPassword: "Confirmer le mot de passe",
    submit: "Mettre à jour",
    passwordMismatch: "Les mots de passe ne correspondent pas.",
    successTitle: "Mot de passe mis à jour",
    successMessage: "Votre mot de passe a été modifié avec succès.",
    loginButton: "Se connecter",
    error: "Une erreur est survenue."
  },
  en: {
    title: "New password",
    description: "Please enter your new password.",
    password: "New password",
    confirmPassword: "Confirm password",
    submit: "Update",
    passwordMismatch: "Passwords do not match.",
    successTitle: "Password updated",
    successMessage: "Your password has been successfully changed.",
    loginButton: "Login",
    error: "An error occurred."
  }
};
const t = translations[lang as keyof typeof translations] || translations.fr;
---

<Layout title={t.title} lang={lang as string}>
  <div class="max-w-md mx-auto py-12 px-4">
    <div class="bg-white p-8 rounded-3xl border border-stone-200 shadow-xl shadow-stone-100/50">
      <h1 class="text-3xl font-black mb-4 text-center">{t.title}</h1>
      
      <div id="form-container">
        <p class="text-center text-stone-500 mb-6">{t.description}</p>
        
        <form id="reset-form" class="space-y-4">
          <div class="form-control">
            <label class="label"><span class="label-text font-bold">{t.password}</span></label>
            <input type="password" name="password" id="password" required minlength="6" class="input input-bordered rounded-2xl w-full" />
          </div>
          
          <div class="form-control">
            <label class="label"><span class="label-text font-bold">{t.confirmPassword}</span></label>
            <input type="password" name="confirmPassword" id="confirmPassword" required minlength="6" class="input input-bordered rounded-2xl w-full" />
          </div>
          
          <div id="error-message" class="text-error text-sm font-bold hidden bg-red-50 p-3 rounded-xl border border-red-100 text-center">
            {t.error}
          </div>
          
          <div id="password-mismatch" class="text-error text-sm font-bold hidden bg-red-50 p-3 rounded-xl border border-red-100 text-center">
            {t.passwordMismatch}
          </div>

          <button type="submit" class="btn btn-primary w-full rounded-2xl font-black mt-4">
            {t.submit}
          </button>
        </form>
      </div>

      <div id="success-message" class="hidden text-center py-6">
        <div class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h2 class="text-2xl font-black mb-2">{t.successTitle}</h2>
        <p class="text-stone-500 mb-6">{t.successMessage}</p>
        <a href={`/${lang}/login`} class="btn btn-primary w-full rounded-2xl font-black">
          {t.loginButton}
        </a>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { supabase } from '../../lib/supabase/client';

  const form = document.getElementById('reset-form') as HTMLFormElement;
  const formContainer = document.getElementById('form-container');
  const successMsg = document.getElementById('success-message');
  const errorMsg = document.getElementById('error-message');
  const mismatchMsg = document.getElementById('password-mismatch');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMsg?.classList.add('hidden');
    mismatchMsg?.classList.add('hidden');
    
    const formData = new FormData(form);
    const password = formData.get('password') as string;
    const confirmPassword = formData.get('confirmPassword') as string;
    
    if (password !== confirmPassword) {
      mismatchMsg?.classList.remove('hidden');
      return;
    }

    const { error } = await supabase.auth.updateUser({
      password: password
    });

    if (error) {
      if (errorMsg) {
        errorMsg.textContent = error.message;
        errorMsg.classList.remove('hidden');
      }
    } else {
      // Deconnecter l'utilisateur apres le reset pour le forcer a se reconnecter proprement
      await supabase.auth.signOut();
      
      formContainer?.classList.add('hidden');
      successMsg?.classList.remove('hidden');
    }
  });
</script>
