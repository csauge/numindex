---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import ResourceIcons from "../../components/ResourceIcons.astro";
import FilterBar from "../../components/FilterBar.astro";
import ResourceGrid from "../../components/ResourceGrid.astro";
import { CATEGORIES, getCategoryLabel } from "../../utils/categories";
import { getImageUrl } from "../../lib/supabase/client";
import { fetchAllResources, getNextEventDate } from "../../lib/services";

const { lang } = Astro.params;
const allRessources = await fetchAllResources();
const activeCategoryKeys = [...new Set(allRessources.map(r => r.category))].sort();

const taxonomy = Object.fromEntries(
  Object.entries(CATEGORIES).map(([k, v]) => [k, v.mandatoryTags])
);

const translations = {
  fr: {
    title: "L'index du numérique responsable",
    desc: "Explorez les initiatives engagées pour un futur numérique plus sobre, éthique et accessible.",
    searchPlaceholder: "Rechercher...",
    filterCat: "Toutes catégories",
    filterSub: "Tous types",
    filterSort: "Trier par",
    sortNewest: "Mise à jour",
    sortName: "Nom A-Z",
    sortCat: "Catégorie",
    sortDate: "Prochaine date",
    sortPub: "Parution",
    results: "ressources",
    loadMore: "Afficher plus",
    noResults: "Aucune ressource trouvée.",
    exportBookmarks: "Favoris Navigateur",
    exportCalendar: "Calendrier évènements",
    thisWeek: "Cette semaine",
    thisMonth: "Ce mois-ci",
    thisYear: "Cette année",
    older: "Plus ancien",
    noDate: "Sans date",
    pastDate: "Passé"
  },
  en: {
    title: "Sustainable Digital Index",
    desc: "Explore initiatives committed to a more digital future.",
    searchPlaceholder: "Search...",
    filterCat: "All categories",
    filterSub: "All types",
    filterSort: "Sort by",
    sortNewest: "Updated",
    sortName: "Name A-Z",
    sortCat: "Category",
    sortDate: "Next date",
    sortPub: "Publication",
    results: "resources",
    loadMore: "Load more",
    noResults: "No resources found.",
    exportBookmarks: "Browser Bookmarks",
    exportCalendar: "Events Calendar",
    thisWeek: "This week",
    thisMonth: "This month",
    thisYear: "This year",
    older: "Older",
    noDate: "No date",
    pastDate: "Past"
  }
};

const t = lang === "en" ? translations.en : translations.fr;

const clientResources = allRessources.map(res => ({
  id: res.id,
  title: res.title,
  desc: res.description,
  cat: res.category,
  catLabel: getCategoryLabel(res.category, lang as any),
  imgUrl: res.image_url ? getImageUrl(res.image_url, { width: 250, quality: 50 }) : null,
  link: res.link,
  up: res.updated_at,
  pub: res.metadata?.published_at,
  next: getNextEventDate(res),
  tags: res.tags || [],
  kw: (res.title + " " + (res.description || "") + " " + (res.tags?.join(" ") || "")).toLowerCase()
}));
---

<Layout title={t.title} lang={lang as string}>
  <ResourceIcons />

  <section class="max-w-7xl mx-auto px-4">
    <header class="mb-10 pt-8">
      <h1 id="main-title" class="text-3xl font-black text-stone-800 mb-2">{t.title}</h1>
      <p class="text-stone-500 italic text-sm">{t.desc}</p>
    </header>

    <FilterBar lang={lang as string} t={t} activeCategoryKeys={activeCategoryKeys} />

    <ResourceGrid t={t} initialCount={allRessources.length} />
  </section>

  <script id="taxonomy-data" type="application/json" is:inline set:html={JSON.stringify(taxonomy)} />
  <script id="resource-data" type="application/json" is:inline set:html={JSON.stringify(clientResources)} />
</Layout>

<script>
  import { initIndex } from "../../lib/index-client";

  const allData = JSON.parse(document.getElementById('resource-data')?.textContent || '[]');
  const taxonomy = JSON.parse(document.getElementById('taxonomy-data')?.textContent || '{}');
  const currentLang = document.documentElement.lang || 'fr';
  
  const translations = {
    fr: { thisWeek: "Cette semaine", thisMonth: "Ce mois-ci", thisYear: "Cette année", older: "Plus ancien", noDate: "Sans date", pastDate: "Passé", filterSub: "Tous types" },
    en: { thisWeek: "This week", thisMonth: "This month", thisYear: "This year", older: "Older", noDate: "No date", pastDate: "Past", filterSub: "All types" }
  };

  const t = translations[currentLang as keyof typeof translations] || translations.fr;

  initIndex(allData, taxonomy, currentLang, t);
</script>

<style is:global>
  .truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .alphabet-divider span { font-size: 1.5rem; font-weight: 900; color: #10b981; opacity: 0.3; text-transform: capitalize; }
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .pill { cursor: pointer; border-radius: 9999px; padding: 4px 12px; font-size: 10px; font-weight: 800; text-transform: uppercase; border: 1px solid #e7e5e4; transition: all 0.2s; background: #fafaf9; color: #78716c; }
  .pill:hover { border-color: #d6d3d1; background: #f5f5f4; }
  .pill.active { background: #10b981 !important; color: white !important; border-color: #10b981 !important; }
</style>
