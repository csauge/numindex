---
export const prerender = false;

import Layout from '../../../layouts/Layout.astro';
import { getCategoryLabel, getCategoryIcon, getCategoryType, ACTION_ICONS, getCategoryMandatoryTags } from '../../../utils/categories';
import { supabase, getImageUrl } from '../../../lib/supabase/client';
import type { Resource } from '../../../lib/supabase/types';
import { getProfile, getNextEventDate } from '../../../lib/services';

const { id, lang } = Astro.params;

// Fetch current resource
const { data: res } = await supabase
  .from('resources')
  .select('*')
  .eq('id', id)
  .single();

if (!res) return Astro.redirect(`/${lang}`);

// Sub-category identification
const mandatoryTags = getCategoryMandatoryTags(res.category);
const subCategory = res.tags?.find((t: string) => mandatoryTags.includes(t));
const otherTags = res.tags?.filter((t: string) => t !== subCategory) || [];

// Fetch profiles for creators/editors
const createdByProfile = res.created_by ? await getProfile(res.created_by) : null;
const updatedByProfile = res.updated_by ? await getProfile(res.updated_by) : null;

// Fetch related entities (if this is a resource) or children (if this is an entity)
let relatedResources: Resource[] = [];
if (getCategoryType(res.category) === 'entity') {
  const { data } = await supabase
    .from('resources')
    .select('id, title, category')
    .contains('related_ids', [id]);
  if (data) relatedResources = data as Resource[];
} else if (res.related_ids?.length > 0) {
  const { data } = await supabase
    .from('resources')
    .select('id, title, category')
    .in('id', res.related_ids);
  if (data) relatedResources = data as Resource[];
}

// Fetch total favorites count
const { data: favCountData } = await supabase
  .from('resource_favorite_counts')
  .select('total_favorites')
  .eq('resource_id', id)
  .single();

const totalFavorites = favCountData?.total_favorites || 0;

const translations = {
  fr: {
    back: "Retour à l'index",
    visit: "Visiter le site officiel",
    details: "Détails",
    tags: "Tags",
    relations: getCategoryType(res.category) === 'entity' ? "Ressources proposées :" : "Proposé par :",
    meta: "Informations",
    created: "Soumis le",
    updated: "Modifié le",
    by: "par",
    edit: "Modifier",
    report: "Supprimer",
    published: "Publié le",
    version: "Dernière version",
    nextEvent: "Prochain événement",
    occurrences: "Éditions / Dates",
    address: "Lieu / Adresse",
    favorite: "Favori",
    totalFavorites: "favoris",
  },
  en: {
    back: "Back to index",
    visit: "Visit official website",
    details: "Details",
    tags: "Tags",
    relations: getCategoryType(res.category) === 'entity' ? "Proposed resources:" : "Proposed by:",
    meta: "Information",
    created: "Submitted on",
    updated: "Modified on",
    by: "by",
    edit: "Edit",
    report: "Delete",
    published: "Published on",
    version: "Latest version",
    nextEvent: "Next event",
    occurrences: "Editions / Dates",
    address: "Location / Address",
    favorite: "Favorite",
    totalFavorites: "favorites",
  }
};
const t = translations[lang as keyof typeof translations] || translations.fr;

const formatDate = (dateStr: string, options: Intl.DateTimeFormatOptions = { day: 'numeric', month: 'long', year: 'numeric' }) => {
  return new Date(dateStr).toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-US', options);
};

const formatDateTime = (dateStr: string) => {
  return new Date(dateStr).toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-US', { 
    day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' 
  });
};

const nextEventDate = getNextEventDate(res as Resource);

const categoryLabel = getCategoryLabel(res.category, lang as 'fr' | 'en');
const pageTitle = `${res.title} — ${categoryLabel} Numérique Responsable`;

const currentUrl = new URL(Astro.url.pathname.replace(/\/$/, ''), Astro.site).toString();

// JSON-LD
const baseJsonLd = {
  "@context": "https://schema.org",
  "@type": res.category === 'outil' ? "SoftwareApplication" : 
           res.category === 'evenement' ? "Event" :
           res.category === 'acteur' ? "Organization" : "Article",
  "name": res.title,
  "description": res.description,
  "url": currentUrl,
};

if (res.category === 'evenement' && nextEventDate) {
  Object.assign(baseJsonLd, {
    "startDate": nextEventDate,
    "location": {
      "@type": "Place",
      "name": res.metadata?.address || "Online",
      "address": res.metadata?.address
    }
  });
}

if (res.category === 'outil') {
  Object.assign(baseJsonLd, {
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web"
  });
}

const jsonLd = JSON.stringify(baseJsonLd);
---

<Layout 
  title={pageTitle} 
  description={res.description} 
  ogImage={res.image_url ? getImageUrl(res.image_url) : undefined}
  type="article"
  lang={lang as string}
  jsonLd={jsonLd}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    
    {/* Navigation Retour */}
    <a href={`/${lang}`} class="inline-flex items-center gap-2 text-stone-500 hover:text-primary transition-colors text-sm font-black mb-12 group">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
      {t.back}
    </a>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      
      {/* Colonne Gauche : Visuel & Actions */}
      <div class="space-y-8">
        <div class="aspect-square rounded-3xl bg-white border border-stone-200 shadow-sm overflow-hidden flex items-center justify-center p-6 relative group">
          {res.image_url ? (
            <img src={getImageUrl(res.image_url)} alt="" class="w-full h-full object-contain" />
          ) : (
            <svg xmlns="http://www.w3.org/2000/svg" class="w-24 h-24 text-stone-100" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={getCategoryIcon(res.category)} />
            </svg>
          )}
        </div>

        <div class="flex flex-col gap-3">
          <a href={res.link} target="_blank" rel="noopener noreferrer" class="btn btn-primary w-full shadow-md shadow-primary/20 rounded-2xl font-black">
            {t.visit}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
          </a>
          
          <button id="btn-favorite-main" class="btn btn-outline border-stone-200 hover:border-amber-300 hover:bg-amber-50 text-stone-500 hover:text-amber-600 w-full rounded-2xl font-bold gap-2 group transition-all" data-id={id}>
            <svg id="fav-star-main" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-stone-300 fill-none transition-colors" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.175 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.382-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
            <span id="fav-count-main" class="text-sm font-black text-stone-400 transition-colors">{totalFavorites}</span>
          </button>

          <div class="flex gap-2">
            <a href={`/${lang}/propose?id=${res.id}&action=update`} class="btn btn-ghost btn-sm flex-1 text-[10px] uppercase font-bold text-stone-400 hover:text-primary gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ACTION_ICONS.update} /></svg>
              {t.edit}
            </a>
            <a href={`/${lang}/propose?id=${res.id}&action=delete`} class="btn btn-ghost btn-sm flex-1 text-[10px] uppercase font-bold text-stone-400 hover:text-error gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={ACTION_ICONS.delete} /></svg>
              {t.report}
            </a>
          </div>
        </div>
      </div>

      {/* Colonne Droite : Contenu */}
      <div class="md:col-span-2 space-y-10">
        <div>
          <div class="flex flex-wrap items-center gap-2 mb-4">
            <span class="px-1.5 py-0.5 rounded bg-stone-100 text-stone-700 text-[9px] font-black uppercase tracking-tight border border-stone-200">
              {getCategoryLabel(res.category, lang as 'fr' | 'en')}
            </span>
            {subCategory && (
              <span class="px-1.5 py-0.5 rounded bg-emerald-100 text-emerald-800 text-[9px] font-black uppercase tracking-tight border border-emerald-200 shadow-sm">
                {subCategory}
              </span>
            )}
            {res.category !== 'evenement' && res.metadata?.address && (
              <span class="flex items-center gap-1 text-[9px] font-bold text-stone-600 uppercase tracking-tight bg-stone-50 px-1.5 py-1 rounded border border-stone-200 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                {res.metadata.address}
              </span>
            )}
            {res.metadata?.published_at && (
              <span class="flex items-center gap-1 text-[10px] font-bold text-stone-600 uppercase tracking-wider bg-stone-100 px-2 py-1 rounded border border-stone-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                {t.published} {formatDate(res.metadata.published_at)}
              </span>
            )}
            {res.metadata?.version_date && (
              <span class="flex items-center gap-1 text-[10px] font-bold text-stone-600 uppercase tracking-wider bg-stone-100 px-2 py-1 rounded border border-stone-200">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                {t.version} : {formatDate(res.metadata.version_date)}
              </span>
            )}
            {nextEventDate && (
              <span class="flex items-center gap-1 text-[10px] font-bold text-emerald-600 uppercase tracking-wider bg-emerald-50 px-2 py-1 rounded border border-emerald-100 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                {t.nextEvent} : {formatDateTime(nextEventDate)}
              </span>
            )}
          </div>
          <h1 class="text-4xl md:text-5xl font-black text-stone-800 leading-tight">{res.title}</h1>
        </div>

        <div class="prose prose-stone max-w-none">
          <p class="text-lg text-stone-600 leading-relaxed italic">{res.description}</p>
        </div>

        {res.metadata?.occurrences?.length > 0 && (
          <div class="space-y-4">
            <h2 class="text-xs font-black uppercase tracking-widest text-stone-300">{t.occurrences}</h2>
            <div class="grid gap-3">
              {res.metadata.occurrences.map((occ: any) => {
                const isNext = occ.start === nextEventDate;
                return (
                  <div class={`p-4 rounded-2xl border transition-all ${isNext ? 'bg-emerald-50 border-emerald-200 shadow-sm' : 'bg-white border-stone-100'}`}>
                    <div class="flex justify-between items-start">
                      <div>
                        <p class={`text-sm font-bold ${isNext ? 'text-emerald-800' : 'text-stone-700'}`}>
                          {formatDateTime(occ.start)} 
                          {occ.end && ` → ${formatDateTime(occ.end)}`}
                        </p>
                        {occ.address && <p class="text-xs text-stone-400 mt-1">{occ.address}</p>}
                      </div>
                      {isNext && <span class="badge badge-primary badge-xs font-black uppercase px-2 py-1 rounded-lg">Next</span>}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        {otherTags.length > 0 && (
          <div class="space-y-4">
            <h2 class="text-xs font-black uppercase tracking-widest text-stone-300">{t.tags}</h2>
            <div class="flex flex-wrap gap-2">
              {otherTags.map((tag: string) => (
                <span class="px-3 py-1 bg-white border border-stone-200 rounded-full text-xs font-bold text-stone-500 shadow-sm hover:border-primary/30 transition-colors cursor-default">{tag}</span>
              ))}
            </div>
          </div>
        )}

        {relatedResources.length > 0 && (
          <div class="space-y-4 pt-8 border-t border-stone-100">
            <h2 class="text-xs font-black uppercase tracking-widest text-stone-300">{t.relations}</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {relatedResources.map((rel) => (
                <a href={`/${lang}/resource/${rel.id}`} class="flex items-center gap-3 p-3 bg-white border border-stone-100 rounded-2xl hover:border-primary/20 hover:shadow-md transition-all group">
                  <div class="w-10 h-10 rounded-xl bg-stone-50 flex items-center justify-center text-stone-300 group-hover:text-primary transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={getCategoryIcon(rel.category)} />
                    </svg>
                  </div>
                  <span class="text-sm font-bold text-stone-700 group-hover:text-primary transition-colors">{rel.title}</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="pt-8 border-t border-stone-100 flex flex-wrap gap-x-8 gap-y-4">
          <div>
            <p class="text-[9px] font-black uppercase tracking-tighter text-stone-300">{t.created}</p>
            <p class="text-xs font-bold text-stone-500">
              {formatDate(res.created_at)}
              {createdByProfile && <span class="text-stone-300 font-medium"> {t.by} {createdByProfile.full_name}</span>}
            </p>
          </div>
          {res.updated_at !== res.created_at && (
            <div>
              <p class="text-[9px] font-black uppercase tracking-tighter text-stone-300">{t.updated}</p>
              <p class="text-xs font-bold text-stone-500">
                {formatDate(res.updated_at)}
                {updatedByProfile && <span class="text-stone-300 font-medium"> {t.by} {updatedByProfile.full_name}</span>}
              </p>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { toggleFavorite, fetchUserFavoriteIds } from '../../../lib/favorites-client';

  const btn = document.getElementById('btn-favorite-main') as HTMLButtonElement;
  const star = document.getElementById('fav-star-main') as unknown as SVGElement;
  const countEl = document.getElementById('fav-count-main')!;
  const resourceId = btn.dataset.id!;
  const currentLang = document.documentElement.lang || 'fr';

  function updateVisuals(isActive: boolean) {
    if (isActive) {
      btn.classList.add('border-amber-200', 'bg-amber-50', 'text-amber-600');
      star.classList.remove('text-stone-300', 'fill-none');
      star.classList.add('text-amber-500', 'fill-amber-500');
      countEl.classList.remove('text-stone-400');
      countEl.classList.add('text-amber-600');
    } else {
      btn.classList.remove('border-amber-200', 'bg-amber-50', 'text-amber-600');
      star.classList.add('text-stone-300', 'fill-none');
      star.classList.remove('text-amber-500', 'fill-amber-500');
      countEl.classList.add('text-stone-400');
      countEl.classList.remove('text-amber-600');
    }
  }

  async function init() {
    const favorites = await fetchUserFavoriteIds();
    if (favorites.includes(resourceId)) {
      btn.dataset.active = 'true';
      updateVisuals(true);
    }
  }

  btn.onclick = async () => {
    try {
      const res = await toggleFavorite(resourceId);
      if (res === null) {
        window.location.href = `/${currentLang}/login?redirect=${encodeURIComponent(window.location.pathname)}`;
        return;
      }

      const currentCount = parseInt(countEl.innerText);
      if (res) {
        btn.dataset.active = 'true';
        updateVisuals(true);
        countEl.innerText = (currentCount + 1).toString();
      } else {
        delete btn.dataset.active;
        updateVisuals(false);
        countEl.innerText = Math.max(0, currentCount - 1).toString();
      }
    } catch (err) {
      console.error(err);
    }
  };

  init();
</script>
