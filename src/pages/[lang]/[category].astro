---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import ResourceIcons from "../../components/ResourceIcons.astro";
import FilterBar from "../../components/FilterBar.astro";
import ResourceGrid from "../../components/ResourceGrid.astro";
import { CATEGORIES, getCategoryLabel, TAG_TRANSLATIONS } from "../../utils/categories";
import { getImageUrl } from "../../lib/supabase/client";
import { fetchAllResources, getNextEventDate } from "../../lib/services";

const { lang, category } = Astro.params;

// Map plural URL to category key
const categoryMapping: Record<string, string> = {
  'acteurs': 'acteur',
  'evenements': 'evenement',
  'contenus': 'contenu',
  'outils': 'outil',
  'actors': 'acteur',
  'events': 'evenement',
  'contents': 'contenu',
  'tools': 'outil'
};

const categoryKey = categoryMapping[category as string];

// If not a valid category, 404
if (!categoryKey) {
  return Astro.redirect(`/${lang}`);
}

const allRessources = await fetchAllResources();
const filteredResources = allRessources.filter(r => r.category === categoryKey);
const activeCategoryKeys = [categoryKey];

const taxonomy = Object.fromEntries(
  Object.entries(CATEGORIES).map(([k, v]) => [k, v.mandatoryTags])
);

const catLabel = getCategoryLabel(categoryKey, lang as 'fr' | 'en');

const translations = {
  fr: {
    title: `Liste des ${catLabel}s Numérique Responsable`,
    desc: `Découvrez tous les ${catLabel}s engagés pour un numérique plus sobre, éthique et accessible.`,
    searchPlaceholder: "Rechercher...",
    filterCat: "Catégories",
    filterSub: "Tous types",
    filterSort: "Trier par",
    sortNewest: "Récent",
    sortName: "Nom A-Z",
    sortCat: "Catégorie",
    sortDate: "A venir",
    sortPub: "Parution",
    sortFavorites: "Favoris",
    filterFavorites: "Favoris",
    results: "ressources",
    loadMore: "Afficher plus",
    noResults: "Aucune ressource trouvée.",
    exportBookmarks: "Favoris Navigateur",
    exportCalendar: "Calendrier évènements",
    thisWeek: "Cette semaine",
    thisMonth: "Ce mois-ci",
    thisYear: "Cette année",
    older: "Plus ancien",
    noDate: "Sans date",
    pastDate: "Passé",
    popular: "Les plus populaires",
    others: "Autres ressources"
  },
  en: {
    title: `${catLabel}s — Sustainable Digital Index`,
    desc: `Explore all ${catLabel}s committed to a more digital future.`,
    searchPlaceholder: "Search...",
    filterCat: "Categories",
    filterSub: "All types",
    filterSort: "Sort by",
    sortNewest: "Updated",
    sortName: "Name A-Z",
    sortCat: "Category",
    sortDate: "Next date",
    sortPub: "Publication",
    sortFavorites: "Most favorited",
    filterFavorites: "Favorites",
    results: "resources",
    loadMore: "Load more",
    noResults: "No resources found.",
    exportBookmarks: "Browser Bookmarks",
    exportCalendar: "Events Calendar",
    thisWeek: "This week",
    thisMonth: "This month",
    thisYear: "This year",
    older: "Older",
    noDate: "No date",
    pastDate: "Past",
    popular: "Most popular",
    others: "Other resources"
  }
};

const t = lang === "en" ? translations.en : translations.fr;

const clientResources = filteredResources.map(res => ({
  id: res.id,
  title: res.title,
  desc: res.description,
  cat: res.category,
  catLabel: getCategoryLabel(res.category, lang as any),
  imgUrl: res.image_url ? getImageUrl(res.image_url, { width: 250, quality: 50 }) : null,
  link: res.link,
  up: res.updated_at,
  pub: res.metadata?.published_at,
  next: getNextEventDate(res),
  stars: res.metadata?.stars_count || null,
  tags: res.tags || [],
  kw: (res.title + " " + (res.description || "") + " " + (res.tags?.join(" ") || "")).toLowerCase()
}));

// SEO Keywords based on category
const seoKeywords: Record<string, string[]> = {
  acteur: ["entreprises tech éthique", "associations numérique responsable", "acteurs green IT", "sociétés éco-responsables"],
  evenement: ["conférences numérique responsable", "ateliers green IT", "webinaires éco-conception", "meetups tech durable"],
  contenu: ["guides éco-conception", "rapports green IT", "articles numérique responsable", "podcasts tech éthique"],
  outil: ["outils éco-conception", "logiciels green IT", "solutions numérique responsable", "référentiels durables"]
};

const keywords = seoKeywords[categoryKey] || [];
const extendedDesc = `${t.desc} Retrouvez notre sélection : ${keywords.join(', ')}.`;

const currentUrl = new URL(Astro.url.pathname.replace(/\/$/, ''), Astro.site).toString();

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": t.title,
  "description": extendedDesc,
  "url": currentUrl,
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": clientResources.slice(0, 10).map((res, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "url": new URL(`${lang}/resource/${res.id}`, Astro.site).toString(),
      "name": res.title
    }))
  }
});
---

<Layout title={t.title} description={extendedDesc} lang={lang as string} jsonLd={jsonLd}>
  <ResourceIcons />

  <section class="max-w-7xl mx-auto px-4">
    <header class="mb-6 pt-8">
      <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h1 id="main-title" class="text-3xl font-black text-stone-800 mb-1 leading-tight tracking-tighter">{t.title}</h1>
          <p class="text-stone-500 italic text-sm font-medium">{t.desc}</p>
        </div>
        <div class="px-4 py-2 bg-stone-50 rounded-2xl border border-stone-200 flex items-center gap-2 self-start md:self-center shadow-sm">
          <span id="results-count" class="text-sm font-black text-stone-800">{filteredResources.length}</span>
          <span class="text-[9px] font-black uppercase text-stone-400 tracking-tight">{t.results}</span>
        </div>
      </div>
    </header>

    <FilterBar lang={lang as string} t={t} />

    <ResourceGrid t={t} initialCount={filteredResources.length} />
  </section>

  <script id="taxonomy-data" type="application/json" is:inline set:html={JSON.stringify(taxonomy)} />
  <script id="tag-translations" type="application/json" is:inline set:html={JSON.stringify(TAG_TRANSLATIONS)} />
  <script id="resource-data" type="application/json" is:inline set:html={JSON.stringify(clientResources)} />
</Layout>

<script>
  import { initIndex } from "../../lib/index-client";

  const allData = JSON.parse(document.getElementById('resource-data')?.textContent || '[]');
  const taxonomy = JSON.parse(document.getElementById('taxonomy-data')?.textContent || '{}');
  const currentLang = document.documentElement.lang || 'fr';
  
  const translations = {
    fr: { thisWeek: "Cette semaine", thisMonth: "Ce mois-ci", thisYear: "Cette année", older: "Plus ancien", noDate: "Sans date", pastDate: "Passé", filterSub: "Tous types", popular: "Les plus populaires", others: "Autres ressources" },
    en: { thisWeek: "This week", thisMonth: "This month", thisYear: "This year", older: "Older", noDate: "No date", pastDate: "Past", filterSub: "All types", popular: "Most popular", others: "Other resources" }
  };

  const t = translations[currentLang as keyof typeof translations] || translations.fr;

  initIndex(allData, taxonomy, currentLang, t);
</script>

<style is:global>
  .truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .alphabet-divider span { font-size: 12px; font-weight: 900; color: var(--p); text-transform: uppercase; letter-spacing: 0.1em; padding-right: 1.5rem; opacity: 0.6; flex-shrink: 0; }
  .alphabet-divider { position: relative; border: none !important; display: flex; align-items: center; margin-bottom: 0.25rem; }
  .alphabet-divider::after { content: ""; flex-grow: 1; height: 1px; background: #e7e5e4; }
</style>
