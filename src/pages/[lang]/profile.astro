---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase/client';

const { lang } = Astro.params;

const translations = {
  fr: {
    title: "Mon Profil",
    info: "Informations personnelles",
    name: "Nom complet",
    email: "Adresse Email",
    role: "Rôle",
    roleAdmin: "Administrateur",
    roleUser: "Utilisateur",
    contributions: "Mes contributions",
    noContributions: "Vous n'avez pas encore proposé de ressources.",
    favorites: "Mes Favoris",
    noFavorites: "Vous n'avez pas encore de favoris.",
    statusPending: "En attente",
    statusApproved: "Approuvé",
    statusRejected: "Refusé",
    backHome: "Retour à l'accueil"
  },
  en: {
    title: "My Profile",
    info: "Personal Information",
    name: "Full Name",
    email: "Email Address",
    role: "Role",
    roleAdmin: "Administrator",
    roleUser: "User",
    contributions: "My contributions",
    noContributions: "You haven't suggested any resources yet.",
    favorites: "My Favorites",
    noFavorites: "You haven't favorited any resources yet.",
    statusPending: "Pending",
    statusApproved: "Approved",
    statusRejected: "Rejected",
    backHome: "Back to home"
  }
};

const t = translations[lang as keyof typeof translations] || translations.fr;
---

<Layout title={t.title} lang={lang as string}>
  <div id="profile-content" class="max-w-4xl mx-auto py-8 hidden">
    <div class="flex items-center gap-6 mb-12">
      <div class="w-20 h-20 rounded-3xl bg-emerald-100 flex items-center justify-center text-emerald-700 font-black text-3xl uppercase shadow-inner border border-emerald-50">
        <span id="p-initials"></span>
      </div>
      <div>
        <h1 id="p-name" class="text-4xl font-black text-stone-800"></h1>
        <p id="p-email" class="text-stone-400 font-medium"></p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="md:col-span-1 space-y-6">
        <div class="bg-white p-6 rounded-3xl border border-stone-100 shadow-sm">
          <h2 class="text-xs font-black uppercase tracking-widest text-stone-400 mb-4">{t.info}</h2>
          <div class="space-y-4">
            <div>
              <p class="text-[10px] font-bold text-stone-300 uppercase tracking-tighter">{t.role}</p>
              <p id="p-role" class="font-bold text-stone-600"></p>
            </div>
          </div>
        </div>

        <div class="bg-white p-2 rounded-2xl border border-stone-100 shadow-sm flex flex-col gap-1">
          <button id="tab-favorites" class="btn btn-sm btn-ghost justify-start rounded-xl font-bold gap-3 text-stone-500 hover:bg-emerald-50 hover:text-emerald-700 active-tab">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.175 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.382-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
            {t.favorites}
          </button>
          <button id="tab-contributions" class="btn btn-sm btn-ghost justify-start rounded-xl font-bold gap-3 text-stone-500 hover:bg-emerald-50 hover:text-emerald-700">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
            {t.contributions}
          </button>
        </div>

        <a href={`/${lang}`} class="btn btn-ghost btn-sm w-full rounded-xl text-stone-400 font-bold gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7 7-7" /></svg>
          {t.backHome}
        </a>
      </div>

      <div class="md:col-span-2">
        <div class="bg-white p-8 rounded-3xl border border-stone-100 shadow-sm min-h-[400px]">
          <h2 id="section-title" class="text-xl font-black text-stone-800 mb-6">{t.favorites}</h2>
          
          <div id="favorites-list" class="space-y-4">
            <div class="animate-pulse space-y-4">
              <div class="h-12 bg-stone-50 rounded-2xl w-full"></div>
              <div class="h-12 bg-stone-50 rounded-2xl w-full"></div>
            </div>
          </div>

          <div id="contributions-list" class="space-y-4 hidden">
            <div class="animate-pulse space-y-4">
              <div class="h-12 bg-stone-50 rounded-2xl w-full"></div>
              <div class="h-12 bg-stone-50 rounded-2xl w-full"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="loading-profile" class="flex flex-col items-center justify-center py-20 gap-4">
    <span class="loading loading-ring loading-lg text-primary"></span>
  </div>
</Layout>

<script>
  import { supabase } from '../../lib/supabase/client';
  import { toggleFavorite } from '../../lib/favorites-client';

  async function loadProfile() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      const lang = document.documentElement.lang || 'fr';
      window.location.href = `/${lang}/login?redirect=${encodeURIComponent(window.location.pathname)}`;
      return;
    }

    const { data: profile } = await supabase
      .from('profiles')
      .select('*')
      .eq('id', session.user.id)
      .single();

    const { data: suggestions } = await supabase
      .from('suggestions')
      .select('*')
      .eq('submitted_by', session.user.id)
      .order('created_at', { ascending: false });

    const { data: favoriteRelations } = await supabase
      .from('favorites')
      .select('resource_id, resources(*)')
      .eq('user_id', session.user.id)
      .order('created_at', { ascending: false });

    // UI Update
    const name = profile?.full_name || session.user.email?.split('@')[0] || 'User';
    document.getElementById('p-name')!.innerText = name;
    document.getElementById('p-email')!.innerText = session.user.email;
    document.getElementById('p-initials')!.innerText = name.split(' ').map((n: any) => n[0]).join('').substring(0, 2).toUpperCase();
    
    const roleEl = document.getElementById('p-role')!;
    const lang = document.documentElement.lang || 'fr';
    roleEl.innerText = profile?.role === 'admin' 
      ? (lang === 'fr' ? 'Administrateur' : 'Administrator')
      : (lang === 'fr' ? 'Utilisateur' : 'User');

    // Contributions List
    const contribList = document.getElementById('contributions-list')!;
    if (!suggestions || suggestions.length === 0) {
      contribList.innerHTML = `<p class="text-stone-400 italic text-sm text-center py-10">${lang === 'fr' ? "Aucune proposition pour le moment." : "No suggestions yet."}</p>`;
    } else {
      contribList.innerHTML = suggestions.map(s => `
        <div class="flex items-center justify-between p-4 bg-stone-50 rounded-2xl border border-stone-100 hover:border-emerald-100 transition-colors">
          <div>
            <p class="font-bold text-stone-800">${s.title}</p>
            <p class="text-[10px] font-bold text-stone-400 uppercase tracking-widest">${s.category}</p>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-[10px] font-black uppercase px-2 py-1 rounded-lg ${
              s.status === 'approved' ? 'bg-emerald-100 text-emerald-700' : 
              s.status === 'rejected' ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700'
            }">${s.status}</span>
          </div>
        </div>
      `).join('');
    }

    // Favorites List
    const favList = document.getElementById('favorites-list')!;
    if (!favoriteRelations || favoriteRelations.length === 0) {
      favList.innerHTML = `<p class="text-stone-400 italic text-sm text-center py-10">${lang === 'fr' ? "Aucun favori pour le moment." : "No favorites yet."}</p>`;
    } else {
      favList.innerHTML = favoriteRelations.map((f: any) => `
        <div class="favorite-item flex items-center justify-between p-4 bg-stone-50 rounded-2xl border border-stone-100 hover:border-amber-100 transition-colors" data-id="${f.resource_id}">
          <a href="/${lang}/resource/${f.resource_id}" class="flex-grow">
            <p class="font-bold text-stone-800">${f.resources.title}</p>
            <p class="text-[10px] font-bold text-stone-400 uppercase tracking-widest">${f.resources.category}</p>
          </a>
          <button class="btn-unfavorite btn btn-ghost btn-circle btn-sm text-amber-400 hover:bg-amber-50" data-id="${f.resource_id}">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 fill-current" viewBox="0 0 24 24"><path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.175 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.382-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
          </button>
        </div>
      `).join('');

      favList.querySelectorAll('.btn-unfavorite').forEach(btn => {
        (btn as HTMLElement).onclick = async (e) => {
          e.preventDefault();
          const id = (btn as HTMLElement).dataset.id!;
          await toggleFavorite(id);
          favList.querySelector(`.favorite-item[data-id="${id}"]`)?.remove();
          if (favList.children.length === 0) {
            favList.innerHTML = `<p class="text-stone-400 italic text-sm text-center py-10">${lang === 'fr' ? "Aucun favori pour le moment." : "No favorites yet."}</p>`;
          }
        };
      });
    }

    // Tabs logic
    const tabFav = document.getElementById('tab-favorites')!;
    const tabContrib = document.getElementById('tab-contributions')!;
    const sectionTitle = document.getElementById('section-title')!;
    const translations = {
      fr: { favorites: "Mes Favoris", contributions: "Mes contributions" },
      en: { favorites: "My Favorites", contributions: "My contributions" }
    };
    const t = lang === 'en' ? translations.en : translations.fr;

    tabFav.onclick = () => {
      tabFav.classList.add('bg-emerald-50', 'text-emerald-700');
      tabContrib.classList.remove('bg-emerald-50', 'text-emerald-700');
      favList.classList.remove('hidden');
      contribList.classList.add('hidden');
      sectionTitle.innerText = t.favorites;
    };

    tabContrib.onclick = () => {
      tabContrib.classList.add('bg-emerald-50', 'text-emerald-700');
      tabFav.classList.remove('bg-emerald-50', 'text-emerald-700');
      contribList.classList.remove('hidden');
      favList.classList.add('hidden');
      sectionTitle.innerText = t.contributions;
    };

    document.getElementById('loading-profile')?.classList.add('hidden');
    document.getElementById('profile-content')?.classList.remove('hidden');
  }

  loadProfile();
</script>
