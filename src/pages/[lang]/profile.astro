---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { supabase } from '../../lib/supabase/client';

const { lang } = Astro.params;

const translations = {
  fr: {
    title: "Mon Profil",
    info: "Informations personnelles",
    name: "Nom complet",
    email: "Adresse Email",
    role: "Rôle",
    roleAdmin: "Administrateur",
    roleUser: "Utilisateur",
    contributions: "Mes contributions",
    noContributions: "Vous n'avez pas encore proposé de ressources.",
    favorites: "Mes Favoris",
    noFavorites: "Vous n'avez pas encore de favoris.",
    settings: "Paramètres du compte",
    changeName: "Changer de nom",
    newName: "Nouveau nom complet",
    changeEmail: "Changer d'email",
    newEmail: "Nouvelle adresse email",
    changePassword: "Changer de mot de passe",
    newPassword: "Nouveau mot de passe",
    updateBtn: "Mettre à jour",
    deleteAccount: "Supprimer mon compte",
    deleteWarning: "Cette action est irréversible et supprimera toutes vos données personnelles.",
    statusPending: "En attente",
    statusApproved: "Approuvé",
    statusRejected: "Refusé",
    confirmCancel: "Annuler cette proposition ?",
    back: "Retour à l'index"
  },
  en: {
    title: "My Profile",
    info: "Personal Information",
    name: "Full Name",
    email: "Email Address",
    role: "Role",
    roleAdmin: "Administrator",
    roleUser: "User",
    contributions: "My contributions",
    noContributions: "You haven't suggested any resources yet.",
    favorites: "My Favorites",
    noFavorites: "You haven't favorited any resources yet.",
    settings: "Account Settings",
    changeName: "Change Name",
    newName: "New full name",
    changeEmail: "Change Email",
    newEmail: "New email address",
    changePassword: "Change Password",
    newPassword: "New password",
    updateBtn: "Update",
    deleteAccount: "Delete my account",
    deleteWarning: "This action is irreversible and will delete all your personal data.",
    statusPending: "Pending",
    statusApproved: "Approved",
    statusRejected: "Rejected",
    confirmCancel: "Cancel this suggestion?",
    back: "Back to index"
  }
};

const t = translations[lang as keyof typeof translations] || translations.fr;
---

<Layout title={t.title} lang={lang as string}>
  <div id="profile-content" class="max-w-4xl mx-auto py-8 hidden">
    <div class="mb-8">
      <a href={`/${lang}`} class="back-link group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7" /></svg>
        {t.back}
      </a>
    </div>

    <div class="flex items-center gap-6 mb-12">
      <div class="w-20 h-20 rounded-3xl bg-emerald-100 flex items-center justify-center text-emerald-700 font-black text-3xl uppercase shadow-inner border border-emerald-50">
        <span id="p-initials"></span>
      </div>
      <div>
        <h1 id="p-name" class="text-4xl font-black text-stone-800"></h1>
        <p id="p-email" class="text-stone-400 font-medium"></p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="md:col-span-1 space-y-6">
        <div class="bg-white p-6 rounded-3xl border border-stone-100 shadow-sm">
          <h2 class="text-xs font-black uppercase tracking-widest text-stone-400 mb-4">{t.info}</h2>
          <div class="space-y-4">
            <div>
              <p class="text-[10px] font-bold text-stone-300 uppercase tracking-tighter">{t.role}</p>
              <p id="p-role" class="font-bold text-stone-600"></p>
            </div>
          </div>
        </div>

        <div class="bg-white p-2 rounded-2xl border border-stone-100 shadow-sm flex flex-col gap-1">
          <button id="tab-favorites" class="btn btn-sm btn-ghost justify-start rounded-xl font-bold gap-3 text-stone-500 hover:bg-emerald-50 hover:text-emerald-700 active-tab">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.175 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.382-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
            {t.favorites}
          </button>
          <button id="tab-contributions" class="btn btn-sm btn-ghost justify-start rounded-xl font-bold gap-3 text-stone-500 hover:bg-emerald-50 hover:text-emerald-700">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
            {t.contributions}
          </button>
          <button id="tab-settings" class="btn btn-sm btn-ghost justify-start rounded-xl font-bold gap-3 text-stone-500 hover:bg-emerald-50 hover:text-emerald-700">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            {t.settings}
          </button>
        </div>
      </div>

      <div class="md:col-span-2">
        <div class="bg-white p-8 rounded-3xl border border-stone-100 shadow-sm min-h-[400px]">
          <h2 id="section-title" class="text-xl font-black text-stone-800 mb-6">{t.favorites}</h2>
          
          <div id="favorites-list" class="space-y-4">
            <div class="animate-pulse space-y-4">
              <div class="h-12 bg-stone-50 rounded-2xl w-full"></div>
              <div class="h-12 bg-stone-50 rounded-2xl w-full"></div>
            </div>
          </div>

          <div id="contributions-list" class="space-y-4 hidden"></div>

          <div id="settings-list" class="space-y-8 hidden">
            <!-- Name -->
            <div id="name-section" class="p-6 bg-stone-50 rounded-2xl border border-stone-100">
              <h3 id="name-section-title" class="font-bold text-stone-800 mb-4">{t.changeName}</h3>
              <form id="name-form" class="flex flex-col gap-3">
                <input type="text" id="new-name" required placeholder={t.newName} class="input input-bordered rounded-xl bg-white focus:border-primary focus:ring-2 focus:ring-primary/20" />
                <button type="submit" id="btn-name" class="btn btn-primary rounded-xl font-bold w-max">{t.updateBtn}</button>
                <p id="msg-name" class="text-xs font-bold hidden mt-2"></p>
              </form>
            </div>

            <!-- Email -->
            <div class="p-6 bg-stone-50 rounded-2xl border border-stone-100">
              <h3 class="font-bold text-stone-800 mb-4">{t.changeEmail}</h3>
              <form id="email-form" class="flex flex-col gap-3">
                <input type="email" id="new-email" required placeholder={t.newEmail} class="input input-bordered rounded-xl bg-white focus:border-primary focus:ring-2 focus:ring-primary/20" />
                <button type="submit" id="btn-email" class="btn btn-primary rounded-xl font-bold w-max">{t.updateBtn}</button>
                <p id="msg-email" class="text-xs font-bold hidden mt-2"></p>
              </form>
            </div>
            
            <!-- Password -->
            <div class="p-6 bg-stone-50 rounded-2xl border border-stone-100">
              <h3 class="font-bold text-stone-800 mb-4">{t.changePassword}</h3>
              <form id="password-form" class="flex flex-col gap-3">
                <input type="password" id="new-password" required minlength="6" placeholder={t.newPassword} class="input input-bordered rounded-xl bg-white focus:border-primary focus:ring-2 focus:ring-primary/20" />
                <button type="submit" id="btn-password" class="btn btn-primary rounded-xl font-bold w-max">{t.updateBtn}</button>
                <p id="msg-password" class="text-xs font-bold hidden mt-2"></p>
              </form>
            </div>

            <!-- Delete Account -->
            <div class="p-6 bg-red-50 rounded-2xl border border-red-100">
              <h3 class="font-bold text-red-800 mb-2">{t.deleteAccount}</h3>
              <p class="text-sm text-red-600 mb-4">{t.deleteWarning}</p>
              <button id="btn-delete-account" class="btn btn-error rounded-xl font-bold text-white hover:bg-red-600 border-none">{t.deleteAccount}</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="loading-profile" class="flex flex-col items-center justify-center py-20 gap-4">
    <span class="loading loading-ring loading-lg text-primary"></span>
  </div>
</Layout>

<script>
  import { supabase } from '../../lib/supabase/client';
  import { toggleFavorite } from '../../lib/favorites-client';
  import { renderResourcePreview } from '../../lib/preview-utils';
  import { CATEGORIES } from '../../utils/categories';

  function attachContributionEvents() {
    const lang = document.documentElement.lang || 'fr';
    const confirmCancelMsg = lang === 'fr' ? "Annuler cette proposition ?" : "Cancel this suggestion?";

    document.querySelectorAll('.cancel-btn').forEach(btn => {
      (btn as HTMLElement).onclick = async (e) => {
        e.preventDefault();
        if (confirm(confirmCancelMsg)) {
          const id = (btn as HTMLElement).dataset.id!;
          (btn as HTMLElement).classList.add('loading');
          const { error } = await supabase.from('suggestions').delete().eq('id', id);
          if (error) {
            alert(error.message);
            (btn as HTMLElement).classList.remove('loading');
          } else {
            // Remove the card immediately
            (btn.closest('.suggestion-card') as HTMLElement)?.remove();
            if (document.querySelectorAll('.suggestion-card').length === 0) {
              const contribList = document.getElementById('contributions-list')!;
              contribList.innerHTML = `<p class="text-stone-400 italic text-sm text-center py-10">${lang === 'fr' ? "Aucune proposition pour le moment." : "No suggestions yet."}</p>`;
            }
          }
        }
      };
    });
  }

  async function loadProfile() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      const lang = document.documentElement.lang || 'fr';
      window.location.href = `/${lang}/login?redirect=${encodeURIComponent(window.location.pathname)}`;
      return;
    }

    const { data: profile } = await supabase
      .from('profiles')
      .select('*')
      .eq('id', session.user.id)
      .single();

    const { data: suggestions } = await supabase
      .from('suggestions')
      .select('*')
      .eq('submitted_by', session.user.id)
      .order('created_at', { ascending: false });

    const { data: favoriteRelations } = await supabase
      .from('favorites')
      .select('resource_id, resources(*)')
      .eq('user_id', session.user.id)
      .order('created_at', { ascending: false });

    // UI Update
    const name = profile?.full_name || session.user.email?.split('@')[0] || 'User';
    document.getElementById('p-name')!.innerText = name;
    document.getElementById('p-email')!.innerText = session.user.email;
    document.getElementById('p-initials')!.innerText = name.split(' ').map((n: any) => n[0]).join('').substring(0, 2).toUpperCase();
    
    const nameInput = document.getElementById('new-name') as HTMLInputElement;
    if (nameInput) {
      nameInput.value = profile?.full_name || '';
    }

    if (!profile?.full_name) {
      const nameSection = document.getElementById('name-section');
      if (nameSection) {
        nameSection.classList.remove('bg-stone-50', 'border-stone-100');
        nameSection.classList.add('bg-red-50', 'border-red-100');
      }
      const nameSectionTitle = document.getElementById('name-section-title');
      if (nameSectionTitle) {
        nameSectionTitle.classList.remove('text-stone-800');
        nameSectionTitle.classList.add('text-red-800');
      }
      const tabSettings = document.getElementById('tab-settings');
      if (tabSettings) {
        tabSettings.classList.remove('text-stone-500');
        tabSettings.classList.add('text-red-500');
      }
    }
    
    const roleEl = document.getElementById('p-role')!;
    const lang = document.documentElement.lang || 'fr';
    roleEl.innerText = profile?.role === 'admin' 
      ? (lang === 'fr' ? 'Administrateur' : 'Administrator')
      : (lang === 'fr' ? 'Utilisateur' : 'User');

    // Contributions List
    const contribList = document.getElementById('contributions-list')!;
    if (!suggestions || suggestions.length === 0) {
      contribList.innerHTML = `<p class="text-stone-400 italic text-sm text-center py-10">${lang === 'fr' ? "Aucune proposition pour le moment." : "No suggestions yet."}</p>`;
    } else {
      const { data: resources } = await supabase.from('resources').select('*');
      
      contribList.innerHTML = suggestions.map(s => {
        if (s.status === 'pending') {
          const original = s.resource_id ? (resources || []).find(r => r.id === s.resource_id) : null;
          return renderResourcePreview(s, {
            lang: lang as 'fr' | 'en',
            isOwner: true,
            diffWith: original,
            allResources: resources || [],
            categoriesData: CATEGORIES
          });
        }
        
        return `
          <div class="flex items-center justify-between p-4 bg-stone-50 rounded-2xl border border-stone-100 hover:border-emerald-100 transition-colors">
            <div>
              <p class="font-bold text-stone-800">${s.title}</p>
              <p class="text-[10px] font-black uppercase text-stone-400 tracking-widest border border-stone-200 bg-white px-1.5 py-0.5 rounded mt-1 inline-block">${s.category}</p>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-[10px] font-black uppercase px-2 py-1 rounded border ${
                s.status === 'approved' ? 'bg-emerald-50 text-emerald-800 border-emerald-200' : 
                s.status === 'rejected' ? 'bg-red-50 text-red-800 border-red-200' : 'bg-amber-50 text-amber-800 border-amber-200'
              }">${lang === 'fr' ? (s.status === 'approved' ? 'Approuvé' : 'Refusé') : s.status}</span>
            </div>
          </div>
        `;
      }).join('');
      attachContributionEvents();
    }

    // Favorites List
    const favList = document.getElementById('favorites-list')!;
    if (!favoriteRelations || favoriteRelations.length === 0) {
      favList.innerHTML = `<p class="text-stone-400 italic text-sm text-center py-10">${lang === 'fr' ? "Aucun favori pour le moment." : "No favorites yet."}</p>`;
    } else {
      favList.innerHTML = favoriteRelations.map((f: any) => `
        <div class="favorite-item flex items-center justify-between p-4 bg-stone-50 rounded-2xl border border-stone-100 hover:border-amber-100 transition-colors" data-id="${f.resource_id}">
          <a href="/${lang}/resource/${f.resource_id}" class="flex-grow">
            <p class="font-bold text-stone-800">${f.resources.title}</p>
            <p class="text-[10px] font-black uppercase text-stone-400 tracking-widest border border-stone-200 bg-white px-1.5 py-0.5 rounded mt-1 inline-block">${f.resources.category}</p>
          </a>
          <button class="btn-unfavorite btn btn-ghost btn-circle btn-sm text-amber-500 hover:bg-amber-50" data-id="${f.resource_id}">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 fill-current" viewBox="0 0 24 24"><path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.175 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.382-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" /></svg>
          </button>
        </div>
      `).join('');

      favList.querySelectorAll('.btn-unfavorite').forEach(btn => {
        (btn as HTMLElement).onclick = async (e) => {
          e.preventDefault();
          const id = (btn as HTMLElement).dataset.id!;
          await toggleFavorite(id);
          favList.querySelector(`.favorite-item[data-id="${id}"]`)?.remove();
          if (favList.children.length === 0) {
            favList.innerHTML = `<p class="text-stone-400 italic text-sm text-center py-10">${lang === 'fr' ? "Aucun favori pour le moment." : "No favorites yet."}</p>`;
          }
        };
      });
    }

    // Tabs logic
    const tabFav = document.getElementById('tab-favorites')!;
    const tabContrib = document.getElementById('tab-contributions')!;
    const tabSettings = document.getElementById('tab-settings')!;
    const settingsList = document.getElementById('settings-list')!;
    const sectionTitle = document.getElementById('section-title')!;
    const translations = {
      fr: { favorites: "Mes Favoris", contributions: "Mes contributions", settings: "Paramètres du compte" },
      en: { favorites: "My Favorites", contributions: "My contributions", settings: "Account Settings" }
    };
    const t = lang === 'en' ? translations.en : translations.fr;

    function resetTabs() {
      [tabFav, tabContrib, tabSettings].forEach(t => t.classList.remove('bg-stone-100', 'text-stone-800'));
      [favList, contribList, settingsList].forEach(l => l.classList.add('hidden'));
    }

    tabFav.onclick = () => {
      resetTabs();
      tabFav.classList.add('bg-stone-100', 'text-stone-800');
      favList.classList.remove('hidden');
      sectionTitle.innerText = t.favorites;
    };

    tabContrib.onclick = () => {
      resetTabs();
      tabContrib.classList.add('bg-stone-100', 'text-stone-800');
      contribList.classList.remove('hidden');
      sectionTitle.innerText = t.contributions;
    };

    tabSettings.onclick = () => {
      resetTabs();
      tabSettings.classList.add('bg-stone-100', 'text-stone-800');
      settingsList.classList.remove('hidden');
      sectionTitle.innerText = t.settings;
    };

    // Auto-select tab if in URL
    const urlParams = new URLSearchParams(window.location.search);
    if (urlParams.get('tab') === 'settings') {
      tabSettings.click();
    }

    // Account Settings Forms
    const nameForm = document.getElementById('name-form') as HTMLFormElement;
    const btnName = document.getElementById('btn-name') as HTMLButtonElement;
    const msgName = document.getElementById('msg-name')!;

    if (nameForm) {
      nameForm.onsubmit = async (e) => {
        e.preventDefault();
        const newName = (document.getElementById('new-name') as HTMLInputElement).value;
        btnName.classList.add('loading');
        msgName.classList.add('hidden');
        
        const { error } = await supabase.from('profiles').update({ full_name: newName }).eq('id', session.user.id);
        
        btnName.classList.remove('loading');
        msgName.classList.remove('hidden');
        if (error) {
          msgName.innerText = error.message;
          msgName.className = 'text-xs font-bold mt-2 text-red-500';
        } else {
          msgName.innerText = lang === 'fr' ? 'Nom mis à jour avec succès.' : 'Name updated successfully.';
          msgName.className = 'text-xs font-bold mt-2 text-emerald-600';
          
          // Update UI
          const displayStr = newName || session.user.email?.split('@')[0] || 'User';
          document.getElementById('p-name')!.innerText = displayStr;
          document.getElementById('p-initials')!.innerText = displayStr.split(' ').map((n: any) => n[0]).join('').substring(0, 2).toUpperCase();

          // Remove highlighting if name was previously missing
          if (newName) {
            const nameSection = document.getElementById('name-section');
            if (nameSection) {
              nameSection.classList.remove('bg-red-50', 'border-red-100');
              nameSection.classList.add('bg-stone-50', 'border-stone-100');
            }
            const nameSectionTitle = document.getElementById('name-section-title');
            if (nameSectionTitle) {
              nameSectionTitle.classList.remove('text-red-800');
              nameSectionTitle.classList.add('text-stone-800');
            }
            const tabSettings = document.getElementById('tab-settings');
            if (tabSettings) {
              tabSettings.classList.remove('text-red-500');
              tabSettings.classList.add('text-stone-500');
            }
            
            // Also notify the header if it was visible
            const warningBadge = document.getElementById('profile-warning-badge');
            const warningItem = document.getElementById('profile-warning-item');
            if (warningBadge) warningBadge.classList.add('hidden');
            if (warningItem) warningItem.classList.add('hidden');
          }
        }
      };
    }

    const emailForm = document.getElementById('email-form') as HTMLFormElement;
    const btnEmail = document.getElementById('btn-email') as HTMLButtonElement;
    const msgEmail = document.getElementById('msg-email')!;

    emailForm.onsubmit = async (e) => {
      e.preventDefault();
      const newEmail = (document.getElementById('new-email') as HTMLInputElement).value;
      btnEmail.classList.add('loading');
      msgEmail.classList.add('hidden');
      
      const { error } = await supabase.auth.updateUser({ email: newEmail });
      
      btnEmail.classList.remove('loading');
      msgEmail.classList.remove('hidden');
      if (error) {
        msgEmail.innerText = error.message;
        msgEmail.className = 'text-xs font-bold mt-2 text-red-500';
      } else {
        msgEmail.innerText = lang === 'fr' ? 'Veuillez vérifier vos boîtes mail (ancienne et nouvelle) pour confirmer le changement.' : 'Please check both your old and new email inboxes to confirm the change.';
        msgEmail.className = 'text-xs font-bold mt-2 text-emerald-600';
        emailForm.reset();
      }
    };

    const passwordForm = document.getElementById('password-form') as HTMLFormElement;
    const btnPassword = document.getElementById('btn-password') as HTMLButtonElement;
    const msgPassword = document.getElementById('msg-password')!;

    passwordForm.onsubmit = async (e) => {
      e.preventDefault();
      const newPassword = (document.getElementById('new-password') as HTMLInputElement).value;
      btnPassword.classList.add('loading');
      msgPassword.classList.add('hidden');
      
      const { error } = await supabase.auth.updateUser({ password: newPassword });
      
      btnPassword.classList.remove('loading');
      msgPassword.classList.remove('hidden');
      if (error) {
        msgPassword.innerText = error.message;
        msgPassword.className = 'text-xs font-bold mt-2 text-red-500';
      } else {
        msgPassword.innerText = lang === 'fr' ? 'Mot de passe mis à jour avec succès.' : 'Password updated successfully.';
        msgPassword.className = 'text-xs font-bold mt-2 text-emerald-600';
        passwordForm.reset();
      }
    };

    const btnDelete = document.getElementById('btn-delete-account') as HTMLButtonElement;
    btnDelete.onclick = async () => {
      const confirmMsg = lang === 'fr' ? 'Êtes-vous sûr de vouloir supprimer définitivement votre compte ?' : 'Are you sure you want to permanently delete your account?';
      if (confirm(confirmMsg)) {
        btnDelete.classList.add('loading');
        const { error } = await supabase.rpc('delete_own_account');
        if (error) {
          alert(error.message);
          btnDelete.classList.remove('loading');
        } else {
          await supabase.auth.signOut();
          window.location.href = `/${lang}`;
        }
      }
    };

    document.getElementById('loading-profile')?.classList.add('hidden');
    document.getElementById('profile-content')?.classList.remove('hidden');
  }

  loadProfile();
</script>
