---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import ResourceIcons from "../../components/ResourceIcons.astro";
import InteractiveMap from "../../components/InteractiveMap.astro";
import { fetchAllResources } from "../../lib/services";

const { lang } = Astro.params;
const allResources = await fetchAllResources();

const translations = {
  fr: {
    title: "Carte de l'index",
    desc: "Découvrez géographiquement les acteurs et événements du numérique responsable.",
    back: "Retour à l'index",
  },
  en: {
    title: "Index Map",
    desc: "Geographically discover sustainable digital actors and events.",
    back: "Back to index",
  }
};

const t = translations[lang as 'fr' | 'en'] || translations.fr;
---

<Layout title={t.title} lang={lang as string}>
  <ResourceIcons />

  <section class="max-w-7xl mx-auto px-4">
    <div class="mb-8 pt-8">
      <a href={`/${lang}`} class="inline-flex items-center gap-2 text-stone-400 hover:text-emerald-700 transition-colors text-sm font-bold group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7" /></svg>
        {t.back}
      </a>
    </div>

    <header class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <h1 class="text-3xl font-black text-stone-800 mb-2">{t.title}</h1>
        <p class="text-stone-500 italic text-sm">{t.desc}</p>
      </div>
    </header>

    <div class="mb-12">
      <InteractiveMap resources={allResources} lang={lang as 'fr' | 'en'} autoActivate={true} />
    </div>
  </section>
</Layout>
