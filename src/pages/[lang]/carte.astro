---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import ResourceIcons from "../../components/ResourceIcons.astro";
import InteractiveMap from "../../components/InteractiveMap.astro";
import { fetchAllResources } from "../../lib/services";
import { CATEGORIES } from "../../utils/categories";

const { lang } = Astro.params;
const allResources = await fetchAllResources();

const taxonomy = Object.fromEntries(
  Object.entries(CATEGORIES).map(([k, v]) => [k, v.mandatoryTags])
);

const translations = {
  fr: {
    title: "Carte des acteurs et événements",
    desc: "Découvrez géographiquement les acteurs et événements du numérique responsable.",
    back: "Retour à l'index",
  },
  en: {
    title: "Actors and Events Map",
    desc: "Geographically discover sustainable digital actors and events.",
    back: "Back to index",
  }
};

const t = translations[lang as 'fr' | 'en'] || translations.fr;
---

<Layout title={t.title} lang={lang as string}>
  <ResourceIcons />

  <section class="max-w-7xl mx-auto px-4">
    <div class="mb-8 pt-8">
      <a href={`/${lang}`} class="inline-flex items-center gap-2 text-stone-500 hover:text-primary transition-colors text-sm font-black group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        {t.back}
      </a>
    </div>

    <header class="mb-4 flex flex-col md:flex-row md:items-center justify-between gap-6 pb-2">
      <div>
        <h1 class="text-3xl font-black text-stone-800 mb-1 leading-tight tracking-tighter">{t.title}</h1>
        <p class="text-stone-500 italic text-sm font-medium">{t.desc}</p>
      </div>
    </header>

    <div id="category-filters-container" class="mb-6 flex items-center border-b border-stone-100 overflow-x-auto no-scrollbar gap-1 md:gap-2 px-1"></div>
    <div id="sub-filters-container" class="mb-6 px-1 py-2 flex items-center gap-2 overflow-x-auto no-scrollbar whitespace-nowrap min-h-[44px]"></div>

    <div class="mb-12">
      <div id="map-wrapper">
        <InteractiveMap resources={allResources} lang={lang as 'fr' | 'en'} autoActivate={true} />
      </div>
    </div>
  </section>

  <script id="taxonomy-data" type="application/json" is:inline set:html={JSON.stringify(taxonomy)} />
  <script id="resource-data" type="application/json" is:inline set:html={JSON.stringify(allResources)} />
</Layout>

<script>
  const taxonomy = JSON.parse(document.getElementById('taxonomy-data')?.textContent || '{}');
  const allResources = JSON.parse(document.getElementById('resource-data')?.textContent || '[]');
  const categoryContainer = document.getElementById('category-filters-container');
  const subContainer = document.getElementById('sub-filters-container');
  
  let currentCategory = 'all';
  let currentSubCat: string | null = null;

  function renderCategoryFilters() {
    if (!categoryContainer) return;
    const lang = document.documentElement.lang || 'fr';
    
    const cats = [
      { id: 'all', fr: 'Tout', en: 'All' },
      { id: 'acteur', fr: 'Acteurs', en: 'Actors' },
      { id: 'evenement', fr: 'Événements', en: 'Events' }
    ];
    
    let html = '';
    cats.forEach(c => {
      const label = lang === 'en' ? c.en : c.fr;
      const activeClass = currentCategory === c.id ? 'text-primary border-primary bg-emerald-50/30' : 'text-stone-400 border-transparent hover:text-stone-600 hover:bg-stone-50/50';
      html += `
        <button class="px-4 py-2 text-[11px] font-black uppercase tracking-widest transition-all border-b-2 whitespace-nowrap ${activeClass}" data-cat="${c.id}">
          ${label}
        </button>
      `;
    });
    categoryContainer.innerHTML = html;

    categoryContainer.querySelectorAll('button').forEach(btn => {
      btn.onclick = () => {
        currentCategory = btn.getAttribute('data-cat') || 'all';
        currentSubCat = null;
        renderCategoryFilters();
        renderSubFilters();
        updateMap();
      };
    });
  }

  function renderSubFilters() {
    if (!subContainer) return;
    const lang = document.documentElement.lang || 'fr';
    
    if (currentCategory === 'all') {
      subContainer.innerHTML = `<span class="text-[10px] text-stone-300 italic px-2">${lang === 'en' ? 'Select a category to filter by type' : 'Sélectionnez une catégorie pour filtrer par type'}</span>`;
      return;
    }

    const subCats = taxonomy[currentCategory] || [];
    const filterAll = lang === 'en' ? 'All types' : 'Tous types';
    
    let html = `<button class="pill-chip ${!currentSubCat ? 'active' : ''}" data-sub="all">${filterAll}</button>`;
    subCats.forEach((s: string) => {
      html += `<button class="pill-chip ${currentSubCat === s ? 'active' : ''}" data-sub="${s}">${s}</button>`;
    });
    subContainer.innerHTML = html;

    subContainer.querySelectorAll('.pill-chip').forEach(btn => {
      (btn as HTMLElement).onclick = () => {
        const sub = btn.getAttribute('data-sub');
        currentSubCat = sub === 'all' ? null : sub;
        updateMap();
        renderSubFilters();
      };
    });
  }

  async function updateMap() {
    const filtered = allResources.filter((r: any) => {
      const matchCat = currentCategory === 'all' || r.category === currentCategory;
      const matchSub = !currentSubCat || r.tags?.includes(currentSubCat);
      return matchCat && matchSub && (r.category === 'acteur' || r.category === 'evenement');
    });

    if ((window as any).L && (window as any).mapInstance) {
      const map = (window as any).mapInstance;
      const markers = (window as any).markerGroup;
      if (markers) {
        markers.clearLayers();
        const customIcon = (window as any).L.divIcon({
          className: 'numindex-marker',
          html: `<div class="w-8 h-8 bg-primary rounded-full flex items-center justify-center text-white border-2 border-white shadow-lg">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  </svg>
                </div>`,
          iconSize: [32, 32],
          iconAnchor: [16, 32],
          popupAnchor: [0, -32]
        });

        const lang = document.documentElement.lang || 'fr';

        filtered.forEach((item: any) => {
          if (item.metadata?.lat && item.metadata?.lng) {
            const categoryLabel = item.category === 'acteur' ? (lang === 'fr' ? 'Acteur' : 'Actor') : (lang === 'fr' ? 'Événement' : 'Event');
            const popupContent = `
              <div class="p-2">
                <span class="text-[10px] font-black uppercase text-primary mb-1 block tracking-wider">${categoryLabel}</span>
                <h4 class="font-black text-stone-800 mb-2 leading-tight">${item.title}</h4>
                <a href="/${lang}/resource/${item.id}" class="btn btn-xs btn-primary rounded-lg no-underline text-white font-bold w-full">Détails</a>
              </div>
            `;
            (window as any).L.marker([item.metadata.lat, item.metadata.lng], { icon: customIcon })
              .bindPopup(popupContent)
              .addTo(markers);
          }
        });
        
        if (filtered.length > 0) {
          map.fitBounds(markers.getBounds(), { padding: [50, 50] });
        }
      }
    }
  }

  // Initialisation
  renderCategoryFilters();
  renderSubFilters();
</script>

<style is:global>
  /* Les styles .pill-chip sont déjà dans Layout.astro */
</style>
