---
export const prerender = false;

import Layout from "../../layouts/Layout.astro";
import ResourceIcons from "../../components/ResourceIcons.astro";
import InteractiveMap from "../../components/InteractiveMap.astro";
import { fetchAllResources } from "../../lib/services";

const { lang } = Astro.params;
const allResources = await fetchAllResources();

const translations = {
  fr: {
    title: "Carte de l'index",
    desc: "Découvrez géographiquement les acteurs et événements du numérique responsable.",
    back: "Retour à la liste",
  },
  en: {
    title: "Index Map",
    desc: "Geographically discover sustainable digital actors and events.",
    back: "Back to list",
  }
};

const t = translations[lang as 'fr' | 'en'] || translations.fr;
---

<Layout title={t.title} lang={lang as string}>
  <ResourceIcons />

  <section class="max-w-7xl mx-auto px-4">
    <header class="mb-10 pt-8 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div>
        <h1 class="text-3xl font-black text-stone-800 mb-2">{t.title}</h1>
        <p class="text-stone-500 italic text-sm">{t.desc}</p>
      </div>
      
      <a href={`/${lang}`} class="btn btn-ghost btn-sm rounded-xl text-stone-400 font-bold gap-2 hover:text-primary transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
        </svg>
        {t.back}
      </a>
    </header>

    <div class="mb-12">
      <InteractiveMap resources={allResources} lang={lang as 'fr' | 'en'} autoActivate={true} />
    </div>
  </section>
</Layout>
