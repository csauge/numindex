---
import Layout from '../../layouts/Layout.astro';
import SuggestionForm from '../../components/SuggestionForm.astro';
import { supabase } from '../../lib/supabase/client';

export async function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params as { lang: 'fr' | 'en' };
const id = Astro.url.searchParams.get('id');
const actionParam = Astro.url.searchParams.get('action');

const action = (actionParam === 'update' || actionParam === 'delete') ? actionParam : 'create';

// Si on modifie ou supprime, on récupère les données actuelles
let initialData = null;
if (id && supabase) {
  const { data } = await supabase
    .from('resources')
    .select('*')
    .eq('id', id)
    .single();
  initialData = data;
}

const t = {
  fr: {
    title: action === 'delete' ? "Signaler une ressource" : (action === 'update' ? "Modifier une ressource" : "Proposer une ressource"),
    back: "Retour à l'accueil"
  },
  en: {
    title: action === 'delete' ? "Report a resource" : (action === 'update' ? "Edit a resource" : "Suggest a resource"),
    back: "Back to home"
  }
}[lang];
---

<Layout title={t.title} lang={lang}>
  <div class="mb-8">
    <a href={`/${lang}`} class="text-sm font-medium text-emerald-700 hover:text-emerald-900 flex items-center gap-1 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
      {t.back}
    </a>
  </div>

  <SuggestionForm 
    lang={lang} 
    initialData={initialData} 
    resourceId={id} 
    action={action} 
  />
</Layout>
