---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import SuggestionForm from '../../components/SuggestionForm.astro';
import type { SuggestionAction } from '../../lib/supabase/types';

const { lang } = Astro.params as { lang: 'fr' | 'en' };

// Récupération des paramètres d'URL (SSR)
const action = (Astro.url.searchParams.get('action') || 'create') as SuggestionAction;
const resourceId = Astro.url.searchParams.get('id');
const suggestionId = Astro.url.searchParams.get('sid');
const isModeration = Astro.url.searchParams.get('moderation') === 'true';

const translations = {
  fr: {
    title: isModeration ? "Corriger la suggestion" : (action === 'delete' ? "Supprimer une ressource" : (action === 'update' ? "Modifier une ressource" : "Proposer une ressource")),
    back: isModeration ? "Retour à la modération" : "Retour à l'index"
  },
  en: {
    title: isModeration ? "Correct suggestion" : (action === 'delete' ? "Delete resource" : (action === 'update' ? "Update resource" : "Suggest a resource")),
    back: isModeration ? "Back to moderation" : "Back to index"
  }
};
const t = translations[lang as keyof typeof translations] || translations.fr;
---

<Layout title={t.title} lang={lang}>
  <div data-auth-only class="w-full max-w-2xl mx-auto flex-col">
    <div class="mb-8 px-1">
      <a href={isModeration ? `/${lang}/admin` : (resourceId ? `/${lang}/resource/${resourceId}` : `/${lang}`)} class="inline-flex items-center gap-2 text-stone-500 hover:text-primary transition-colors text-sm font-black group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        {t.back}
      </a>
    </div>

    <SuggestionForm lang={lang} action={action} resourceId={resourceId} suggestionId={suggestionId} isModeration={isModeration} />
  </div>
</Layout>
