---
import { getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params as { lang: 'fr' | 'en' };

// On récupère l'entrée correspondante (ex: 'fr/terms')
const entry = await getEntry('pages', `${lang}/terms`);

if (!entry) {
  return Astro.redirect(`/${lang}/404`);
}

const { Content } = await render(entry);
---

<Layout title={entry.data.title} description={entry.data.subtitle} lang={lang}>
  <main class="max-w-4xl mx-auto px-4 py-8 md:py-12 flex-1 w-full" id="main-content">
    
    <div class="mb-8 md:mb-12">
      <h1 class="text-3xl md:text-5xl font-black text-stone-900 tracking-tight mb-4 flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 md:h-10 md:w-10 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        {entry.data.title}
      </h1>
      {entry.data.subtitle && (
        <p class="text-lg md:text-xl text-stone-600 max-w-2xl font-medium">
          {entry.data.subtitle}
        </p>
      )}
    </div>

    <!-- Conteneur pour le Markdown converti -->
    <article class="prose prose-stone prose-emerald md:prose-lg max-w-none bg-white p-6 md:p-10 rounded-3xl shadow-sm border border-emerald-100">
      <Content />
    </article>
    
  </main>
</Layout>