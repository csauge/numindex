---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { ACTION_ICONS, CATEGORIES } from '../../utils/categories';

const { lang } = Astro.params as { lang: 'fr' | 'en' };

const translations = {
  fr: { 
    title: "Administration", 
    noPending: "Aucune suggestion en attente.", 
    loading: "Chargement des suggestions...",
    back: "Retour à l'index",
    diff_notice: "Champs modifiés entourés en rouge.",
    users_title: "Utilisateurs",
    users_loading: "Chargement des utilisateurs...",
    name: "Nom",
    email: "Email",
    role: "Rôle",
    joined: "Inscription",
    users_error: "Erreur lors du chargement des utilisateurs"
  },
  en: { 
    title: "Administration", 
    noPending: "No pending suggestions.", 
    loading: "Loading suggestions...",
    back: "Back to index",
    diff_notice: "Modified fields highlighted in red.",
    users_title: "Users",
    users_loading: "Loading users...",
    name: "Name",
    email: "Email",
    role: "Role",
    joined: "Joined",
    users_error: "Error loading users"
  }
};
const t = translations[lang as keyof typeof translations] || translations.fr;
---

<Layout title={t.title} lang={lang}>
  <div class="max-w-4xl mx-auto">
    <div class="mb-8 flex justify-between items-center">
      <a href={`/${lang}`} class="inline-flex items-center gap-2 text-stone-500 hover:text-primary transition-colors text-sm font-black group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg>
        {t.back}
      </a>
      <span id="diff-notice" class="hidden text-[10px] font-bold text-red-500 uppercase tracking-widest bg-red-50 px-3 py-1 rounded-full border border-red-100">
        ⚠️ {t.diff_notice}
      </span>
    </div>

    <h1 class="text-3xl font-black mb-8">{t.title}</h1>

    <div class="mb-8 bg-white border border-stone-100 p-8 rounded-3xl shadow-sm">
      <h2 class="text-xl font-black text-stone-800 mb-4">{lang === 'fr' ? 'Inviter un utilisateur' : 'Invite a user'}</h2>
      <form id="invite-form" class="flex gap-4">
        <input type="email" id="invite-email" required placeholder={lang === 'fr' ? 'Adresse email' : 'Email address'} class="input input-bordered rounded-xl flex-grow bg-stone-50 border-stone-200 focus:border-primary focus:ring-2 focus:ring-primary/20" />
        <button type="submit" id="invite-btn" class="btn btn-primary rounded-xl font-black shadow-md shadow-emerald-200">
          {lang === 'fr' ? 'Inviter' : 'Invite'}
        </button>
      </form>
      <p id="invite-message" class="mt-4 text-sm font-bold hidden"></p>
    </div>

    <div class="mb-8 bg-white border border-stone-100 p-8 rounded-3xl shadow-sm" id="users-section">
      <h2 class="text-xl font-black text-stone-800 mb-4">{t.users_title}</h2>
      
      <div id="users-loading-state" class="text-center py-8">
        <span class="loading loading-spinner loading-md text-primary mb-2"></span>
        <p class="text-stone-400 font-medium italic text-sm">{t.users_loading}</p>
      </div>
      
      <div class="overflow-x-auto">
        <table class="table table-zebra w-full text-sm hidden" id="users-table">
          <thead>
            <tr>
              <th class="font-black text-stone-500 bg-stone-50/50">{t.name}</th>
              <th class="font-black text-stone-500 bg-stone-50/50">{t.email}</th>
              <th class="font-black text-stone-500 bg-stone-50/50">{t.role}</th>
              <th class="font-black text-stone-500 bg-stone-50/50">{t.joined}</th>
            </tr>
          </thead>
          <tbody id="users-list">
            <!-- Loaded dynamically -->
          </tbody>
        </table>
      </div>
      <p id="users-error" class="hidden text-sm font-bold text-red-500 mt-4 text-center"></p>
    </div>

    <div id="loading-state" class="bg-white border border-stone-100 p-12 rounded-3xl text-center shadow-sm">
      <span class="loading loading-spinner loading-lg text-primary mb-4"></span>
      <p class="text-stone-400 font-medium italic">{t.loading}</p>
    </div>

    <div id="empty-state" class="hidden bg-stone-50 border border-stone-200 p-12 rounded-3xl text-center">
      <p class="text-stone-400 font-medium italic">{t.noPending}</p>
    </div>

    <div id="suggestions-list" class="grid gap-6" data-categories={JSON.stringify(CATEGORIES)}></div>

    <div id="access-denied" class="hidden bg-white border border-stone-50 p-12 rounded-3xl text-center shadow-xl shadow-stone-100/50 max-w-lg mx-auto mt-12">
      <div class="w-20 h-20 bg-red-50 text-red-500 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      </div>
      <h2 class="text-2xl font-black text-stone-800 mb-2">{lang === 'fr' ? 'Accès réservé' : 'Access Restricted'}</h2>
      <p class="text-stone-500 mb-8 leading-relaxed italic">{lang === 'fr' ? 'Désolé, cette page est réservée aux administrateurs de l\'index.' : 'Sorry, this page is restricted to index administrators.'}</p>
      <a href={`/${lang}`} class="btn btn-primary rounded-2xl px-12 font-black shadow-md shadow-emerald-200">{t.back}</a>
    </div>
  </div>
</Layout>

<script>
  import { supabase, getImageUrl } from '../../lib/supabase/client';
  import { getCategoryLabel, getCategoryIcon, ACTION_ICONS } from '../../utils/categories';
  import { fetchAllProfiles, isUserAdmin } from '../../lib/services';
  import { renderResourcePreview } from '../../lib/preview-utils';
  import type { Suggestion, Resource, Profile } from '../../lib/supabase/types';

  const lang = (document.documentElement.lang || 'fr') as 'fr' | 'en';
  const listContainer = document.getElementById('suggestions-list');
  const loadingState = document.getElementById('loading-state');
  const emptyState = document.getElementById('empty-state');
  const accessDenied = document.getElementById('access-denied');
  const diffNotice = document.getElementById('diff-notice');

  // Parse CATEGORIES from data attribute
  const categoriesData = JSON.parse(listContainer?.dataset.categories || '{}');

  async function loadModeration() {
    if (!supabase) {
      return;
    }

    try {

      const { data: { session }, error: sessionError } = await supabase.auth.getSession();
      
      if (sessionError) throw sessionError;
      if (!session) {
        window.location.href = `/${lang}/login?redirect=admin`;
        return;
      }

      // Check role via helper
      const isAdmin = await isUserAdmin();

      if (!isAdmin) {
        loadingState?.classList.add('hidden');
        accessDenied?.classList.remove('hidden');
        document.querySelector('h1')?.classList.add('hidden');
        return;
      }

      const { data: suggestions, error: sugError } = await supabase
        .from('suggestions')
        .select('*')
        .eq('status', 'pending')
        .order('created_at', { ascending: false });

      if (sugError) throw sugError;

      if (!suggestions || suggestions.length === 0) {
        loadingState?.classList.add('hidden');
        emptyState?.classList.remove('hidden');
        return;
      }

      const { data: resources } = await supabase.from('resources').select('*');
      const profiles = await fetchAllProfiles();

      loadingState?.classList.add('hidden');
      if (suggestions.some(s => s.action === 'update')) diffNotice?.classList.remove('hidden');

      listContainer!.innerHTML = suggestions.map(res => {
        const original = res.resource_id ? (resources || []).find(r => r.id === res.resource_id) : null;
        return renderResourcePreview(res, {
          lang,
          isModeration: true,
          diffWith: original,
          profiles,
          allResources: resources || [],
          categoriesData: categoriesData
        });
      }).join('');
      attachEvents();
    } catch (err: any) {
      if (loadingState) {
        loadingState.innerHTML = `
          <div class="text-error font-bold p-4 bg-red-50 rounded-xl border border-red-100">
            Une erreur est survenue lors du chargement :<br/>
            <span class="text-xs font-mono">${err.message || 'Erreur inconnue'}</span>
          </div>
        `;
      }
    }
  }

  function attachEvents() {
    document.querySelectorAll('.approve-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const isConfirmed = confirm('Approuver ?');
        if (!isConfirmed) return;
        
        const id = btn.getAttribute('data-id');
        const card = document.querySelector(`.suggestion-card[data-id="${id}"]`);
        
        btn.classList.add('loading');

        try {
          const { error: resError } = await supabase!.rpc('approve_suggestion', { suggestion_id: id });

          if (resError) {
            alert(`Erreur : ${resError.message}`);
            btn.classList.remove('loading');
          } else {
            // Success: remove card immediately
            if (card) {
              card.remove();
            }
            if (document.querySelectorAll('.suggestion-card').length === 0) {
              emptyState?.classList.remove('hidden');
            }
          }
        } catch (err: any) {
          btn.classList.remove('loading');
        }
      });
    });

    document.querySelectorAll('.reject-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-id');
        const card = document.querySelector(`.suggestion-card[data-id="${id}"]`);
        
        const isConfirmed = confirm('Rejeter ?');
        if (isConfirmed) {
          btn.classList.add('loading');
          try {
            const { error } = await supabase!.rpc('reject_suggestion', { suggestion_id: id });
            if (error) {
              alert(`Erreur : ${error.message}`);
              btn.classList.remove('loading');
            } else {
              // Success: remove card immediately
              if (card) {
                card.remove();
              }
              if (document.querySelectorAll('.suggestion-card').length === 0) {
                emptyState?.classList.remove('hidden');
              }
            }
          } catch (err) {
            btn.classList.remove('loading');
          }
        }
      });
    });
  }

  async function loadUsers() {
    if (!supabase) return;
    const usersLoadingState = document.getElementById('users-loading-state');
    const usersTable = document.getElementById('users-table');
    const usersListContainer = document.getElementById('users-list');
    const usersError = document.getElementById('users-error');
    
    try {
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) return;
      
      const res = await fetch('/api/users', {
        headers: {
          'Authorization': `Bearer ${session.access_token}`
        }
      });
      
      const json = await res.json();
      
      if (!res.ok) {
        throw new Error(json.error || (lang === 'fr' ? 'Erreur lors du chargement des utilisateurs' : 'Error loading users'));
      }
      
      if (usersLoadingState) usersLoadingState.classList.add('hidden');
      if (usersTable) usersTable.classList.remove('hidden');
      
      if (usersListContainer && json.users) {
        const dateFormatter = new Intl.DateTimeFormat(lang, { dateStyle: 'medium', timeStyle: 'short' });
        usersListContainer.innerHTML = json.users.map((u: any) => `
          <tr>
            <td class="font-medium">${u.full_name || '-'}</td>
            <td class="text-stone-500">${u.email || '-'}</td>
            <td>
              <span class="badge ${u.role === 'admin' ? 'badge-primary font-bold' : 'badge-ghost'} badge-sm">
                ${u.role === 'admin' ? 'Admin' : (lang === 'fr' ? 'Utilisateur' : 'User')}
              </span>
            </td>
            <td class="text-stone-500 text-xs">${u.created_at ? dateFormatter.format(new Date(u.created_at)) : '-'}</td>
          </tr>
        `).join('');
      }
      
    } catch (err: any) {
      if (usersLoadingState) usersLoadingState.classList.add('hidden');
      if (usersError) {
        usersError.innerText = err.message;
        usersError.classList.remove('hidden');
      }
    }
  }

  loadModeration();
  loadUsers();

  const inviteForm = document.getElementById('invite-form') as HTMLFormElement;
  const inviteMessage = document.getElementById('invite-message');
  const inviteBtn = document.getElementById('invite-btn');

  if (inviteForm) {
    inviteForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!inviteBtn || !inviteMessage) return;
      
      inviteBtn.classList.add('loading');
      inviteMessage.classList.add('hidden');
      
      const email = (document.getElementById('invite-email') as HTMLInputElement).value;
      const { data: { session } } = await supabase!.auth.getSession();
      
      try {
        const res = await fetch('/api/invite', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${session?.access_token}`
          },
          body: JSON.stringify({ email })
        });
        
        const json = await res.json();
        inviteMessage.classList.remove('hidden');
        
        if (!res.ok) throw new Error(json.error || 'Erreur inconnue');
        
        inviteMessage.innerText = lang === 'fr' ? 'Invitation envoyée avec succès !' : 'Invitation sent successfully!';
        inviteMessage.className = 'mt-4 text-sm font-bold text-emerald-600';
        inviteForm.reset();
      } catch (err: any) {
        inviteMessage.innerText = err.message;
        inviteMessage.className = 'mt-4 text-sm font-bold text-red-500';
      } finally {
        inviteBtn.classList.remove('loading');
      }
    });
  }
</script>
