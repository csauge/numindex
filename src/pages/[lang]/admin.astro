---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import { ACTION_ICONS } from '../../utils/categories';

const { lang } = Astro.params as { lang: 'fr' | 'en' };

const translations = {
  fr: { 
    title: "Modération", 
    noPending: "Aucune suggestion en attente.", 
    loading: "Chargement des suggestions...",
    approve: "Approuver", 
    correct: "Corriger",
    reject: "Rejeter",
    action_create: "Nouveau",
    action_update: "Modification",
    action_delete: "Suppression",
    reason_label: "Motif de suppression :",
    target_id: "ID cible :",
    back: "Retour à l'accueil",
    by: "Par",
    submittedBy: "Proposé par :",
    diff_notice: "Champs modifiés entourés en rouge."
  },
  en: { 
    title: "Moderation", 
    noPending: "No pending suggestions.", 
    loading: "Loading suggestions...",
    approve: "Approve", 
    correct: "Correct",
    reject: "Reject",
    action_create: "New",
    action_update: "Update",
    action_delete: "Delete",
    reason_label: "Deletion reason:",
    target_id: "Target ID:",
    back: "Back to home",
    by: "By",
    submittedBy: "Submitted by:",
    diff_notice: "Modified fields highlighted in red."
  }
};
const t = translations[lang as keyof typeof translations] || translations.fr;
---

<Layout title={t.title} lang={lang}>
  <div class="max-w-4xl mx-auto">
    <div class="mb-8 flex justify-between items-center">
      <a href={`/${lang}`} class="text-sm font-medium text-emerald-700 hover:text-emerald-900 flex items-center gap-1 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        {t.back}
      </a>
      <span id="diff-notice" class="hidden text-[10px] font-bold text-red-500 uppercase tracking-widest bg-red-50 px-3 py-1 rounded-full border border-red-100">
        ⚠️ {t.diff_notice}
      </span>
    </div>

    <h1 class="text-3xl font-black mb-8">{t.title}</h1>

    <div id="loading-state" class="bg-white border border-stone-100 p-12 rounded-3xl text-center shadow-sm">
      <span class="loading loading-spinner loading-lg text-primary mb-4"></span>
      <p class="text-stone-400 font-medium italic">{t.loading}</p>
    </div>

    <div id="empty-state" class="hidden bg-stone-50 border border-stone-200 p-12 rounded-3xl text-center">
      <p class="text-stone-400 font-medium italic">{t.noPending}</p>
    </div>

    <div id="suggestions-list" class="grid gap-6"></div>

    <div id="access-denied" class="hidden bg-white border border-stone-50 p-12 rounded-3xl text-center shadow-xl shadow-stone-100/50 max-w-lg mx-auto mt-12">
      <div class="w-20 h-20 bg-red-50 text-red-500 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      </div>
      <h2 class="text-2xl font-black text-stone-800 mb-2">{lang === 'fr' ? 'Accès réservé' : 'Access Restricted'}</h2>
      <p class="text-stone-500 mb-8 leading-relaxed italic">{lang === 'fr' ? 'Désolé, cette page est réservée aux administrateurs de l\'index.' : 'Sorry, this page is restricted to index administrators.'}</p>
      <a href={`/${lang}`} class="btn btn-primary rounded-2xl px-12 font-black shadow-md shadow-emerald-200">{lang === 'fr' ? "Retour à l'accueil" : "Back to Home"}</a>
    </div>
  </div>
</Layout>

<script>
  import { supabase, getImageUrl } from '../../lib/supabase/client';
  import { getCategoryLabel, getCategoryIcon, ACTION_ICONS } from '../../utils/categories';
  import { fetchAllProfiles } from '../../lib/services';
  import type { Suggestion, Resource, Profile } from '../../lib/supabase/types';

  const lang = (document.documentElement.lang || 'fr') as 'fr' | 'en';
  const listContainer = document.getElementById('suggestions-list');
  const loadingState = document.getElementById('loading-state');
  const emptyState = document.getElementById('empty-state');
  const accessDenied = document.getElementById('access-denied');
  const diffNotice = document.getElementById('diff-notice');

  async function loadModeration() {
    if (!supabase) {
      console.error('[Admin] Supabase client not initialized');
      return;
    }

    try {

      const { data: { session }, error: sessionError } = await supabase.auth.getSession();
      
      if (sessionError) throw sessionError;
      if (!session) {
        console.warn('[Admin] Aucune session trouvée, redirection...');
        window.location.href = `/${lang}/login?redirect=admin`;
        return;
      }

      // Check role via profile
      const { data: profile, error: profileError } = await supabase
        .from('profiles')
        .select('role')
        .eq('id', session.user.id)
        .single();
      
      if (profileError) throw profileError;

      if (profile?.role !== 'admin') {
        loadingState?.classList.add('hidden');
        accessDenied?.classList.remove('hidden');
        document.querySelector('h1')?.classList.add('hidden');
        return;
      }

      const { data: suggestions, error: sugError } = await supabase
        .from('suggestions')
        .select('*')
        .eq('status', 'pending')
        .order('created_at', { ascending: false });

      if (sugError) throw sugError;

      if (!suggestions || suggestions.length === 0) {
        loadingState?.classList.add('hidden');
        emptyState?.classList.remove('hidden');
        return;
      }

      const { data: resources } = await supabase.from('resources').select('*');
      const profiles = await fetchAllProfiles();

      loadingState?.classList.add('hidden');
      if (suggestions.some(s => s.action === 'update')) diffNotice?.classList.remove('hidden');

      listContainer!.innerHTML = suggestions.map(res => renderSuggestion(res, resources || [], profiles)).join('');
      attachEvents();
    } catch (err: any) {
      console.error('[Admin] Erreur critique lors du chargement :', err);
      if (loadingState) {
        loadingState.innerHTML = `
          <div class="text-error font-bold p-4 bg-red-50 rounded-xl border border-red-100">
            Une erreur est survenue lors du chargement :<br/>
            <span class="text-xs font-mono">${err.message || 'Erreur inconnue'}</span>
          </div>
        `;
      }
    }
  }

  function renderSuggestion(res: Suggestion, allResources: Resource[], allProfiles: Profile[]) {
    const actionClass = getActionClass(res.action);
    const actionIcon = ACTION_ICONS[res.action] || ACTION_ICONS.create;
    
    const isMod = (field: string) => {
      if (res.action !== 'update' || !res.resource_id) return false;
      const original = allResources.find(r => r.id === res.resource_id);
      if (!original) return false;
      if (field === 'city' || field === 'published_at' || field === 'next_date') return res.metadata?.[field] !== original.metadata?.[field];
      return (res as any)[field] !== (original as any)[field];
    };

    const diffClass = "ring-2 ring-red-500 ring-offset-2 rounded-sm";
    const proposer = allProfiles.find(p => p.id === res.submitted_by)?.full_name || '...';

    return `
      <article class="suggestion-card bg-white border border-stone-200 rounded-2xl p-6 flex flex-col md:flex-row gap-6 items-start relative overflow-hidden">
        <div class="w-full md:w-48 aspect-video rounded-xl overflow-hidden bg-stone-50/50 border border-stone-100 flex-shrink-0 relative flex items-center justify-center text-stone-200 ${isMod('image_url') ? diffClass : ''}">
          ${res.image_url ? `<img src="${getImageUrl(res.image_url)}" class="absolute inset-0 w-full h-full object-contain p-2" />` : `
            <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="${getCategoryIcon(res.category)}" />
            </svg>
          `}
        </div>
        
        <div class="flex-grow w-full">
          <div class="flex flex-wrap items-center gap-2 mb-3">
            <span class="flex items-center gap-1.5 px-2.5 py-1 rounded-lg border text-[10px] font-black uppercase tracking-wider shadow-sm ${actionClass}">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="${actionIcon}"/></svg>
              ${res.action === 'create' ? 'Nouveau' : (res.action === 'update' ? 'Modification' : 'Suppression')}
            </span>
            <span class="badge badge-outline badge-sm uppercase text-[10px] font-bold ${isMod('category') ? diffClass : ''}">
              ${getCategoryLabel(res.category, lang)}
            </span>
            ${res.metadata?.city ? `<span class="flex items-center gap-1 text-[10px] font-bold text-stone-400 uppercase tracking-wider bg-stone-50 px-2 py-0.5 rounded border border-stone-100 ${isMod('city') ? diffClass : ''}">${res.metadata.city}</span>` : ''}
          </div>

          <h2 class="text-xl font-bold mb-1 inline-block ${isMod('title') ? diffClass : ''}">${res.title}</h2>

          <div class="flex flex-col gap-1 mb-3">
            <p class="text-[10px] font-bold text-stone-300 uppercase">
              ${res.action === 'create' ? 'Proposé par :' : 'Modification par :'} 
              <span class="text-stone-400 ml-1">${proposer}</span>
            </p>
            ${res.resource_id && res.action !== 'create' ? `<p class="text-[10px] text-stone-300 font-mono tracking-tighter opacity-70">ID cible : <a href="/${lang}/resource/${res.resource_id}" target="_blank" class="underline hover:text-primary transition-colors ml-1">${res.resource_id}</a></p>` : ''}
          </div>

          <p class="text-stone-500 text-sm mb-4 ${isMod('description') ? diffClass : ''}">${res.description}</p>
          
          ${res.tags && res.tags.length > 0 ? `
            <div class="flex flex-wrap gap-1 mb-4 ${isMod('tags') ? diffClass : ''}">
              ${res.tags.map(tag => `<span class="text-[10px] bg-stone-100 px-2 py-0.5 rounded text-stone-400">#${tag}</span>`).join('')}
            </div>
          ` : ''}

          <a href="${res.link}" target="_blank" class="text-xs text-primary font-bold underline mb-4 inline-block ${isMod('link') ? diffClass : ''}">${res.link}</a>

          ${res.action === 'delete' ? `<div class="mt-4 bg-red-50 p-4 rounded-xl border border-red-100 mb-4"><p class="text-xs font-bold text-red-800 uppercase mb-1">Motif :</p><p class="text-red-700 italic text-sm">${res.reason}</p></div>` : ''}
        </div>

        <div class="flex md:flex-col gap-2 w-full md:w-auto">
          <button class="btn btn-primary btn-sm flex-grow approve-btn" data-id="${res.id}">Approuver</button>
          ${res.action !== 'delete' ? `<a href="/${lang}/propose?sid=${res.id}&moderation=true" class="btn btn-outline btn-sm">Corriger</a>` : ''}
          <button class="btn btn-ghost btn-sm text-error flex-grow reject-btn" data-id="${res.id}">Rejeter</button>
        </div>
      </article>
    `;
  }

  function getActionClass(action: string) {
    if (action === 'update') return 'bg-emerald-100 text-emerald-700 border-emerald-200';
    if (action === 'delete') return 'bg-red-100 text-red-700 border-red-200';
    return 'bg-emerald-600 text-white border-emerald-700';
  }

  function attachEvents() {
    document.querySelectorAll('.approve-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-id');
        btn.classList.add('loading');

        const { data, error: fetchError } = await supabase!.from('suggestions').select('*').eq('id', id).single();
        if (fetchError || !data) {
          btn.classList.remove('loading');
          return;
        }

        const payload: any = {
          title: data.title,
          description: data.description,
          link: data.link,
          category: data.category,
          image_url: data.image_url,
          metadata: data.metadata,
          tags: data.tags,
          related_ids: data.related_ids
        };

        let resError = null;
        if (data.action === 'create') {
          payload.created_by = data.submitted_by;
          const { error } = await supabase!.from('resources').insert([payload]);
          resError = error;
        } else if (data.action === 'update') {
          payload.updated_by = data.submitted_by;
          const { error } = await supabase!.from('resources').update(payload).eq('id', data.resource_id);
          resError = error;
        } else if (data.action === 'delete') {
          const { error } = await supabase!.from('resources').delete().eq('id', data.resource_id);
          resError = error;
        }

        if (resError) {
          console.error("Erreur lors de l'approbation :", resError);
          alert(`Erreur : ${resError.message}`);
          btn.classList.remove('loading');
        } else {
          await supabase!.from('suggestions').update({ status: 'approved' }).eq('id', id);
          location.reload();
        }
      });
    });

    document.querySelectorAll('.reject-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.getAttribute('data-id');
        if (confirm('Rejeter ?')) {
          await supabase!.from('suggestions').update({ status: 'rejected' }).eq('id', id);
          location.reload();
        }
      });
    });
  }

  loadModeration();
</script>
