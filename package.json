    "test:unit": "vitest run",
    "verify": "npm run verify-sobriety && npm run build && npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/sitemap": "^3.2.1",
    "@supabase/supabase-js": "^2.102.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^5.4.2",
    "browser-image-compression": "^2.0.2",
    "daisyui": "^5.5.19",
    "marked": "^18.0.0",
    "rss-parser": "^3.13.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/marked": "^6.0.0",
    "dotenv": "^17.4.1",
    "happy-dom": "^20.8.9",
    "pagefind": "^1.5.0",
