{
  "name": "numindex",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "add-ressource": "node scripts/add-ressource.mjs",
    "postbuild": "pagefind --site dist && cp dist/sitemap-index.xml dist/sitemap.xml && node scripts/fix-routes.mjs",
    "cleanup-images": "node scripts/cleanup-images.mjs",
    "optimize-images": "node scripts/optimize-images.mjs",
    "verify-sobriety": "node scripts/verify-sobriety.mjs",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "verify": "npm run verify-sobriety && npm run build && npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "^6.0.2",
    "@supabase/supabase-js": "^2.98.0",
    "astro": "^5.4.1",
    "browser-image-compression": "^2.0.2",
    "daisyui": "^4.12.24",
    "marked": "^17.0.5",
    "sharp": "^0.34.5",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/marked": "^5.0.2",
    "autoprefixer": "^10.4.24",
    "dotenv": "^17.3.1",
    "happy-dom": "^20.8.9",
    "pagefind": "^1.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vitest": "^4.1.2"
  }
}
